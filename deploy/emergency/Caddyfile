# emergency-origin is validated before production DNS moves. Caddy continues
# retrying the onsilo.dev certificate after activation; keep the emergency
# hostname available until cleanup so certificate renewal and diagnostics work.
emergency-origin.onsilo.dev, onsilo.dev {
	tls {
		dns cloudflare {env.CLOUDFLARE_DNS_API_TOKEN}
	}
	encode zstd gzip
	reverse_proxy dataplane:3001
}
