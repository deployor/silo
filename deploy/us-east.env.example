# Common Compose settings (store real values in Dokploy/Infisical, not Git)
SILO_REGION=us-east
SILO_INSTANCE_ID=us-east-a
COMPOSE_PROFILES=
SILO_DATAPLANE_ENV_FILE=.env
DRAGONFLY_IMAGE=docker.dragonflydb.io/dragonflydb/dragonfly:<reviewed-version-or-digest>
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:<reviewed-version-or-digest>
REDIS_PASSWORD=<unique-us-cache-password>
DRAGONFLY_MAX_MEMORY=8gb
DATAPLANE_DATABASE_MAX_CONNECTIONS=3
DATAPLANE_REPLICATION_WORKERS=1
SIGNOZ_OTLP_ENDPOINT=signoz.example.internal:4317
SIGNOZ_INGESTION_KEY=<secret-if-required>
# Set COMPOSE_PROFILES=observability when a real SigNoz destination is ready.

DATAPLANE_ORIGIN_DOMAINS=onsilo.dev,eu.onsilo.dev,us.onsilo.dev,eu-origin.onsilo.dev,us-origin.onsilo.dev
DATAPLANE_INGRESS_DOMAINS={"onsilo.dev":"eu-central","eu.onsilo.dev":"eu-central","us.onsilo.dev":"us-east","eu-origin.onsilo.dev":"eu-central","us-origin.onsilo.dev":"us-east"}
DATAPLANE_REGION_PEERS={"eu-central":"https://eu-origin.onsilo.dev"}
CONTROL_PLANE_URL=https://control-origin.onsilo.dev

# Normal operation is local-only. Infisical renders the actual JSON into the
# dataplane secret file; never put B2 keys in this Compose environment file.
DATAPLANE_FAILOVER_REGIONS=

# Used by regional migration and failover tooling. There is no US Bun service.
CLICKHOUSE_QUERY_URLS=https://logs-us.onsilo.dev,https://logs-eu.onsilo.dev
CLICKHOUSE_QUERY_USER=silo_query
CLICKHOUSE_QUERY_PASSWORD=<shared-read-only-password>

# docker-compose.prod.yml writes accounting to PostgreSQL or the persistent
# dataplane-cache disk spool. Dragonfly is never an accounting durability tier.
