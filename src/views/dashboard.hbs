{{#if user.dataExported}}
<div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 mb-8 text-center">
    <h3 class="text-blue-400 font-bold text-lg">Your account is frozen</h3>
    <p class="text-blue-300 text-sm mt-1 max-w-2xl mx-auto">
        You've downloaded your data, so we've locked your account to keep everything consistent. You can't upload new files or change settings anymore, and your data will be permanently deleted soon.
    </p>
</div>
{{else}}
  {{#if user.markedAsOverAge}}
  <div class="bg-hc-dark border border-white/10 rounded-3xl p-6 mb-8 card-shadow flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-start gap-4">
          <div class="shrink-0 p-3 bg-white/10 rounded-xl text-white">
              <i class="ph ph-warning-circle text-2xl"></i>
          </div>
          <div>
              <h3 class="text-white font-bold text-lg">Your account is closing soon.</h3>
              <p class="text-text-muted text-sm mt-1 max-w-xl">
                  Since you're 18, you've aged out of Silo. We've disabled creating new resources, and your existing data will be permanently deleted in 2 months.
              </p>
          </div>
      </div>
      <a href="/dashboard/offboarding" class="shrink-0 bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow whitespace-nowrap">
        Start Migration <i class="ph ph-arrow-right"></i>
      </a>
  </div>
  {{/if}}
{{/if}}

<!-- Mission Control Section (YSWS) -->
<div class="mb-12">
    {{#if latestSubmission}}
        {{#if (eq latestSubmission.status 'pending')}}
            <!-- Pending Submission -->
            <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow relative overflow-hidden group">
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                    <div class="flex-1 text-center md:text-left">
                        <div class="inline-flex items-center gap-2 bg-yellow-500/10 text-yellow-400 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-yellow-500/20">
                            <i class="ph-fill ph-clock-countdown animate-pulse"></i>
                            Under Review
                        </div>
                        <h2 class="text-3xl font-black text-white italic tracking-tight mb-2">
                            "{{latestSubmission.projectName}}" is in the pipeline.
                        </h2>
                        <p class="text-text-muted text-lg max-w-xl">
                            We're reviewing your submission. Once approved, your storage quota will be upgraded automatically.
                        </p>
                    </div>
                    <div class="shrink-0">
                        <a href="/ysws/history" class="bg-white/5 hover:bg-white/10 text-white px-6 py-4 rounded-xl text-lg font-bold transition-all border border-white/10 flex items-center gap-3">
                            <i class="ph-bold ph-clock-counter-clockwise"></i>
                            View History
                        </a>
                    </div>
                </div>
            </div>
        {{else}}
             <!-- Approved/Rejected (Show CTA for next project) -->
            <div class="bg-hc-dark rounded-3xl card-shadow relative overflow-hidden group border border-white/10 p-8">
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                        <div class="flex-1 text-center md:text-left">
                            <h2 class="text-3xl md:text-4xl font-black text-white italic tracking-tight mb-3">
                                Ship projects. <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-400">Get paid in storage.</span>
                            </h2>
                            <p class="text-text-muted text-lg max-w-xl mb-6">
                                Built something cool? Submit it to YSWS. Every shipped project unlocks <span class="text-white font-bold">{{yswsQuotaPerHourHuman}} of permanent storage</span>.
                            </p>
                             <div class="flex flex-wrap items-center justify-center md:justify-start gap-4">
                                <a href="/ysws/submit" class="bg-hc-red hover:bg-red-500 text-white px-8 py-4 rounded-xl text-lg font-bold transition-all shadow-lg shadow-hc-red/20 hover:scale-105 flex items-center gap-3">
                                    <i class="ph-bold ph-rocket-launch"></i>
                                    Ship a Project
                                </a>
                            </div>
                        </div>
                        <div class="shrink-0 hidden md:block opacity-80 group-hover:opacity-100 transition-opacity transform group-hover:scale-105 duration-500">
                             <i class="ph-duotone ph-package text-9xl text-white/10"></i>
                        </div>
                    </div>
                </div>
            </div>
        {{/if}}
    {{else}}
        <!-- No Submissions yet (First time CTA) -->
        <div id="low-storage-ysws-cta" class="bg-hc-dark rounded-3xl p-6 md:p-8 card-shadow relative overflow-hidden group mb-8 border border-white/10 hidden">
            <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
                <div class="text-center md:text-left">
                    <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight mb-2">
                        Low on storage? <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-400">Ship something.</span>
                    </h2>
                    <p class="text-text-muted text-sm md:text-base max-w-2xl">
                        Submit a YSWS project to unlock more permanent storage.
                    </p>
                </div>
                <a href="/ysws/submit" class="shrink-0 bg-hc-red hover:bg-red-500 text-white px-6 py-3 rounded-xl text-sm md:text-base font-bold transition-all shadow-lg shadow-hc-red/20 hover:scale-105 flex items-center gap-2">
                    <i class="ph-bold ph-rocket-launch"></i>
                    Ship a Project
                </a>
            </div>
        </div>
        </div>
    {{/if}}
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-hc-dark rounded-3xl p-6 border border-white/10 card-shadow">
    <h3 class="text-text-muted text-sm font-bold uppercase tracking-wider mb-2">
      Storage Usage
    </h3>
    <div class="flex items-baseline gap-2">
      <span class="text-3xl font-bold text-white" id="storage-usage">0</span>
      <span class="text-text-muted text-sm font-mono" id="storage-limit-container">/ <span id="storage-limit">0</span> GB</span>
    </div>
    <div class="w-full bg-white/5 rounded-full h-2 mt-4 overflow-hidden">
      <div class="bg-hc-red h-2 rounded-full transition-all duration-500" id="storage-bar" style="width: 0%"></div>
    </div>
  </div>

  <div class="bg-hc-dark rounded-3xl p-6 border border-white/10 card-shadow">
    <h3 class="text-text-muted text-sm font-bold uppercase tracking-wider mb-2">
      Total Traffic
    </h3>
    <div class="flex flex-col gap-2 font-mono">
      <div class="flex justify-between text-sm">
        <span class="text-emerald-400">Ingress (In)</span>
        <span id="ingress-bytes" class="text-white">0 GB</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-hc-red">Egress (Out)</span>
        <div class="text-right">
          <span id="egress-bytes" class="text-white">0 GB</span>
          <span class="text-text-muted text-xs block" id="egress-limit">/ 0 GB</span>
        </div>
      </div>
      <div class="w-full bg-white/5 rounded-full h-1.5 mt-1 overflow-hidden">
        <div class="bg-hc-red h-1.5 rounded-full transition-all duration-500" id="egress-bar" style="width: 0%"></div>
      </div>
      <div class="mt-1 pt-2 border-t border-white/10 flex justify-between font-bold">
        <span class="text-text-muted">Total</span>
        <span id="total-bytes" class="text-white">0 GB</span>
      </div>
    </div>
  </div>

  <div class="bg-hc-dark rounded-3xl p-6 border border-white/10 card-shadow">
    <h3 class="text-text-muted text-sm font-bold uppercase tracking-wider mb-2">
      API Requests
    </h3>
    <div class="flex items-baseline gap-2">
      <span class="text-3xl font-bold text-white" id="total-requests">0</span>
      <span class="text-text-muted text-sm">requests</span>
    </div>
    <p class="text-xs text-text-muted mt-2">
      Lifetime total across all buckets
    </p>
  </div>
</div>

<!-- Buckets Section -->
<div class="bg-hc-dark rounded-3xl border border-white/10 overflow-hidden card-shadow">
  <div class="p-6 border-b border-white/10 flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-white">Your Storage Inventory</h2>
      <p class="text-text-muted text-sm mt-1">
        <span id="bucket-count" class="text-white font-mono">0</span> / <span id="bucket-limit" class="text-white font-mono">0</span>
        buckets utilized
      </p>
    </div>
    <button onclick="openCreateModal()" class="bg-white/5 hover:bg-white/10 text-white border border-white/10 px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105">
      + New Bucket
    </button>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm">
      <thead class="bg-white/5 text-text-muted font-bold uppercase text-xs tracking-wider">
        <tr>
          <th class="px-6 py-4">Name</th>
          <th class="px-6 py-4">Keys</th>
          <th class="px-6 py-4">Usage</th>
          <th class="px-6 py-4">Visibility</th>
          <th class="px-6 py-4">Created</th>
          <th class="px-6 py-4 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5" id="buckets-table">
        <!-- Buckets will be inserted here -->
      </tbody>
    </table>
  </div>
</div>

{{#section "modals"}}
  <!-- Create Bucket Modal -->
  <div id="create-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
      <h3 class="text-2xl font-bold mb-6 text-white">Create New Bucket</h3>
      <form id="create-bucket-form" onsubmit="createBucket(event)">
        <div class="mb-6">
          <label class="block text-sm font-bold text-text-muted mb-2 uppercase tracking-wider">Bucket Name</label>
          <input type="text" name="name" required minlength="3" pattern="[a-z0-9\-]+" class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-red focus:ring-1 focus:ring-hc-red font-mono placeholder-white/20 transition-colors" placeholder="my-awesome-project" />
          <p class="text-xs text-text-muted mt-2">
            Only lowercase letters, numbers, and hyphens. Minimum 3 characters. Names starting with 'u' or 'w' followed by numbers are reserved.
          </p>
          <p class="text-xs text-text-muted mt-2">
            Bucket names are global (not per-user), can’t be changed later, and should match your project. Some names (like <span class="font-mono">dashboard</span>) are reserved.
          </p>
        </div>
        <div class="flex justify-end gap-3">
          <button type="button" onclick="closeCreateModal()" class="text-text-muted hover:text-white px-4 py-2 text-sm font-bold transition-colors">
            Cancel
          </button>
          <button type="submit" class="bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow">
            Create Bucket
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- CORS Modal -->
  <div id="cors-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-2xl card-shadow transform transition-all">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h3 class="text-2xl font-bold text-white">CORS Configuration</h3>
          <p class="text-text-muted text-sm mt-1 font-mono" id="cors-bucket-name">bucket-name</p>
        </div>
        <button onclick="closeCorsModal()" class="text-text-muted hover:text-white transition-colors">
          <i class="ph ph-x text-2xl"></i>
        </button>
      </div>

      <div class="mb-6">
        <p class="text-text-muted text-sm mb-4">
          Configure Cross-Origin Resource Sharing (CORS) for this bucket. Enter a JSON array of rules.
        </p>
        <textarea id="cors-editor" class="w-full h-64 bg-black/30 border border-white/10 rounded-xl p-4 text-white font-mono text-sm focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue resize-none" placeholder='[
  {
    "AllowedOrigins": ["*"],
    "AllowedMethods": ["GET", "HEAD"],
    "AllowedHeaders": ["*"],
    "ExposeHeaders": [],
    "MaxAgeSeconds": 3000
  }
]'></textarea>
        <p class="text-xs text-red-400 mt-2 hidden" id="cors-error"></p>
      </div>

      <div class="flex justify-end gap-3">
        <button onclick="resetCors()" class="text-text-muted hover:text-white px-4 py-2 text-sm font-bold transition-colors">
          Reset
        </button>
        <button onclick="saveCors()" class="bg-hc-blue hover:bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow">
          Save Configuration
        </button>
      </div>
    </div>
  </div>

  <!-- Manage Keys Modal -->
  <div id="manage-keys-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-4xl card-shadow transform transition-all max-h-[90vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h3 class="text-2xl font-bold text-white">Manage Keys</h3>
          <p class="text-text-muted text-sm mt-1 font-mono" id="manage-keys-bucket-name">bucket-name</p>
        </div>
        <button onclick="closeManageKeysModal()" class="text-text-muted hover:text-white transition-colors">
          <i class="ph ph-x text-2xl"></i>
        </button>
      </div>

      <div class="bg-black/30 rounded-xl border border-white/10 overflow-hidden mb-6 max-h-[55vh] overflow-y-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-white/5 text-text-muted font-bold uppercase text-xs tracking-wider sticky top-0">
            <tr>
              <th class="px-4 py-3">Access Key ID</th>
              <th class="px-4 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5" id="manage-keys-table">
            <!-- Keys will be inserted here -->
          </tbody>
        </table>
      </div>

      <div class="flex items-center justify-between">
        <div class="text-xs text-text-muted font-mono">
          <span id="manage-keys-count" class="text-white">0</span><span class="text-text-muted"> / <span id="manage-keys-limit">0</span> keys</span>
        </div>
        <button id="manage-keys-generate-btn" onclick="generateKeyFromModal()" class="bg-hc-blue hover:bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow">
          + Generate New Key
        </button>
      </div>
    </div>
  </div>

  <!-- Secret Key Modal -->
  <div id="key-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow">
      <div class="flex items-center gap-3 mb-2">
        <div class="bg-emerald-500/20 p-2 rounded-full text-emerald-400">
          <i class="ph ph-check-circle text-2xl"></i>
        </div>
        <h3 class="text-2xl font-bold text-white">Bucket Created!</h3>
      </div>
      <p class="text-text-muted text-sm mb-6 ml-11">
