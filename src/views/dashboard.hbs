            <div class="font-mono text-sm select-all text-emerald-400 overflow-x-auto whitespace-nowrap scrollbar-thin flex-1" id="new-secret-key"></div>
            <button id="btn-new-secret-key" onclick="copyToClipboard('new-secret-key')" class="text-text-muted hover:text-white transition-colors p-1" title="Copy">
              <i class="ph ph-copy text-lg"></i>
            </button>
          </div>
        </div>
        <div>
          <label class="text-xs text-text-muted font-bold uppercase tracking-wider block mb-1">Endpoint</label>
          <div class="flex items-center gap-2 bg-black/20 rounded-lg p-2 border border-white/5 hover:border-white/10 transition-colors">
            <div class="font-mono text-sm select-all text-hc-red overflow-x-auto whitespace-nowrap scrollbar-thin flex-1" id="new-endpoint">
              https://silo.deployor.dev
            </div>
            <button id="btn-new-endpoint" onclick="copyToClipboard('new-endpoint')" class="text-text-muted hover:text-white transition-colors p-1" title="Copy">
              <i class="ph ph-copy text-lg"></i>
            </button>
          </div>
        </div>

        <div>
          <label class="text-xs text-text-muted font-bold uppercase tracking-wider block mb-1">Public URL Example</label>
          <div class="flex items-center gap-2 bg-black/20 rounded-lg p-2 border border-white/5 hover:border-white/10 transition-colors">
            <div class="font-mono text-sm select-all text-hc-blue overflow-x-auto whitespace-nowrap scrollbar-thin flex-1" id="new-public-url">
              ...
            </div>
            <button id="btn-new-public-url" onclick="copyToClipboard('new-public-url')" class="text-text-muted hover:text-white transition-colors p-1" title="Copy">
              <i class="ph ph-copy text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <button onclick="closeKeyModal()" class="w-full bg-white/10 hover:bg-white/20 text-white px-4 py-3 rounded-xl text-sm font-bold transition-colors border border-white/5 hover:border-white/20">
        I have saved my keys
      </button>
    </div>
  </div>

  <!-- Confirmation Modal -->
  <div id="confirm-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
      <h3 class="text-2xl font-bold mb-4 text-white" id="confirm-title">
        Confirm Action
      </h3>
      <p class="text-text-muted mb-8" id="confirm-message">
        Are you sure you want to proceed?
      </p>

      <div class="flex justify-end gap-3">
        <button onclick="closeConfirmModal()" class="text-text-muted hover:text-white px-4 py-2 text-sm font-bold transition-colors">
          Cancel
        </button>
        <button id="confirm-btn" class="bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow flex items-center gap-2">
          <span id="confirm-btn-text">Confirm</span>
          <i id="confirm-spinner" class="ph ph-spinner animate-spin text-lg hidden"></i>
        </button>
      </div>
    </div>
  </div>
{{/section}}

{{#section "extraScripts"}}
<script>
  // Format bytes to human readable string
  function formatBytes(bytes, decimals = 2) {
    if (!+bytes) return "0 Bytes";
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ["Bytes", "KB", "MB", "GB", "TB", "PB", "EB", "ZB", "YB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return `${parseFloat((bytes / k ** i).toFixed(dm))} ${sizes[i]}`;
  }

  function escapeHtml(unsafe) {
    if (unsafe === null || unsafe === undefined) return "";
    return String(unsafe)
      .replace(/&/g, "&")
      .replace(/</g, "<")
      .replace(/>/g, ">")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function escapeJs(unsafe) {
    if (unsafe === null || unsafe === undefined) return "";
    return String(unsafe)
        .replace(/\\/g, '\\\\')
        .replace(/'/g, "\\'")
        .replace(/"/g, '\\"');
  }

  let currentDashboardData = null;
  let currentManagedBucket = null;
  let currentCorsBucket = null;

  async function loadDashboard() {
    try {
      const res = await fetch("/api/dashboard/stats");
      if (!res.ok) throw new Error("Failed to load stats");
      const data = await res.json();
      currentDashboardData = data;

      // Update User Info
      // document.getElementById("user-id").textContent = data.user.id;
      
      // if (data.user.isAdmin) {
      //   document.getElementById("admin-link").classList.remove("hidden");
      // }

      // if (data.user.slackId) {
      //   const avatar = document.getElementById("user-avatar");
      //   const newSrc = `https://cachet.dunkirk.sh/users/${data.user.slackId}/r`;
        
      //   if (avatar.getAttribute("src") !== newSrc) {
      //     avatar.classList.add("hidden");
      //     avatar.onload = () => avatar.classList.remove("hidden");
      //     avatar.onerror = () => avatar.classList.add("hidden");
      //     avatar.src = newSrc;
      //   }
      // }

      // Update Storage Stats
      const storageUsage = Number(data.user.storageUsage) || 0;
      const storageLimit = Number(data.user.storageLimit) || 1073741824;
      const storagePercent = storageLimit > 0 ? (storageUsage / storageLimit) * 100 : 0;

      document.getElementById("storage-usage").textContent = formatBytes(storageUsage);
      const storageLimitContainer = document.getElementById("storage-limit-container");

      if (data.user.isImmortal) {
        if (storageLimitContainer) storageLimitContainer.innerHTML = '/ ∞';
        
        const bar = document.getElementById("storage-bar");
        bar.style.width = "100%";
        bar.className = "bg-amber-400 h-2 rounded-full transition-all duration-500 shadow-[0_0_10px_rgba(251,191,36,0.3)]";
      } else {
        const limitGB = (storageLimit / (1024 * 1024 * 1024)).toFixed(0);
        if (storageLimitContainer && !document.getElementById("storage-limit")) {
             storageLimitContainer.innerHTML = `/ <span id="storage-limit">${limitGB}</span> GB`;
        } else if (document.getElementById("storage-limit")) {
             document.getElementById("storage-limit").textContent = limitGB;
        }

        const percent = Math.min(storagePercent, 100);
        const bar = document.getElementById("storage-bar");
        bar.style.width = `${percent}%`;
        bar.className = "bg-hc-red h-2 rounded-full transition-all duration-500";
      }

      const lowStorageCta = document.getElementById("low-storage-ysws-cta");
      if (lowStorageCta) {
        const LOW_STORAGE_THRESHOLD_PERCENT = 80;
        const isLowOnStorage = storagePercent >= LOW_STORAGE_THRESHOLD_PERCENT;
        lowStorageCta.classList.toggle("hidden", data.user.isImmortal || !isLowOnStorage);
      }

      // Update Traffic Stats
      const ingressBytes = Number(data.user.ingressBytes) || 0;
      const egressBytes = Number(data.user.egressBytes) || 0;

      document.getElementById("ingress-bytes").textContent = formatBytes(ingressBytes);
      document.getElementById("egress-bytes").textContent = formatBytes(egressBytes);
      
      // Egress Limit Logic
      let egressLimitBytes;
      let egressLimitText;
      
      if (data.user.isImmortal) {
         egressLimitBytes = Infinity;
         egressLimitText = "/ ∞";
      } else if (data.user.egressLimit === null || data.user.egressLimit === undefined) {
         // Default: Max(10GB, 3x Storage)
         const calculated = storageLimit * 3;
         const minLimit = 10 * 1024 * 1024 * 1024; // 10GB
         egressLimitBytes = Math.max(calculated, minLimit);
         egressLimitText = `/ ${formatBytes(egressLimitBytes)} (Default)`;
      } else if (data.user.egressLimit === -1) {
         // Unlimited
         egressLimitBytes = Infinity;
         egressLimitText = "/ Unlimited";
      } else {
         // Custom
         egressLimitBytes = Number(data.user.egressLimit);
         egressLimitText = `/ ${formatBytes(egressLimitBytes)}`;
      }

      document.getElementById("egress-limit").textContent = egressLimitText;
      
      const egressBar = document.getElementById("egress-bar");
      if (data.user.isImmortal) {
         egressBar.style.width = "100%";
         egressBar.className = "bg-amber-400 h-1.5 rounded-full transition-all duration-500 shadow-[0_0_10px_rgba(251,191,36,0.3)]";
      } else {
         let egressPercent = 0;
         if (egressLimitBytes === Infinity) {
            egressPercent = 0;
         } else {
            egressPercent = Math.min((egressBytes / egressLimitBytes) * 100, 100);
         }
         egressBar.style.width = `${egressPercent}%`;
         egressBar.className = "bg-hc-red h-1.5 rounded-full transition-all duration-500";
      }
      
      document.getElementById("total-bytes").textContent = formatBytes(ingressBytes + egressBytes);
      document.getElementById("total-requests").textContent = (Number(data.user.totalRequests) || 0).toLocaleString();

      // Update Buckets List
      document.getElementById("bucket-count").textContent = data.buckets ? data.buckets.length : 0;
      const bucketLimitEl = document.getElementById("bucket-limit");
      if (bucketLimitEl) {
          if (data?.user?.isImmortal) {
              bucketLimitEl.textContent = "∞";
          } else {
              bucketLimitEl.textContent = String(Number(data?.limits?.maxBucketsPerUser) || 0);
          }
      }
      const tbody = document.getElementById("buckets-table");
      tbody.innerHTML = data.buckets
        .map(
          (bucket) => {
            const isPaused = bucket.isPaused;
            const isCdn = bucket.isCdn;
            const disabledClass = isPaused ? "opacity-50 cursor-not-allowed pointer-events-none" : "";
            const disabledAttr = isPaused ? "disabled" : "";
            
            // CDN specific classes
            const cdnDisabledClass = isCdn ? "opacity-50 cursor-not-allowed pointer-events-none" : "";
            const cdnDisabledAttr = isCdn ? "disabled" : "";

            return `
                <tr class="hover:bg-white/5 transition-colors group ${isPaused ? 'bg-red-500/5' : ''}">
                    <td class="px-6 py-4 font-medium text-white font-mono">
                        ${escapeHtml(bucket.name)}
                        ${isPaused ? `<span class="ml-2 bg-red-500/20 text-red-400 px-1.5 py-0.5 rounded text-[10px] font-bold border border-red-500/30" title="${escapeHtml(bucket.pauseReason || 'Paused by admin')}">PAUSED</span>` : ''}
                        ${isCdn ? `<span class="ml-2 bg-blue-500/20 text-blue-400 px-1.5 py-0.5 rounded text-[10px] font-bold border border-blue-500/30" title="Slack CDN Bucket">CDN</span>` : ''}
                    </td>
                    <td class="px-6 py-4 font-mono text-xs text-text-muted group-hover:text-white transition-colors">
                        ${!isCdn ? `
                        <button onclick="openManageKeysModal('${escapeJs(bucket.name)}')" class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors flex items-center gap-2 ${disabledClass}" ${disabledAttr}>
                            <i class="ph ph-key text-sm"></i>
                            ${bucket.keys.length} Keys
                        </button>` : '<span class="text-text-muted italic">Managed</span>'}
                    </td>
                    <td class="px-6 py-4 text-text-main">
                        <div class="text-xs font-mono">
                            <div>${formatBytes(bucket.totalBytes)}</div>
                            <div class="text-text-muted">${bucket.totalRequests.toLocaleString()} reqs</div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                      <label class="inline-flex items-center cursor-pointer ${disabledClass} ${cdnDisabledClass}">
                        <input type="checkbox" class="sr-only peer" onchange="togglePublic('${escapeJs(bucket.name)}', this.checked)" ${bucket.isPublic ? "checked" : ""} ${disabledAttr} ${cdnDisabledAttr}>
                        <div class="relative w-9 h-5 bg-white/10 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-hc-blue rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-hc-blue"></div>
                        <span class="ms-2 text-xs font-medium text-text-muted peer-checked:text-white">${bucket.isPublic ? "Public" : "Private"}</span>
                      </label>
                    </td>
                    <td class="px-6 py-4 text-text-muted text-xs font-mono">${new Date(bucket.createdAt).toLocaleDateString()}</td>
                    <td class="px-6 py-4 text-right flex justify-end items-center gap-3">
                        ${!isCdn ? `
                        <button onclick="openCorsModal('${escapeJs(bucket.name)}')" class="bg-white/5 hover:bg-white/10 text-text-muted hover:text-white px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors flex items-center gap-2 ${disabledClass}" ${disabledAttr}>
                            <i class="ph ph-code text-sm"></i>
                            CORS
                        </button>` : ''}
                        <a href="/dashboard/buckets/${escapeHtml(bucket.name)}" class="bg-hc-blue/10 hover:bg-hc-blue/20 text-hc-blue px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors flex items-center gap-2 ${disabledClass}">
                            <i class="ph ph-folder text-sm"></i>
                            Files
                        </a>
                        ${isCdn ?
                            `<button onclick="emptyBucket('${escapeJs(bucket.name)}')" class="text-hc-red hover:text-red-400 text-xs font-bold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-all ${disabledClass}" ${disabledAttr}>Empty</button>`
                            : (bucket.name !== data.user.slackId?.toLowerCase() ? `
                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-all">
                                <button onclick="emptyBucket('${escapeJs(bucket.name)}')" class="text-yellow-400 hover:text-yellow-300 text-xs font-bold uppercase tracking-wider ${disabledClass}" ${disabledAttr}>Empty</button>
                                <button onclick="deleteBucket('${escapeJs(bucket.name)}')" class="text-hc-red hover:text-red-400 text-xs font-bold uppercase tracking-wider ${disabledClass}" ${disabledAttr}>Delete</button>
                            </div>` : '')
                        }
                    </td>
                </tr>
            `;
          }
        )
        .join("");
    } catch (error) {
      console.error(error);
      // Redirect to login if unauthorized
      window.location.href = "/auth/login";
    }
  }

  // Modal Logic
  function openCreateModal() {
    document.getElementById("create-modal").classList.remove("hidden");
    document.getElementById("create-modal").classList.add("flex");
  }

  function closeCreateModal() {
    document.getElementById("create-modal").classList.add("hidden");
    document.getElementById("create-modal").classList.remove("flex");
  }

  async function closeKeyModal() {
    document.getElementById("key-modal").classList.add("hidden");
    document.getElementById("key-modal").classList.remove("flex");
    await loadDashboard(); // Reload to show new bucket
    if (currentManagedBucket) {
        openManageKeysModal(currentManagedBucket);
    }
  }

  async function createBucket(e) {
    e.preventDefault();
    const form = e.target;
    const name = form.name.value;

    try {
      const res = await fetch("/api/dashboard/buckets", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name }),
      });

      if (!res.ok) {
        const err = await res.text();
        alert(err);
        return;
      }

      const data = await res.json();

      closeCreateModal();
      form.reset();
      
      // Show keys modal
      document.getElementById("new-access-key").textContent = data.accessKey;
      document.getElementById("new-secret-key").textContent = data.secretKey;
      document.getElementById("new-public-url").textContent = data.publicUrl;
      document.getElementById("key-modal").classList.remove("hidden");
      document.getElementById("key-modal").classList.add("flex");
    } catch (_error) {
      console.error(_error);
      alert("Failed to create bucket");
    }
  }

  function copyToClipboard(elementId) {
    const text = document.getElementById(elementId).textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById(`btn-${elementId}`);
      const originalHTML = btn.innerHTML;
      btn.innerHTML =
        '<i class="ph ph-check text-emerald-400 text-lg"></i>';
      setTimeout(() => {
        btn.innerHTML = originalHTML;
      }, 2000);
    });
  }

  function deleteBucket(name) {
    openConfirmModal(
        "Delete Bucket",
        `Are you sure you want to delete bucket "${escapeHtml(name)}"? This action cannot be undone and all data will be permanently lost.`,
        async () => {
            const res = await fetch(`/api/dashboard/buckets/${name}`, {
                method: "DELETE",
            });

            if (!res.ok) {
                const err = await res.text();
                throw new Error(err);
            }

            await loadDashboard();
        }
    );
  }

  function emptyBucket(name) {
    openConfirmModal(
        "Empty Bucket",
        `Are you sure you want to empty bucket "${escapeHtml(name)}"? This will delete ALL files in it. This action cannot be undone.`,
        async () => {
            const res = await fetch(`/api/dashboard/buckets/${name}?empty=true`, {
                method: "DELETE",
            });

            if (!res.ok) {
                const err = await res.text();
                throw new Error(err);
            }

            await loadDashboard();
        }
    );
  }

  function generateKey(bucketName) {
    openConfirmModal(
        "Generate New Key",
        `Generate a new access key pair for bucket "${escapeHtml(bucketName)}"?`,
        async () => {
            const res = await fetch(`/api/dashboard/buckets/${bucketName}/keys`, {
                method: "POST",
            });

            if (!res.ok) {
                const err = await res.text();
                // Special-case the key limit for a nicer UX.
                if (res.status === 429 || err.includes("Key limit reached")) {
                    alert(err || "Key limit reached. Delete one to create another.");
                    return;
                }
                throw new Error(err);
            }

            const data = await res.json();

            // Show keys modal
            document.getElementById("new-access-key").textContent = data.accessKey;
            document.getElementById("new-secret-key").textContent = data.secretKey;
            document.getElementById("new-public-url").textContent = data.publicUrl;
            document.getElementById("key-modal").classList.remove("hidden");
            document.getElementById("key-modal").classList.add("flex");
        }
    );
  }

  function deleteKey(bucketName, keyId) {
    openConfirmModal(
        "Delete Key",
        `Are you sure you want to delete this access key? Any applications using it will lose access immediately.`,
        async () => {
            const res = await fetch(`/api/dashboard/buckets/${bucketName}/keys/${keyId}`, {
                method: "DELETE",
            });

            if (!res.ok) {
                const err = await res.text();
                throw new Error(err);
            }

            await loadDashboard();
            if (currentManagedBucket === bucketName) {
                openManageKeysModal(bucketName);
            }
        }
    );
  }

  function openManageKeysModal(bucketName) {
    currentManagedBucket = bucketName;
    const bucket = currentDashboardData.buckets.find(b => b.name === bucketName);
    if (!bucket) return;

    document.getElementById('manage-keys-bucket-name').textContent = bucket.name;

    const keyCount = (bucket.keys?.length || 0);

    const countEl = document.getElementById('manage-keys-count');
    if (countEl) countEl.textContent = String(keyCount);

    const limitEl = document.getElementById('manage-keys-limit');
    if (limitEl) {
         if (currentDashboardData?.user?.isImmortal) {
            limitEl.textContent = "∞";
         } else {
            limitEl.textContent = String(Number(currentDashboardData?.limits?.maxKeysPerBucket) || 0);
         }
    }

    const genBtn = document.getElementById('manage-keys-generate-btn');
    if (genBtn) {
        if (currentDashboardData?.user?.isImmortal) {
             genBtn.disabled = false;
             genBtn.classList.remove('opacity-50', 'cursor-not-allowed');
             genBtn.title = '';
        } else {
            const keyLimit = Number(currentDashboardData?.limits?.maxKeysPerBucket) || 0;
            const atLimit = keyLimit > 0 ? keyCount >= keyLimit : false;
            genBtn.disabled = atLimit;
            genBtn.classList.toggle('opacity-50', atLimit);
            genBtn.classList.toggle('cursor-not-allowed', atLimit);
            genBtn.title = atLimit ? `Key limit reached (${keyLimit}). Delete one to create another.` : '';
        }
    }

    renderManageKeysTable(bucket);

    document.getElementById('manage-keys-modal').classList.remove('hidden');
    document.getElementById('manage-keys-modal').classList.add('flex');
  }

  function closeManageKeysModal() {
    document.getElementById('manage-keys-modal').classList.add('hidden');
    document.getElementById('manage-keys-modal').classList.remove('flex');
    currentManagedBucket = null;
  }

  function openCorsModal(bucketName) {
    currentCorsBucket = bucketName;
    const bucket = currentDashboardData.buckets.find(b => b.name === bucketName);
    if (!bucket) return;

    document.getElementById('cors-bucket-name').textContent = bucket.name;
    
    // Format existing config or default
    let configStr = '';
    if (bucket.corsConfig) {
        try {
            const parsed = JSON.parse(bucket.corsConfig);
            // If it's the S3 XML structure converted to JSON, it might be wrapped in CORSConfiguration
            // But our DB stores it as { CORSRules: [...] } usually if coming from API
            // Let's just show what's in DB but formatted
            configStr = JSON.stringify(parsed.CORSRules || parsed, null, 2);
        } catch (e) {
            configStr = bucket.corsConfig;
        }
    } else {
        configStr = '[]';
    }
    
    document.getElementById('cors-editor').value = configStr;
    document.getElementById('cors-error').classList.add('hidden');

    document.getElementById('cors-modal').classList.remove('hidden');
    document.getElementById('cors-modal').classList.add('flex');
  }

  function closeCorsModal() {
    document.getElementById('cors-modal').classList.add('hidden');
    document.getElementById('cors-modal').classList.remove('flex');
    currentCorsBucket = null;
  }

  async function saveCors() {
    if (!currentCorsBucket) return;
    const editor = document.getElementById('cors-editor');
    const errorEl = document.getElementById('cors-error');
    
    try {
        const rules = JSON.parse(editor.value);
        if (!Array.isArray(rules)) throw new Error("Configuration must be an array of rules");
        
        // Basic validation
        rules.forEach(r => {
            if (!r.AllowedOrigins || !r.AllowedMethods) {
                throw new Error("Each rule must have AllowedOrigins and AllowedMethods");
            }
        });

        const res = await fetch(`/api/dashboard/buckets/${currentCorsBucket}/cors`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ rules }),
        });

        if (!res.ok) {
            const err = await res.text();
            throw new Error(err);
        }

        await loadDashboard();
        closeCorsModal();
    } catch (e) {
        errorEl.textContent = e.message;
        errorEl.classList.remove('hidden');
    }
  }

  async function resetCors() {
    if (!currentCorsBucket) return;
    if (!confirm("Are you sure you want to remove all CORS configuration?")) return;

    try {
        const res = await fetch(`/api/dashboard/buckets/${currentCorsBucket}/cors`, {
            method: "DELETE",
        });

        if (!res.ok) {
            const err = await res.text();
            throw new Error(err);
        }

        await loadDashboard();
        closeCorsModal();
    } catch (e) {
        alert("Failed to reset CORS: " + e.message);
    }
  }

  function renderManageKeysTable(bucket) {
    const tbody = document.getElementById('manage-keys-table');
    if (bucket.keys.length === 0) {
        tbody.innerHTML = '<tr><td colspan="2" class="px-4 py-8 text-center text-text-muted italic">No keys found for this bucket.</td></tr>';
        return;
    }
    tbody.innerHTML = bucket.keys.map(k => `
        <tr class="hover:bg-white/5 transition-colors">
            <td class="px-4 py-3 font-mono text-white">${escapeHtml(k.accessKey)}</td>
            <td class="px-4 py-3 text-right">
                <button onclick="deleteKey('${escapeJs(bucket.name)}', '${escapeJs(k.id)}')" class="text-hc-red hover:text-red-400 text-xs font-bold uppercase tracking-wider transition-colors">Delete</button>
            </td>
        </tr>
    `).join('');
  }

  function generateKeyFromModal() {
    if (!currentManagedBucket) return;
    generateKey(currentManagedBucket);
  }

  let pendingToggle = null;

  function openConfirmModal(title, message, onConfirm) {
    document.getElementById("confirm-title").textContent = title;
    document.getElementById("confirm-message").textContent = message;
    
    const btn = document.getElementById("confirm-btn");
    btn.onclick = async () => {
        const spinner = document.getElementById("confirm-spinner");
        const btnText = document.getElementById("confirm-btn-text");
        
        btn.disabled = true;
        spinner.classList.remove("hidden");
        btnText.textContent = "Processing...";
        
        try {
            await onConfirm();
            closeConfirmModal();
        } catch (e) {
            console.error(e);
            alert("Action failed");
        } finally {
            btn.disabled = false;
            spinner.classList.add("hidden");
            btnText.textContent = "Confirm";
        }
    };
    
    document.getElementById("confirm-modal").classList.remove("hidden");
    document.getElementById("confirm-modal").classList.add("flex");
  }

  function closeConfirmModal() {
    document.getElementById("confirm-modal").classList.add("hidden");
    document.getElementById("confirm-modal").classList.remove("flex");
    if (pendingToggle) {
        // If cancelled, revert the toggle visually
        loadDashboard();
        pendingToggle = null;
    }
  }

  function togglePublic(name, isPublic) {
    pendingToggle = { name, isPublic };
    const action = isPublic ? "make public" : "make private";
    const message = isPublic
        ? `Are you sure you want to make bucket "${escapeHtml(name)}" public? Anyone with the link will be able to view files.`
        : `Are you sure you want to make bucket "${escapeHtml(name)}" private? Only authenticated users will be able to access files.`;

    openConfirmModal(
        `Confirm ${action}`,
        message,
        async () => {
            const res = await fetch(`/api/dashboard/buckets/${name}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ isPublic }),
            });

            if (!res.ok) {
                const err = await res.text();
                throw new Error(err);
            }
            
            await loadDashboard();
            pendingToggle = null;
        }
    );
  }

  // Initial Load
  loadDashboard();
</script>
{{/section}}
