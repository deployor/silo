
<main class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-5xl mx-auto">
  
  <div class="text-center mb-12">
    <h1 class="text-5xl md:text-8xl font-black text-white mb-5 tracking-tighter italic">
      CDN
    </h1>
    <p class="text-text-muted text-lg md:text-xl max-w-2xl mx-auto font-medium mb-6">
      Drag and drop any file to upload.
    </p>

    <div class="flex flex-col items-center gap-4 mb-6">
        <div class="bg-blue-500/10 border border-blue-500/20 text-blue-300 px-4 py-2 rounded-lg text-sm inline-block max-w-xl">
            <div class="flex items-center gap-2">
                <i class="ph ph-info text-lg"></i>
                <span>Files uploaded here can be automatically posted to the <span class="font-bold text-white">#cdn</span> channel on Slack.</span>
            </div>
        </div>
        
        <div class="flex items-center gap-2">
             <input id="postToSlack" type="checkbox" class="form-checkbox h-4 w-4 bg-black/50 border-white/10 rounded text-hc-blue focus:ring-0 cursor-pointer" />
             <label for="postToSlack" class="text-text-muted text-sm cursor-pointer select-none hover:text-white transition-colors">
                Post uploaded files to #cdn
             </label>
        </div>
    </div>
    <br/>

    <div class="inline-flex flex-wrap justify-center items-center gap-3 bg-white/5 px-4 py-2 rounded-full border border-white/10 max-w-full">
        <div class="w-32 h-2 bg-white/10 rounded-full overflow-hidden">
            <div id="storage-bar" class="h-full bg-hc-red rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
        <span id="storage-text" class="text-xs font-mono text-text-muted break-words">Loading usage...</span>
    </div>
  </div>

  <!-- Upload Zone -->
  <div
    id="drop-zone"
    class="w-full max-w-3xl aspect-21/9 bg-black/30 border-2 border-dashed border-white/10 rounded-3xl flex flex-col items-center justify-center p-12 cursor-pointer relative overflow-hidden card-shadow"
  >
    <input
      type="file"
      id="file-input"
      class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
      multiple
    />
    
    <div class="text-center pointer-events-none" id="upload-prompt">
      <div class="inline-flex mb-6 text-hc-red">
        <i class="ph ph-cloud-arrow-up text-5xl"></i>
      </div>
      <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Drop files here</h3>
      <p class="text-text-muted font-mono text-sm">or click to browse</p>
      <p class="text-white/20 font-mono text-xs mt-4">Max 1GB per file</p>
    </div>

    <!-- Uploading State -->
    <div id="uploading-state" class="hidden flex-col items-center w-full max-w-md z-20 pointer-events-none">
        <div class="w-full bg-white/10 rounded-full h-3 mb-6 overflow-hidden backdrop-blur-sm">
            <div id="progress-bar" class="bg-hc-red h-3 rounded-full transition-all duration-100" style="width: 0%"></div>
        </div>
        <p class="text-white font-mono text-base md:text-lg flex items-center gap-2 text-center">
            <i class="ph ph-spinner animate-spin text-xl text-hc-red"></i>
            <span>Uploading <span id="file-count" class="font-bold text-hc-red">0</span> files...</span>
        </p>
    </div>
  </div>

  <!-- Recent Uploads -->
  <div id="results-area" class="w-full max-w-3xl mt-12 hidden">
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-bold text-text-muted uppercase tracking-wider">Recent Uploads</h3>
        <button onclick="clearResults()" class="text-xs text-text-muted hover:text-white transition-colors">Clear All</button>
    </div>
    <div class="space-y-4" id="results-list">
        <!-- Results injected here -->
    </div>
  </div>

</main>

{{#section "extraScripts"}}
<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const uploadPrompt = document.getElementById('upload-prompt');
  const uploadingState = document.getElementById('uploading-state');
  const progressBar = document.getElementById('progress-bar');
  const fileCount = document.getElementById('file-count');
  const resultsArea = document.getElementById('results-area');
  const resultsList = document.getElementById('results-list');

  // Drag & Drop Visuals
  ['dragenter', 'dragover'].forEach(eventName => {
    dropZone.addEventListener(eventName, highlight, false);
  });
  ['dragleave', 'drop'].forEach(eventName => {
    dropZone.addEventListener(eventName, unhighlight, false);
  });

  function highlight(e) {
    dropZone.classList.add('border-hc-red', 'bg-hc-red/5', 'scale-[1.02]');
    dropZone.classList.remove('border-white/10', 'bg-hc-dark');
  }

  function unhighlight(e) {
    dropZone.classList.remove('border-hc-red', 'bg-hc-red/5', 'scale-[1.02]');
    dropZone.classList.add('border-white/10', 'bg-hc-dark');
  }

  // Handle File Selection
  fileInput.addEventListener('change', handleFiles);

  async function handleFiles(e) {
    const files = e.target.files;
    if (!files.length) return;

    uploadFiles(files);
  }

  async function uploadFiles(files) {
    // Reset UI
    uploadPrompt.classList.add('hidden');
    uploadingState.classList.remove('hidden');
    uploadingState.classList.add('flex');
    fileCount.textContent = files.length;
    progressBar.style.width = '0%';

    let completed = 0;
    const total = files.length;
    const results = [];

    for (const file of files) {
        if (file.size > 1024 * 1024 * 1024) {
            results.push({ success: false, name: file.name, error: "File too large (>1GB)" });
        } else {
            const formData = new FormData();
            formData.append('file', file);

            try {
                // Check preferences
                const shouldPost = document.getElementById('postToSlack').checked;
                
                // Add query param to override default if user unchecked it
                // We'll update the API to respect this
                const res = await fetch(`/api/cdn/upload?skipSlack=${!shouldPost}`, {
                    method: 'POST',
                    body: formData
                });

                if (res.ok) {
                    const data = await res.json();
                    results.push({ success: true, name: file.name, url: data.url, size: file.size });
                } else {
                    if (res.status === 413) {
                        results.push({ success: false, name: file.name, error: "File too large" });
                    } else {
                        const err = await res.text();
                        const errorMsg = err.trim().startsWith('<') ? `Error ${res.status}` : err;
                        results.push({ success: false, name: file.name, error: errorMsg });
                    }
                }
            } catch (e) {
                results.push({ success: false, name: file.name, error: "Network error (likely too large)" });
            }
        }

        completed++;
        progressBar.style.width = `${(completed / total) * 100}%`;
    }

    // Show Results
    uploadingState.classList.add('hidden');
    uploadingState.classList.remove('flex');
    uploadPrompt.classList.remove('hidden');
    fileInput.value = ''; // Reset input

    displayResults(results);
  }

  function escapeHtml(unsafe) {
    if (unsafe === null || unsafe === undefined) return "";
    return String(unsafe)
      .replace(/&/g, "&")
      .replace(/</g, "<")
      .replace(/>/g, ">")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function formatBytes(bytes, decimals = 2) {
    if (!+bytes) return "0 Bytes";
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ["Bytes", "KB", "MB", "GB", "TB", "PB", "EB", "ZB", "YB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return `${parseFloat((bytes / k ** i).toFixed(dm))} ${sizes[i]}`;
  }

  function displayResults(results) {
    resultsArea.classList.remove('hidden');
    
    results.forEach(res => {
        const div = document.createElement('div');
        div.className = 'bg-hc-dark border border-white/10 rounded-2xl p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 card-shadow';
        
        if (res.success) {
            div.innerHTML = `
                <div class="flex items-center gap-4 overflow-hidden">
                    <div class="bg-emerald-500/10 p-3 rounded-xl text-emerald-400 shrink-0 border border-emerald-500/20">
                        <i class="ph ph-check text-2xl"></i>
                    </div>
                    <div class="min-w-0">
                        <p class="text-white font-bold truncate text-base">${escapeHtml(res.name)}</p>
                        <div class="flex items-center gap-2 text-xs">
                            <span class="text-text-muted font-mono">${formatBytes(res.size)}</span>
                            <span class="text-white/20">•</span>
                            <a href="${escapeHtml(res.url)}" target="_blank" class="text-hc-red hover:text-red-400 truncate hover:underline font-mono">${escapeHtml(res.url)}</a>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button onclick="copyToClipboard('${escapeHtml(res.url)}', this)" class="text-text-muted hover:text-white p-2 rounded-lg" title="Copy URL">
                        <i class="ph ph-copy text-xl"></i>
                    </button>
                    <a href="${escapeHtml(res.url)}" target="_blank" class="text-text-muted hover:text-white p-2 rounded-lg" title="Open">
                        <i class="ph ph-arrow-square-out text-xl"></i>
                    </a>
                </div>
            `;
        } else {
            div.innerHTML = `
                <div class="flex items-center gap-4 overflow-hidden">
                    <div class="bg-red-500/10 p-3 rounded-xl text-red-400 shrink-0 border border-red-500/20">
                        <i class="ph ph-warning-circle text-2xl"></i>
                    </div>
                    <div class="min-w-0">
                        <p class="text-white font-bold truncate text-base">${escapeHtml(res.name)}</p>
                        <p class="text-red-400 text-sm truncate font-mono">${escapeHtml(res.error)}</p>
                    </div>
                </div>
            `;
        }
        
        // Insert at top
        resultsList.insertBefore(div, resultsList.firstChild);
    });
  }

  function copyToClipboard(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<i class="ph ph-check text-xl text-emerald-400"></i>';
        setTimeout(() => {
            btn.innerHTML = originalHTML;
        }, 2000);
    });
  }

  function clearResults() {
    resultsList.innerHTML = '';
    resultsArea.classList.add('hidden');
  }

  // Load User Info
  fetch('/api/dashboard/stats').then(res => res.json()).then(data => {
    // document.getElementById('user-id').textContent = data.user.id; // Handled by Handlebars
    /*
    if (data.user.slackId) {
        const avatar = document.getElementById("user-avatar");
        avatar.src = `https://cachet.dunkirk.sh/users/${data.user.slackId}/r`;
        avatar.classList.remove("hidden");
    }
    */

    // Update Storage Bar
    const usage = data.user.storageUsage || 0;
    const limit = data.user.storageLimit || 1073741824; // 1GB default
    const percent = Math.min((usage / limit) * 100, 100);
    
    document.getElementById('storage-bar').style.width = `${percent}%`;
    document.getElementById('storage-text').textContent = `${formatBytes(usage)} / ${formatBytes(limit)}`;
    
    if (percent > 90) {
        document.getElementById('storage-bar').classList.remove('bg-hc-red');
        document.getElementById('storage-bar').classList.add('bg-red-500');
    }
    
    // Load preference from local storage or default to true
    const savedPref = localStorage.getItem('silo_cdn_post_slack');
    const checkbox = document.getElementById('postToSlack');
    // Default to true if not set
    checkbox.checked = savedPref === null ? true : (savedPref === 'true');
    
    // Save preference on change
    checkbox.addEventListener('change', (e) => {
        localStorage.setItem('silo_cdn_post_slack', e.target.checked);
    });
  }).catch(() => {
    // window.location.href = '/auth/login'; // Auth middleware handles this
  });
</script>
{{/section}}
