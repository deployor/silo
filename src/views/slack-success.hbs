<main class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-4xl mx-auto">
  
  <div class="text-center">
    <h1 class="text-6xl md:text-9xl font-black text-white mb-8 tracking-tighter italic">
      You're all set!
    </h1>
    
    <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
      Your account is linked and your default storage quota is <span class="text-white font-bold">{{defaultStorageLimitHuman}}</span>.
      <br><br>
      You can now go back to Slack to upload files, or use the <a href="/cdn" class="text-hc-red hover:underline font-bold">Web CDN</a>.
    </p>

    <div class="flex items-center justify-center gap-6 text-sm font-bold uppercase tracking-wider">
        <a href="/" class="text-text-muted hover:text-white transition-colors border-b border-transparent hover:border-white pb-0.5">
            Go to Dashboard
        </a>
    </div>
  </div>

</main>
