<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="/assets/styles.css" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="bg-hc-dark text-text-main min-h-screen flex flex-col items-center justify-center p-6">
    <div class="max-w-xl w-full text-center">
        
        <!-- Header -->
        <div class="mb-12">
            <h1 class="text-5xl font-bold text-white mb-6 tracking-tight">Account Closed</h1>
            <p class="text-xl text-text-muted leading-relaxed">
                Your Silo account has been permanently closed because you've aged out.
            </p>
        </div>

        {{#if user.dataExported}}
            <div class="bg-white/5 rounded-xl p-8 mb-8 border border-white/10">
                <div class="flex items-center justify-center w-12 h-12 bg-white rounded-full mx-auto mb-4 text-black">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h3 class="text-white font-bold text-lg mb-2">You're all set</h3>
                <p class="text-text-muted text-sm">
                    You downloaded your data before the deadline. <br/>
                    We've deleted your files from our servers to save space.
                </p>
            </div>
        {{else}}
             <div class="bg-white/5 rounded-xl p-8 mb-8 border border-white/10">
                <div class="flex items-center justify-center w-12 h-12 bg-red-500 rounded-full mx-auto mb-4 text-white">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </div>
                <h3 class="text-white font-bold text-lg mb-2">Data Deleted</h3>
                <p class="text-text-muted text-sm">
                    You didn't download your data before the deadline, so we've had to delete it to make room for new hackers.
                </p>
            </div>
        {{/if}}

        <p class="text-text-muted mb-8 text-sm">
            Thanks for building with Silo during your time at Hack Club!
        </p>
        
        <div class="flex flex-col gap-4">
            <a href="https://hackclub.com" class="text-white font-bold hover:text-text-muted transition-colors">
                Return to Hack Club &rarr;
            </a>
        </div>
        
        <div class="mt-12 pt-8 border-t border-white/10 text-xs text-text-muted font-mono opacity-40">
            User ID: {{user.id}}
        </div>
    </div>
</body>
</html>
