<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="/assets/styles.css" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="bg-hc-dark text-text-main min-h-screen flex flex-col items-center justify-center p-6">
    <div class="max-w-2xl w-full text-center">
        <!-- Stepper (Final State) -->
        <div class="w-full max-w-3xl mx-auto mb-16 px-4">
            <div class="relative">
                <!-- Progress Track -->
                <div class="absolute top-6 left-0 w-full h-3 bg-white/10 rounded-full overflow-hidden">
                     <!-- Progress Fill (Solid Color) -->
                    <div class="h-full bg-hc-red w-full"></div>
                </div>
                
                <div class="relative flex justify-between w-full">
                    <!-- Step 1: Notification -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        <div class="w-12 h-12 rounded-full bg-white text-black border-4 border-hc-dark flex items-center justify-center z-10 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h3 class="text-white font-bold text-sm uppercase tracking-wide">Notify</h3>
                    </div>

                    <!-- Step 2: Export Data -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        {{#if user.dataExported}}
                        <div class="w-12 h-12 rounded-full bg-white text-black border-4 border-hc-dark flex items-center justify-center z-10 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h3 class="text-white font-bold text-sm uppercase tracking-wide">Export</h3>
                        {{else}}
                        <div class="w-12 h-12 rounded-full bg-hc-red text-white border-4 border-hc-dark flex items-center justify-center z-10 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </div>
                        <h3 class="text-hc-red font-bold text-sm uppercase tracking-wide">Export</h3>
                        {{/if}}
                    </div>

                    <!-- Step 3: Deletion -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        <div class="w-12 h-12 rounded-full bg-white text-black border-4 border-hc-dark flex items-center justify-center z-10 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h3 class="text-white font-bold text-sm uppercase tracking-wide">Deletion</h3>
                    </div>
                </div>
            </div>
        </div>

        <h1 class="text-4xl font-bold text-white mb-4">It's time to move on</h1>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 card-shadow">
            {{#unless user.dataExported}}
            <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-6 text-left">
                <div class="text-red-300 text-sm flex gap-3">
                    <div class="shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div>
                        <strong>You missed the export window.</strong><br/>
                        You did not download your data during the grace period. Unfortunately, your files have now been permanently deleted and cannot be recovered.
                    </div>
                </div>
            </div>
            {{/unless}}

            <p class="text-lg text-text-muted mb-6">
                You've officially aged out of Hack Club's Silo service.
            </p>
            <p class="text-text-muted mb-8">
                We hope Silo was helpful during your teenage hacking years! As per our policy, your data has now been permanently deleted to make room for the next generation of hackers.
            </p>
            
            <div class="flex flex-col gap-4">
                <a href="https://hackclub.com" class="bg-hc-red hover:bg-red-600 text-white px-8 py-3 rounded-xl font-bold transition-transform hover:scale-105 inline-block">
                    Return to Hack Club
                </a>
            </div>
        </div>
        <div class="mt-8 text-sm text-text-muted opacity-50">
            User ID: {{user.id}}
        </div>
    </div>
</body>
</html>
