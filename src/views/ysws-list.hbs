<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8"
    x-data="{
        activeTab: new URLSearchParams(window.location.search).get('tab') || 'my-ships'
    }"
    x-init="$watch('activeTab', value => {
        const url = new URL(window.location);
        url.searchParams.set('tab', value);
        window.history.replaceState({}, '', url);
    })"
>
    <!-- Header with Action -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-8 gap-6 border-b border-white/10 pb-6">
        <div>
            <h1 class="text-4xl font-extrabold tracking-tight mb-2 text-white">YSWS Dashboard</h1>
            <p class="text-xl text-text-muted">Manage your projects and explore the gallery.</p>
        </div>
        
        <a href="/ysws/submit" class="bg-hc-red hover:bg-red-600 text-white font-bold py-2.5 px-6 rounded-lg transition-colors shadow-lg shadow-hc-red/20 flex items-center gap-2">
            <i class="ph-bold ph-plus"></i>
            New Submission
        </a>
    </div>

    <!-- Segmented Control Tab Switcher -->
    <div class="flex justify-start mb-8">
        <div class="bg-white/5 p-1 rounded-lg inline-flex border border-white/10">
            <button
                @click="activeTab = 'my-ships'"
                :class="activeTab === 'my-ships' ? 'bg-hc-blue text-white shadow-sm' : 'text-white/60 hover:text-white hover:bg-white/5'"
                class="px-6 py-2 rounded-md font-bold transition-all text-sm flex items-center gap-2"
            >
                <i class="ph-bold ph-rocket-launch"></i>
                My Ships
            </button>
            <button
                @click="activeTab = 'gallery'"
                :class="activeTab === 'gallery' ? 'bg-hc-green text-white shadow-sm' : 'text-white/60 hover:text-white hover:bg-white/5'"
                class="px-6 py-2 rounded-md font-bold transition-all text-sm flex items-center gap-2"
            >
                <i class="ph-bold ph-images"></i>
                Gallery
            </button>
        </div>
    </div>

    {{#if success}}
    <div class="mb-8 bg-green-500/10 border border-green-500/20 rounded-xl p-4 flex items-center gap-4" x-show="activeTab === 'my-ships'" x-cloak>
        <div class="bg-green-500/20 p-2 rounded-full">
            <i class="ph-bold ph-check text-green-400"></i>
        </div>
        <div>
            <h3 class="font-bold text-green-400">Submission Received!</h3>
            <p class="text-green-300/80 text-sm">Your project is in the queue.</p>
        </div>
    </div>
    {{/if}}

    <!-- My Ships Tab (Compact List View) -->
    <div x-show="activeTab === 'my-ships'" x-cloak>
        {{#if submissions}}
        <div class="bg-hc-dark border border-white/10 rounded-xl overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/5 border-b border-white/10 text-xs uppercase tracking-wider text-text-muted font-bold">
                        <th class="p-4 pl-6">Project</th>
                        <th class="p-4">Status</th>
                        <th class="p-4">Hours</th>
                        <th class="p-4">Submitted</th>
                        <th class="p-4 text-right pr-6">Links</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    {{#each submissions}}
                    <tr class="group hover:bg-white/[0.02] transition-colors">
                        <td class="p-4 pl-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-8 rounded bg-black/30 border border-white/10 overflow-hidden shrink-0">
                                    {{#if this.screenshotUrl}}
                                    <img src="{{this.screenshotUrl}}" class="w-full h-full object-cover">
                                    {{else}}
                                    <div class="w-full h-full flex items-center justify-center text-white/20"><i class="ph-fill ph-image"></i></div>
                                    {{/if}}
                                </div>
                                <div>
                                    <div class="font-bold text-white group-hover:text-hc-blue transition-colors">{{this.projectName}}</div>
                                    <div class="text-xs text-text-muted max-w-xs truncate">{{this.shortDescription}}</div>
                                </div>
                            </div>
                        </td>
                        <td class="p-4">
                            {{#if (eq this.status 'pending')}}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-yellow-500/10 text-yellow-500 border border-yellow-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span> Pending
                                </span>
                            {{else if (eq this.status 'approved')}}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-green-500/10 text-green-500 border border-green-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Approved
                                </span>
                            {{else if (eq this.status 'rejected')}}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-red-500/10 text-red-500 border border-red-500/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Rejected
                                </span>
                            {{/if}}
                        </td>
                        <td class="p-4 font-mono text-sm text-white/80">
                            {{this.hoursSpent}}h
                            {{#if (gt (add (or this.tierBonusPercent 0) (or this.adminBonusPercent 0)) 0)}}
                                <div class="inline-flex items-center gap-1 text-[10px] text-hc-green font-bold ml-1 cursor-help" title="Bonus: {{add (or this.tierBonusPercent 0) (or this.adminBonusPercent 0)}}% (Tier: {{or this.tierBonusPercent 0}}%, Admin: {{or this.adminBonusPercent 0}}%)">
                                    <i class="ph-bold ph-trend-up"></i>
                                    +{{add (or this.tierBonusPercent 0) (or this.adminBonusPercent 0)}}%
                                </div>
                            {{/if}}
                        </td>
                        <td class="p-4 text-sm text-text-muted">
                            {{formatDate this.createdAt}}
                        </td>
                        <td class="p-4 pr-6 text-right">
                            <div class="flex justify-end gap-3 text-white/40">
                                {{#if this.repoUrl}}
                                <a href="{{this.repoUrl}}" target="_blank" class="hover:text-white transition-colors"><i class="ph-fill ph-github-logo text-xl"></i></a>
                                {{/if}}
                                {{#if this.demoUrl}}
                                <a href="{{this.demoUrl}}" target="_blank" class="hover:text-white transition-colors"><i class="ph-bold ph-arrow-square-out text-xl"></i></a>
                                {{/if}}
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="text-center py-20 bg-hc-dark border border-white/10 rounded-xl border-dashed">
            <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="ph ph-package text-3xl text-white/40"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">No Projects Yet</h3>
            <p class="text-text-muted max-w-sm mx-auto mb-6">Ship something awesome and earn storage!</p>
            <a href="/ysws/submit" class="inline-flex items-center gap-2 bg-hc-red hover:bg-red-600 text-white font-bold py-2 px-5 rounded-lg transition-colors">
                Start Shipping
            </a>
        </div>
        {{/if}}
    </div>

    <!-- Gallery Tab -->
    <div x-show="activeTab === 'gallery'" x-cloak>
        {{#if galleryProjects}}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {{#each galleryProjects}}
            <div class="bg-hc-dark border border-white/10 rounded-xl overflow-hidden flex flex-col h-full hover:border-white/20 transition-colors">
                <a href="{{this.demoUrl}}" target="_blank" class="block aspect-video bg-black/20 relative group overflow-hidden border-b border-white/5">
                    {{#if this.screenshotUrl}}
                    <img src="{{this.screenshotUrl}}" alt="{{this.projectName}}"
                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                        loading="lazy"
                    >
                    {{else}}
                    <div class="w-full h-full flex items-center justify-center text-white/10">
                        <i class="ph ph-image text-4xl"></i>
                    </div>
                    {{/if}}
                    
                    <div class="absolute top-3 right-3 bg-black/80 backdrop-blur-sm border border-white/10 rounded px-2 py-1 text-xs font-mono text-white flex items-center gap-1.5 shadow-sm">
                        <i class="ph-fill ph-check-circle text-hc-green"></i>
                        {{this.hoursSpent}}h
                    </div>
                </a>
                
                <div class="p-5 flex flex-col flex-1">
                    <div class="flex justify-between items-start gap-4 mb-2">
                        <a href="{{this.demoUrl}}" target="_blank" class="text-lg font-bold text-white hover:text-hc-blue transition-colors line-clamp-1">
                            {{this.projectName}}
                        </a>
                        {{#if this.repoUrl}}
                        <a href="{{this.repoUrl}}" target="_blank" class="text-white/40 hover:text-white transition-colors shrink-0" title="View Code">
                            <i class="ph-fill ph-github-logo text-xl"></i>
                        </a>
                        {{/if}}
                    </div>
                    
                    <p class="text-text-muted text-sm line-clamp-2 leading-relaxed mb-4 flex-1">{{this.shortDescription}}</p>
                    
                    <div class="flex items-center gap-2 text-xs text-white/30 font-mono border-t border-white/5 pt-3 mt-auto">
                        <i class="ph ph-calendar-blank"></i>
                        <span>Shipped {{formatDate this.reviewedAt}}</span>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
         <div class="text-center py-20 bg-hc-dark border border-white/10 rounded-xl border-dashed">
            <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="ph ph-images text-3xl text-white/40"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Gallery is Empty</h3>
            <p class="text-text-muted max-w-sm mx-auto">No approved projects yet.</p>
        </div>
        {{/if}}
    </div>
</div>