<!-- Admin Subnav -->
<div class="flex gap-4 mb-6 border-b border-white/10 pb-4">
  <a href="/admin/users" id="tab-users" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Users</a>
  <a href="/admin/ysws" id="tab-ysws" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">YSWS</a>
  <a href="/admin/logs" id="tab-logs" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Logs</a>
  <a href="/admin/settings" id="tab-settings" class="text-white font-bold px-4 py-2 rounded-lg bg-white/10 transition-colors">Settings</a>
</div>

<div class="bg-hc-dark rounded-3xl border border-white/10 overflow-hidden card-shadow mb-8">
  <div class="p-6 border-b border-white/10 flex justify-between items-center">
    <div>
      <h2 class="text-xl font-bold text-white">Settings</h2>
      <p class="text-text-muted text-sm mt-1">
        Global defaults used across Dashboard + Slack + backend.
      </p>
    </div>
    <div class="flex items-center gap-3">
      <button id="reloadBtn" class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-3 py-2 rounded-lg text-sm font-bold transition-colors">
        Reload
      </button>
      <button id="saveBtn" class="bg-hc-blue hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold transition-colors">
        Save
      </button>
    </div>
  </div>

  <div class="p-6">
    <div id="status" class="text-xs text-text-muted font-mono mb-4"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-black/30 p-6 rounded-xl border border-white/10">
        <h4 class="text-white font-bold mb-1">Default Storage Quota</h4>
        <p class="text-xs text-text-muted mb-4">Used when a user does not have an explicit per-user quota.</p>
        <div class="flex gap-2 items-center">
          <input id="defaultStorageLimitAmount" type="number" min="0" step="0.01" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" placeholder="Amount" />
          <select id="defaultStorageLimitUnit" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white cursor-pointer font-mono">
            <option value="1">Bytes</option>
            <option value="1024">KB</option>
            <option value="1048576">MB</option>
            <option value="1073741824">GB</option>
            <option value="1099511627776">TB</option>
            <option value="1125899906842624">PB</option>
          </select>
        </div>
        <input id="defaultStorageLimitBytes" type="hidden" />
        <p class="text-[11px] text-text-muted mt-2">Stored as bytes.</p>
      </div>

      <div class="bg-black/30 p-6 rounded-xl border border-white/10">
        <h4 class="text-white font-bold mb-1">Default Egress Limit (formula)</h4>
        <p class="text-xs text-text-muted mb-4">When a user has no explicit egress limit, we compute: <span class="font-mono">max(minEgress, storage × multiplier)</span>.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <div class="text-xs text-text-muted mb-1 font-bold uppercase tracking-wider">Multiplier</div>
            <input id="egressMultiplier" type="number" min="0" step="1" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" placeholder="3" />
          </div>

          <div>
            <div class="text-xs text-text-muted mb-1 font-bold uppercase tracking-wider">Minimum Egress</div>
            <div class="flex gap-2 items-center">
              <input id="minEgressAmount" type="number" min="0" step="0.01" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" placeholder="10" />
              <select id="minEgressUnit" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white cursor-pointer font-mono">
                <option value="1">Bytes</option>
                <option value="1024">KB</option>
                <option value="1048576">MB</option>
                <option value="1073741824">GB</option>
                <option value="1099511627776">TB</option>
                <option value="1125899906842624">PB</option>
              </select>
            </div>
            <input id="minEgressBytes" type="hidden" />
          </div>
        </div>

        <p class="text-[11px] text-text-muted mt-3">Example: if storage is <span class="font-mono">1GB</span>, multiplier is <span class="font-mono">3</span>, and min is <span class="font-mono">10GB</span>, default egress becomes <span class="font-mono">10GB</span>.</p>
      </div>

      <div class="bg-black/30 p-6 rounded-xl border border-white/10">
        <h4 class="text-white font-bold mb-1">Max Buckets per User</h4>
        <p class="text-xs text-text-muted mb-4">Enforced when creating buckets (Dashboard + Slack + API).</p>
        <input id="defaultMaxBucketsPerUser" type="number" min="1" step="1" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" />
      </div>

      <div class="bg-black/30 p-6 rounded-xl border border-white/10">
        <h4 class="text-white font-bold mb-1">Max Keys per Bucket</h4>
        <p class="text-xs text-text-muted mb-4">Enforced when generating access keys.</p>
        <input id="defaultMaxKeysPerBucket" type="number" min="1" step="1" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" />
      </div>

      <div class="bg-black/30 p-6 rounded-xl border border-white/10">
        <h4 class="text-white font-bold mb-1">YSWS Quota Per Hour</h4>
        <p class="text-xs text-text-muted mb-4">Storage reward for each hour of shipping.</p>
        <div class="flex gap-2 items-center">
          <input id="yswsQuotaAmount" type="number" min="0" step="0.01" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white w-full font-mono" placeholder="Amount" />
          <select id="yswsQuotaUnit" class="bg-black/50 border border-white/10 rounded-lg px-3 py-2 text-white cursor-pointer font-mono">
            <option value="1">Bytes</option>
            <option value="1024">KB</option>
            <option value="1048576">MB</option>
            <option value="1073741824">GB</option>
            <option value="1099511627776">TB</option>
          </select>
        </div>
        <input id="yswsQuotaPerHourBytes" type="hidden" />
        <p class="text-[11px] text-text-muted mt-2">Stored as bytes.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const statusEl = document.getElementById('status');
  const saveBtn = document.getElementById('saveBtn');
  const reloadBtn = document.getElementById('reloadBtn');

  const fields = {
    defaultStorageLimitBytes: document.getElementById('defaultStorageLimitBytes'),
    defaultStorageLimitAmount: document.getElementById('defaultStorageLimitAmount'),
    defaultStorageLimitUnit: document.getElementById('defaultStorageLimitUnit'),

    egressMultiplier: document.getElementById('egressMultiplier'),
    minEgressBytes: document.getElementById('minEgressBytes'),
    minEgressAmount: document.getElementById('minEgressAmount'),
    minEgressUnit: document.getElementById('minEgressUnit'),

    defaultMaxBucketsPerUser: document.getElementById('defaultMaxBucketsPerUser'),
    defaultMaxKeysPerBucket: document.getElementById('defaultMaxKeysPerBucket'),

    yswsQuotaPerHourBytes: document.getElementById('yswsQuotaPerHourBytes'),
    yswsQuotaAmount: document.getElementById('yswsQuotaAmount'),
    yswsQuotaUnit: document.getElementById('yswsQuotaUnit'),
  };

  function getBestUnit(bytes) {
    if (!Number(bytes)) return { value: 0, unit: 1 };
    const k = 1024;
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    const unitVal = Math.pow(k, i);
    // Clamp to PB for the selector.
    const maxUnit = 1125899906842624;
    const chosen = unitVal > maxUnit ? maxUnit : unitVal;
    return {
      value: parseFloat((bytes / chosen).toFixed(2)),
      unit: chosen,
    };
  }

  function syncBytes(amountEl, unitEl, bytesEl) {
    const amount = parseFloat(amountEl.value);
    const unit = parseFloat(unitEl.value);
    if (Number.isNaN(amount) || Number.isNaN(unit)) {
      bytesEl.value = "0";
      return;
    }
    bytesEl.value = String(Math.floor(amount * unit));
  }

  function setStatus(text, isError = false) {
    statusEl.textContent = text;
    statusEl.style.color = isError ? '#ff6b6b' : '';
  }

  async function loadSettings() {
    setStatus('Loading...');
    const res = await fetch('/api/admin/settings');
    if (!res.ok) {
      setStatus('Failed to load settings', true);
      return;
    }
    const data = await res.json();

    fields.defaultStorageLimitBytes.value = String(data.defaultStorageLimitBytes);
    const bestStorage = getBestUnit(Number(data.defaultStorageLimitBytes));
    fields.defaultStorageLimitAmount.value = String(bestStorage.value);
    fields.defaultStorageLimitUnit.value = String(bestStorage.unit);

    fields.egressMultiplier.value = String(data.egressMultiplier);
    fields.minEgressBytes.value = String(data.minEgressBytes);
    const bestMinEgress = getBestUnit(Number(data.minEgressBytes));
    fields.minEgressAmount.value = String(bestMinEgress.value);
    fields.minEgressUnit.value = String(bestMinEgress.unit);

    fields.defaultMaxBucketsPerUser.value = data.defaultMaxBucketsPerUser;
    fields.defaultMaxKeysPerBucket.value = data.defaultMaxKeysPerBucket;

    fields.yswsQuotaPerHourBytes.value = String(data.yswsQuotaPerHourBytes || 0);
    const bestYsws = getBestUnit(Number(data.yswsQuotaPerHourBytes || 0));
    fields.yswsQuotaAmount.value = String(bestYsws.value);
    fields.yswsQuotaUnit.value = String(bestYsws.unit);

    setStatus('Loaded');
  }

  async function saveSettings() {
    setStatus('Saving...');
    saveBtn.disabled = true;

    syncBytes(fields.defaultStorageLimitAmount, fields.defaultStorageLimitUnit, fields.defaultStorageLimitBytes);
    syncBytes(fields.minEgressAmount, fields.minEgressUnit, fields.minEgressBytes);
    syncBytes(fields.yswsQuotaAmount, fields.yswsQuotaUnit, fields.yswsQuotaPerHourBytes);

    const payload = {
      defaultStorageLimitBytes: Number(fields.defaultStorageLimitBytes.value),
      egressMultiplier: Number(fields.egressMultiplier.value),
      minEgressBytes: Number(fields.minEgressBytes.value),
      defaultMaxBucketsPerUser: Number(fields.defaultMaxBucketsPerUser.value),
      defaultMaxKeysPerBucket: Number(fields.defaultMaxKeysPerBucket.value),
      yswsQuotaPerHourBytes: Number(fields.yswsQuotaPerHourBytes.value),
    };

    const res = await fetch('/api/admin/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    saveBtn.disabled = false;

    if (!res.ok) {
      const msg = await res.text().catch(() => 'Failed to save');
      setStatus(msg || 'Failed to save', true);
      return;
    }

    setStatus('Saved');
  }

  fields.defaultStorageLimitAmount.addEventListener('input', () => syncBytes(fields.defaultStorageLimitAmount, fields.defaultStorageLimitUnit, fields.defaultStorageLimitBytes));
  fields.defaultStorageLimitUnit.addEventListener('change', () => syncBytes(fields.defaultStorageLimitAmount, fields.defaultStorageLimitUnit, fields.defaultStorageLimitBytes));

  fields.minEgressAmount.addEventListener('input', () => syncBytes(fields.minEgressAmount, fields.minEgressUnit, fields.minEgressBytes));
  fields.minEgressUnit.addEventListener('change', () => syncBytes(fields.minEgressAmount, fields.minEgressUnit, fields.minEgressBytes));

  fields.yswsQuotaAmount.addEventListener('input', () => syncBytes(fields.yswsQuotaAmount, fields.yswsQuotaUnit, fields.yswsQuotaPerHourBytes));
  fields.yswsQuotaUnit.addEventListener('change', () => syncBytes(fields.yswsQuotaAmount, fields.yswsQuotaUnit, fields.yswsQuotaPerHourBytes));

  saveBtn.addEventListener('click', saveSettings);
  reloadBtn.addEventListener('click', loadSettings);

  loadSettings();
</script>
