<div class="flex flex-col items-center font-sans w-full min-h-[80vh] justify-center">
  <div class="w-full max-w-4xl mx-auto text-center px-6">
    <h1 class="text-6xl md:text-9xl font-bold mb-2 italic tracking-tighter text-white select-none">HOARD</h1>
    
    <h2 class="sr-only">Free S3 Compatible Object Storage</h2>
    
    <p class="text-2xl md:text-3xl text-gray-400 mb-12 max-w-2xl mx-auto font-light">
      The free S3 gateway for Hack Club.
      <br>
      <span class="text-white font-normal">Ship projects. Earn storage.</span>
    </p>
    
    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
      <a
        href="/auth/login"
        class="text-xl font-bold text-white hover:text-hc-red transition-colors border-b-2 border-transparent hover:border-hc-red pb-1"
      >
        Login
      </a>
      <span class="text-gray-600 hidden sm:inline">•</span>
      <a
        href="/docs"
        class="text-xl font-bold text-white hover:text-hc-blue transition-colors border-b-2 border-transparent hover:border-hc-blue pb-1"
      >
        Docs
      </a>
      <span class="text-gray-600 hidden sm:inline">•</span>
      <a
        href="https://github.com/hackclub/silo"
        target="_blank"
        class="text-xl font-bold text-white hover:text-green-500 transition-colors border-b-2 border-transparent hover:border-green-500 pb-1"
      >
        GitHub
      </a>
    </div>

    <div class="mt-24 grid grid-cols-1 md:grid-cols-3 gap-8 text-left max-w-3xl mx-auto opacity-60 hover:opacity-100 transition-opacity duration-500">
      <div>
        <h3 class="font-mono text-hc-red mb-2">01 / COMPATIBLE</h3>
        <p class="text-sm text-gray-400">Full S3 API compatibility. Use the AWS SDK, Rclone, or any S3-compatible tool.</p>
      </div>
      <div>
        <h3 class="font-mono text-hc-blue mb-2">02 / FAST</h3>
        <p class="text-sm text-gray-400">Built on Cloudflare R2. Global CDN caching for low-latency asset delivery.</p>
      </div>
      <div>
        <h3 class="font-mono text-green-500 mb-2">03 / FREE</h3>
        <p class="text-sm text-gray-400">Start with free object storage. Ship your projects to unlock more quota.</p>
      </div>
    </div>

    {{#if yswsQuotaPerHour}}
    <div class="mt-20 border-t border-white/10 pt-16 max-w-2xl mx-auto" x-data="{ hours: 10, rate: {{yswsQuotaPerHour}} }">
        <h3 class="text-2xl font-bold mb-8 flex items-center justify-center gap-3">
             <span class="bg-gradient-to-r from-hc-red to-orange-500 text-transparent bg-clip-text">YSWS Rewards</span>
             <span class="px-2 py-0.5 rounded text-xs border border-white/20 bg-white/5 text-white/50 uppercase tracking-widest font-mono">Calculator</span>
        </h3>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 backdrop-blur-sm">
            <div class="mb-8">
                <div class="flex justify-between items-end mb-4">
                    <label class="text-sm font-mono text-gray-400 uppercase tracking-wider">Hours Spent Coding</label>
                    <span class="text-4xl font-bold text-white font-mono" x-text="hours + 'h'"></span>
                </div>
                <input type="range" min="1" max="100" x-model="hours" class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-hc-red hover:accent-red-400 transition-all">
                <div class="flex justify-between mt-2 text-xs text-white/30 font-mono">
                    <span>1h</span>
                    <span>100h</span>
                </div>
            </div>

            <div class="flex items-center justify-between border-t border-white/10 pt-6">
                 <div class="text-left">
                    <p class="text-sm text-gray-400 mb-1">Storage Reward</p>
                    <p class="text-xs text-white/30">Lifetime increase</p>
                </div>
                <div class="text-right">
                    <p class="text-4xl font-bold text-green-400 font-mono" x-text="((hours * rate) / (1024 * 1024 * 1024)).toFixed(1) + ' GB'"></p>
                </div>
            </div>
        </div>
        
        <p class="mt-6 text-sm text-white/40 max-w-md mx-auto">
            Ship your project to High Seas, Onboard, or any YSWS to earn permanent storage quota.
            <a href="/ysws" class="text-white hover:text-hc-blue underline decoration-white/30 hover:decoration-hc-blue transition-all">Learn more &rarr;</a>
        </p>
    </div>
    {{/if}}
  </div>
</div>
