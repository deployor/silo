<div class="flex flex-col items-center font-sans w-full min-h-[80vh] justify-center">
  <div class="w-full max-w-4xl mx-auto text-center px-6">
    <h1 class="text-6xl md:text-9xl font-bold mb-2 italic tracking-tighter text-white select-none">HOARD</h1>
    
    <h2 class="sr-only">Free S3 Compatible Object Storage</h2>
    
    <p class="text-2xl md:text-3xl text-gray-400 mb-12 max-w-2xl mx-auto font-light">
      The free S3 gateway for Hack Club.
      <br>
      <span class="text-white font-normal">Ship projects. Earn storage.</span>
    </p>
    
    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
      <a
        href="/auth/login"
        class="text-xl font-bold text-white hover:text-hc-red transition-colors border-b-2 border-transparent hover:border-hc-red pb-1"
      >
        Login
      </a>
      <span class="text-gray-600 hidden sm:inline">•</span>
      <a
        href="/docs"
        class="text-xl font-bold text-white hover:text-hc-blue transition-colors border-b-2 border-transparent hover:border-hc-blue pb-1"
      >
        Docs
      </a>
      <span class="text-gray-600 hidden sm:inline">•</span>
      <a
        href="/gallery"
        class="text-xl font-bold text-white hover:text-yellow-500 transition-colors border-b-2 border-transparent hover:border-yellow-500 pb-1"
      >
        Gallery
      </a>
      <span class="text-gray-600 hidden sm:inline">•</span>
      <a
        href="https://github.com/hackclub/silo"
        target="_blank"
        class="text-xl font-bold text-white hover:text-green-500 transition-colors border-b-2 border-transparent hover:border-green-500 pb-1"
      >
        GitHub
      </a>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-left max-w-3xl mx-auto opacity-60 hover:opacity-100 transition-opacity duration-500">
      <div>
        <h3 class="font-mono text-hc-red mb-2">01 / COMPATIBLE</h3>
        <p class="text-sm text-gray-400">Full S3 API compatibility. Use the AWS SDK, Rclone, or any S3-compatible tool.</p>
      </div>
      <div>
        <h3 class="font-mono text-hc-blue mb-2">02 / FAST</h3>
        <p class="text-sm text-gray-400">Built on Cloudflare R2. Global CDN caching for low-latency asset delivery.</p>
      </div>
      <div>
        <h3 class="font-mono text-green-500 mb-2">03 / FREE</h3>
        <p class="text-sm text-gray-400">Start with free object storage. Ship your projects to unlock more quota.</p>
      </div>
    </div>

    {{#if yswsQuotaPerHour}}
    <div class="mt-20 border-t border-white/10 pt-16 max-w-3xl mx-auto" x-data="rewardCalculator">
        <h3 class="text-text-muted text-sm font-bold uppercase tracking-wider mb-6 text-center">
            Reward Calculator
        </h3>

        <div class="bg-hc-dark rounded-3xl p-8 border border-white/10 card-shadow">
            <div class="flex flex-col md:flex-row gap-8 items-center">
                <div class="flex-1 w-full">
                     <div class="flex justify-between items-end mb-4">
                        <label class="text-sm font-bold text-white">Hours Spent Coding</label>
                        <span class="text-2xl font-bold text-hc-red font-mono" x-text="hours + 'h'"></span>
                    </div>
                    <input type="range" min="1" max="100" x-model="hours" class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-hc-red hover:accent-red-400 transition-all">
                    <div class="flex justify-between mt-2 text-xs text-text-muted font-mono">
                        <span>1h</span>
                        <span>100h</span>
                    </div>
                </div>

                <div class="hidden md:block w-px h-24 bg-white/10"></div>

                <div class="flex-1 w-full text-center md:text-left">
                    <p class="text-text-muted text-xs font-bold uppercase tracking-wider mb-2">You Earn</p>
                    <div class="flex items-baseline justify-center md:justify-start gap-2">
                         <span class="text-5xl font-bold text-white tracking-tighter" x-text="finalRewardGb"></span>
                         <span class="text-xl text-white/40 font-bold">GB</span>
                    </div>
                    <div class="flex flex-col gap-1 mt-2">
                         <p class="text-xs text-text-muted">Permanent storage added to your account</p>
                         <p x-show="activeTierBonus > 0" class="text-xs text-hc-green font-bold" x-text="'+' + activeTierBonus + '% Bonus Applied!'"></p>
                    </div>
                </div>
            </div>
        </div>
        
        <p class="mt-8 text-lg text-text-muted max-w-xl mx-auto">
            Ship your project to earn storage quota.
        </p>
    </div>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('rewardCalculator', () => ({
                hours: 10,
                rate: {{yswsQuotaPerHour}},
                tiers: {{{json yswsBonusTiers}}} || [],
                
                get activeTierBonus() {
                    const sortedTiers = this.tiers
                        .filter(t => t.enabled && this.hours >= t.hours)
                        .sort((a, b) => b.hours - a.hours);
                    return sortedTiers.length > 0 ? sortedTiers[0].percent : 0;
                },

                get finalRewardGb() {
                    const baseBytes = this.hours * this.rate;
                    const multiplier = 1 + (this.activeTierBonus / 100);
                    const totalBytes = baseBytes * multiplier;
                    return (totalBytes / (1024 * 1024 * 1024)).toFixed(1);
                }
            }));
        });
    </script>
    {{/if}}
  </div>
</div>
{{#section "extraScripts"}}
<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/csp@3.x.x/dist/cdn.min.js"></script>
{{/section}}
