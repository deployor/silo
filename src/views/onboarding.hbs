<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-4xl mx-auto"
  x-data="onboardingWizard()"
  x-init="init()"
>
  <!-- Header / Progress -->
  <div class="w-full max-w-3xl mx-auto mb-10">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-black text-white tracking-tighter italic">Welcome to Cargo</h1>
        <p class="text-text-muted mt-1 font-medium">Step <span class="text-white" x-text="step"></span> of <span class="text-white" x-text="steps.length"></span></p>
      </div>

      <div class="flex items-center gap-2">
        <template x-for="(s, idx) in steps" :key="s.id">
          <button
            type="button"
            class="w-8 h-8 rounded-full border text-xs font-bold transition-colors"
            :class="idx + 1 === step ? 'bg-hc-red border-hc-red text-white' : (idx + 1 < step ? 'bg-white/10 border-white/10 text-white' : 'bg-transparent border-white/20 text-text-muted')"
            :aria-current="idx + 1 === step ? 'step' : null"
            :title="s.short"
            @click="goTo(idx + 1)"
          >
            <span x-text="idx + 1"></span>
          </button>
        </template>
      </div>
    </div>

    <div class="mt-4 w-full bg-white/5 rounded-full h-2 overflow-hidden">
      <div class="bg-hc-red h-2 transition-all duration-300"
        :style="`width: ${(step - 1) / (steps.length - 1) * 100}%`"
      ></div>
    </div>
  </div>

  <!-- Card -->
  <div class="w-full max-w-3xl mx-auto bg-hc-dark rounded-3xl border border-white/10 card-shadow p-8">
    <!-- Step content (single slot; no stacked hidden divs that can intercept clicks) -->
    <div class="text-center">
      <div class="mb-8 flex justify-center">
        <i class="text-8xl" :class="current.iconClass"></i>
      </div>

      <h2 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tighter italic" x-text="current.title"></h2>

      <p class="text-text-muted text-xl md:text-2xl max-w-3xl mx-auto font-medium leading-relaxed" x-html="current.html"></p>

      <template x-if="current.note">
        <div class="mt-8 bg-white/5 rounded-xl p-4 max-w-2xl mx-auto border border-white/10 flex items-start gap-4 text-left">
          <i class="ph-fill ph-info text-text-muted text-xl mt-1"></i>
          <p class="text-text-muted/70 text-sm font-medium leading-relaxed" x-text="current.note"></p>
        </div>
      </template>
    </div>

    <!-- Controls -->
    <div class="mt-10 flex items-center justify-between w-full max-w-md mx-auto">
      <button
        type="button"
        @click="prev()"
        :disabled="step === 1"
        class="px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group"
        :class="step === 1 ? 'opacity-40 cursor-not-allowed text-text-muted' : 'text-text-muted hover:text-white'"
      >
        <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
        <span>Back</span>
      </button>

      <button
        type="button"
        @click="next()"
        class="group bg-hc-red text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center gap-3 shadow-lg shadow-hc-red/20"
      >
        <span x-text="step < steps.length ? `Next: ${steps[step].short}` : 'Get Started'"></span>
        <i class="ph-bold" :class="step < steps.length ? 'ph-arrow-right group-hover:translate-x-1 transition-transform' : 'ph-rocket-launch group-hover:translate-x-1 transition-transform'"></i>
      </button>
    </div>
  </div>

  <script>
    function onboardingWizard() {
      return {
        step: 1,
        steps: [
          {
            id: "welcome",
            short: "Your Storage",
            title: "Welcome to Cargo!",
            iconClass: "ph-duotone ph-hand-waving text-hc-red",
            html: "Cargo is an S3 Gateway and the new Hack Club CDN.",
          },
          {
            id: "storage",
            short: "Privacy & Logs",
            title: "1GB Free Storage",
            iconClass: "ph-duotone ph-hard-drives text-blue-500",
            html:
              "Every Hack Clubber on Slack gets <span class='text-white font-bold'>1 GB for free</span>.<br>Need more? Ship projects! Storage can be used for public CDN hosting or private S3 buckets.",
            note:
              "When you turn 18, we'll archive your data and send you a download link before deleting it. But that's a problem for future you!",
          },
          {
            id: "logs",
            short: "How it Works",
            title: "We Log Requests",
            iconClass: "ph-duotone ph-shield-check text-yellow-500",
            html:
              "To keep Cargo safe and fast, we log all requests (User Agent, Path etc).<br><br><span class='text-white font-bold'>We do NOT log your file contents.</span> Your data remains yours. We only track metadata to prevent abuse.",
          },
          {
            id: "how",
            short: "Finish",
            title: "It's Just S3",
            iconClass: "ph-duotone ph-cloud-check text-green-500",
            html:
              "You can use almost all standard S3 functions. We store everyone's data in one massive bucket, but to you, it feels like your own private bucket.<br><br>There is a middleman, but you'll never notice. Just create buckets and ship!",
          },
        ],

        get current() {
          return this.steps[this.step - 1];
        },

        init() {
          // Defensive: ensure we always start on step 1 and content is consistent.
          this.step = 1;
        },

        goTo(n) {
          const next = Number(n);
          if (!Number.isFinite(next)) return;
          if (next < 1 || next > this.steps.length) return;
          this.step = next;
        },

        next() {
          if (this.step < this.steps.length) {
            this.goTo(this.step + 1);
            return;
          }

          // Last step: submit the existing server endpoint.
          // Use fetch so users don’t lose context if something goes wrong.
          fetch("/api/onboarding/complete", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: "",
          })
            .then((res) => {
              if (!res.ok) throw new Error("Failed to complete onboarding");
              window.location.href = "/";
            })
            .catch(() => {
              window.location.href = "/";
            });
        },

        prev() {
          this.goTo(this.step - 1);
        },
      };
    }
  </script>
</div>

{{#section "extraScripts"}}
<script src="https://unpkg.com/htmx.org@1.9.10"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/@phosphor-icons/web"></script>
{{/section}}
