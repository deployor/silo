<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-4xl mx-auto" x-data="{ step: 1 }" x-cloak>
  
  <!-- Step 1: Welcome -->
  <div x-show="step === 1" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100" class="text-center max-w-3xl mx-auto w-full">
    <div class="mb-8 flex justify-center">
        <i class="ph-duotone ph-hand-waving text-8xl text-hc-red"></i>
    </div>
    <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
      Welcome to Cargo!
    </h1>
    
    <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
      Cargo is an S3 Gateway and the new Hack Club CDN.
    </p>

    <div class="flex items-center justify-center gap-6">
        <button type="button" @click="step = 2" class="group bg-hc-red text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center gap-3 shadow-lg shadow-hc-red/20">
            <span>Next: Your Storage</span>
            <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
        </button>
    </div>
  </div>

  <!-- Step 2: Storage -->
  <div x-show="step === 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100" class="text-center max-w-3xl mx-auto w-full">
    <div class="mb-8 flex justify-center">
        <i class="ph-duotone ph-rocket-launch text-8xl text-blue-500"></i>
    </div>
    <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
      Ship Projects.
      <span class="block text-4xl md:text-6xl mt-2 text-white/50">Get Paid in Storage.</span>
    </h1>
    
    <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-8 leading-relaxed">
      Every YSWS project you ship unlocks more permanent cloud storage.
      <br>
      <span class="text-white font-bold">Shipping is the currency.</span> Storage is the reward.
    </p>
    
    <div class="bg-white/5 rounded-xl p-6 mb-12 max-w-2xl mx-auto border border-white/10 flex flex-col gap-4 text-left">
        <div class="flex items-start gap-4">
            <div class="bg-green-500/20 p-2 rounded-lg">
                <i class="ph-bold ph-check text-green-500 text-xl"></i>
            </div>
            <div>
                <h3 class="text-white font-bold text-lg">You ship a project</h3>
                <p class="text-text-muted">Submit your YSWS project through Cargo.</p>
            </div>
        </div>
        <div class="flex items-start gap-4">
            <div class="bg-blue-500/20 p-2 rounded-lg">
                <i class="ph-bold ph-hard-drives text-blue-500 text-xl"></i>
            </div>
            <div>
                <h3 class="text-white font-bold text-lg">We expand your quota</h3>
                <p class="text-text-muted">Earn <span class="text-white font-bold">{{yswsQuotaPerHourHuman}}</span> of permanent storage for every ship.</p>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-between w-full max-w-md mx-auto">
        <button type="button" @click="step = 1" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
            <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            <span>Back</span>
        </button>
        <button type="button" @click="step = 3" class="group bg-hc-red text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center gap-3 shadow-lg shadow-hc-red/20">
            <span>Next: Privacy & Logs</span>
            <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
        </button>
    </div>
  </div>

  <!-- Step 3: Privacy & Logs -->
  <div x-show="step === 3" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100" class="text-center max-w-3xl mx-auto w-full">
    <div class="mb-8 flex justify-center">
        <i class="ph-duotone ph-shield-check text-8xl text-yellow-500"></i>
    </div>
    <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
      We Log Requests
    </h1>
    
    <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
      To keep Cargo safe and fast, we log all requests (User Agent, Path etc). 
      <br><br>
      <span class="text-white font-bold">We do NOT log your file contents.</span> Your data remains yours. We only track metadata to prevent abuse.
    </p>

    <div class="flex items-center justify-between w-full max-w-md mx-auto">
        <button type="button" @click="step = 2" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
            <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            <span>Back</span>
        </button>
        <button type="button" @click="step = 4" class="group bg-hc-red text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center gap-3 shadow-lg shadow-hc-red/20">
            <span>Next: How it Works</span>
            <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
        </button>
    </div>
  </div>

  <!-- Step 4: How it Works -->
  <div x-show="step === 4" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100" class="text-center max-w-3xl mx-auto w-full">
    <div class="mb-8 flex justify-center">
        <i class="ph-duotone ph-cloud-check text-8xl text-green-500"></i>
    </div>
    <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
      It's Just S3
    </h1>
    
    <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
      You can use almost all standard S3 functions. We store everyone's data in one massive bucket, but to you, it feels like your own private bucket.
      <br><br>
      There is a middleman, but you'll never notice. Just create buckets and ship!
    </p>

    <div class="flex items-center justify-between w-full max-w-md mx-auto">
        <button type="button" @click="step = 3" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
            <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            <span>Back</span>
        </button>
        <form action="/api/onboarding/complete" method="POST" class="inline-block">
                <button type="submit" class="group bg-hc-red text-white px-8 py-4 rounded-xl font-bold text-lg transition-all flex items-center gap-3 shadow-lg shadow-hc-red/20">
                    <span>Get Started</span>
                    <i class="ph-bold ph-rocket-launch group-hover:translate-x-1 transition-transform"></i>
                </button>
            </form>
    </div>
  </div>

</div>

{{#section "extraScripts"}}
<script src="https://unpkg.com/htmx.org@1.9.10"></script>
<!-- CSP-safe Alpine build (no eval / Function constructor) -->
<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/csp@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/@phosphor-icons/web"></script>
{{/section}}
