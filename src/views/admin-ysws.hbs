<!-- Admin Subnav -->
<div class="flex gap-4 mb-6 border-b border-white/10 pb-4">
  <a href="/admin/users" id="tab-users" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Users</a>
  <a href="/admin/ysws" id="tab-ysws" class="text-white font-bold px-4 py-2 rounded-lg bg-white/10 transition-colors">YSWS</a>
  <a href="/admin/logs" id="tab-logs" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Logs</a>
  <a href="/admin/settings" id="tab-settings" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Settings</a>
</div>

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-3xl font-bold tracking-tight">YSWS Submissions</h1>
        <div class="text-sm text-text-muted">
            Review submissions and award storage quota.
        </div>
    </div>

    <div class="overflow-x-auto rounded-lg border border-white/10">
        <table class="w-full text-left text-sm">
            <thead class="bg-white/5 uppercase font-medium text-text-muted">
                <tr>
                    <th class="px-6 py-4">Project</th>
                    <th class="px-6 py-4">User</th>
                    <th class="px-6 py-4">Hours</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Submitted</th>
                    <th class="px-6 py-4"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5 bg-black/20">
                {{#each submissions}}
                <tr class="hover:bg-white/5 transition-colors">
                    <td class="px-6 py-4 font-medium">
                        <div class="text-white">{{this.projectName}}</div>
                        <div class="text-xs text-text-muted truncate max-w-[200px]">{{this.shortDescription}}</div>
                    </td>
                    <td class="px-6 py-4 font-mono text-xs text-text-muted">{{this.userId}}</td>
                    <td class="px-6 py-4">{{this.hoursSpent}}h</td>
                    <td class="px-6 py-4">
                        {{#if (eq this.status "pending")}}
                            <span class="px-2 py-1 rounded-full bg-yellow-500/10 text-yellow-400 text-xs border border-yellow-500/20">Pending</span>
                        {{else if (eq this.status "approved")}}
                            <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs border border-green-500/20">Approved</span>
                        {{else}}
                            <span class="px-2 py-1 rounded-full bg-red-500/10 text-red-400 text-xs border border-red-500/20">Rejected</span>
                        {{/if}}
                    </td>
                    <td class="px-6 py-4 text-text-muted deploy-time-ago" data-time="{{this.createdAt}}">
                        {{this.createdAt}}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <a href="/admin/ysws/{{this.id}}" class="text-hc-red hover:text-white transition-colors font-medium flex items-center justify-end gap-1">
                            Review
                            <i class="ph ph-arrow-right"></i>
                        </a>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-text-muted">
                        No submissions found.
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
