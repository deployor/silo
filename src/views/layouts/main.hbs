<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} - Free S3 Storage for Hack Club</title>
    <meta name="description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage. Built on Cloudflare R2 for high performance." />
    <meta name="keywords" content="free s3 storage, hack club, object storage, s3 gateway, cloudflare r2, developer tools, free tier" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://silo.hackclub.com/" />
    <meta property="og:title" content="Silo - Free S3 Storage for Hack Club" />
    <meta property="og:description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage." />
    <meta property="og:image" content="https://assets.hackclub.com/icon-rounded.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://silo.hackclub.com/" />
    <meta property="twitter:title" content="Silo - Free S3 Storage for Hack Club" />
    <meta property="twitter:description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage." />
    <meta property="twitter:image" content="https://assets.hackclub.com/icon-rounded.png" />

    <link rel="stylesheet" href="/assets/styles.css" />
    {{#if extraStyles}}
      {{{extraStyles}}}
    {{/if}}
  </head>
  <body class="min-h-screen selection:bg-hc-red selection:text-white flex flex-col font-sans {{bodyClass}}" x-data>
    <nav class="w-full bg-hc-darker border-b border-white/10 px-6 py-4 sticky top-0 z-50 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/" class="font-bold text-2xl tracking-tighter italic text-white hover:text-hc-red transition-colors">HOARD</a>
        {{#if pageTitle}}
        <span class="bg-hc-red/20 text-hc-red px-2 py-0.5 rounded text-sm font-mono border border-hc-red/30">{{pageTitle}}</span>
        {{/if}}
        {{#if breadcrumbs}}
          {{{breadcrumbs}}}
        {{/if}}
      </div>
      <div class="flex items-center gap-6 font-bold text-sm">
        {{#unless hideNavLinks}}
          {{#if user}}
            <a href="/cdn" class="text-text-muted hover:text-white transition-colors">CDN</a>
            <a href="/docs" class="text-text-muted hover:text-white transition-colors">Docs</a>
            <div class="flex items-center gap-2 min-w-0">
              <img id="user-avatar" src="{{user.avatarUrl}}" alt="User Avatar" class="w-6 h-6 rounded-full {{#unless user.avatarUrl}}hidden{{/unless}}" />
              <span class="text-text-muted font-mono truncate max-w-[14rem]" id="user-id">{{user.id}}</span>
            </div>
            {{#if user.isAdmin}}
              <a href="/admin" id="admin-link" class="text-text-muted hover:text-white transition-colors">Admin</a>
            {{/if}}
            <a href="/auth/logout" class="text-hc-red hover:text-white transition-colors" id="logout-link">Logout</a>
            <script>
              // During admin impersonation, /auth/logout stops impersonation.
              // We detect via a non-HttpOnly cookie set when impersonation starts.
              (function () {
                try {
                  const c = document.cookie || "";
                  if (c.includes("silo_impersonating=true")) {
                    const el = document.getElementById("logout-link");
                    if (el) el.textContent = "Stop impersonating";
                  }
                } catch (_e) {}
              })();
            </script>
          {{else}}
             <a href="/auth/login" class="text-hc-red hover:text-white transition-colors">Login</a>
          {{/if}}
        {{/unless}}
      </div>
    </nav>

    <main class="max-w-7xl mx-auto w-full px-6 py-8 {{mainClass}}" x-cloak>
      {{{body}}}
    </main>

    {{#if modals}}
      {{{modals}}}
    {{/if}}

    {{#if extraScripts}}
      {{{extraScripts}}}
    {{/if}}
  </body>
</html>
