<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} - Free S3 Storage for Hack Club</title>
    <meta name="description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage. Built on Cloudflare R2 for high performance." />
    <meta name="keywords" content="free s3 storage, hack club, object storage, s3 gateway, cloudflare r2, developer tools, free tier" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://silo.hackclub.com/" />
    <meta property="og:title" content="Silo - Free S3 Storage for Hack Club" />
    <meta property="og:description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage." />
    <meta property="og:image" content="https://assets.hackclub.com/icon-rounded.png" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://silo.hackclub.com/" />
    <meta property="twitter:title" content="Silo - Free S3 Storage for Hack Club" />
    <meta property="twitter:description" content="Free S3-compatible object storage for Hack Club members. Ship your projects, earn more storage." />
    <meta property="twitter:image" content="https://assets.hackclub.com/icon-rounded.png" />

    <link rel="stylesheet" href="/assets/styles.css" />
    {{#if extraStyles}}
      {{{extraStyles}}}
    {{/if}}
  </head>
  <body class="min-h-screen selection:bg-hc-red selection:text-white flex flex-col font-sans {{bodyClass}}">
    <nav class="w-full bg-hc-darker border-b border-white/10 px-6 py-4 sticky top-0 z-50 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/" class="font-bold text-2xl tracking-tighter italic text-white hover:text-hc-red transition-colors">HOARD</a>
        {{#if pageTitle}}
        <span class="bg-hc-red/20 text-hc-red px-2 py-0.5 rounded text-sm font-mono border border-hc-red/30">{{pageTitle}}</span>
        {{/if}}
        {{#if breadcrumbs}}
          {{{breadcrumbs}}}
        {{/if}}
        {{#if config.git.shortSha}}
          <div class="hidden md:flex flex-col text-[10px] leading-tight text-white/40 font-mono ml-3 transition-colors cursor-default select-none">
            <div class="flex items-center gap-1.5 whitespace-nowrap">
              <span class="uppercase tracking-wider font-bold text-white/50">{{config.env}}</span>
              <span class="opacity-30">|</span>
              <span title="{{config.git.sha}}">{{config.git.shortSha}}</span>
               {{#if config.git.date}}
                 <span class="deploy-time-ago opacity-60 ml-0.5" data-time="{{config.git.date}}" title="Commit Date: {{config.git.date}}"></span>
               {{/if}}
            </div>
          </div>
        {{/if}}
      </div>
      <div class="flex items-center gap-6 font-bold text-sm">
        {{#unless hideNavLinks}}
          {{#if user}}
            <a href="/cdn" class="text-text-muted hover:text-white transition-colors">CDN</a>
            <a href="/docs" class="text-text-muted hover:text-white transition-colors">Docs</a>
            <div class="flex items-center gap-2 min-w-0">
              <img id="user-avatar" src="{{user.avatarUrl}}" alt="User Avatar" class="w-6 h-6 rounded-full {{#unless user.avatarUrl}}hidden{{/unless}}" />
              <span class="text-text-muted font-mono truncate max-w-[14rem]" id="user-id">{{user.id}}</span>
            </div>
            {{#if user.isAdmin}}
              <a href="/admin/users" id="admin-link" class="text-text-muted hover:text-white transition-colors">Admin</a>
            {{/if}}
            <a href="/auth/logout" class="text-hc-red hover:text-white transition-colors" id="logout-link">Logout</a>
            <script>
              // During admin impersonation, /auth/logout stops impersonation.
              // We detect via a non-HttpOnly cookie set when impersonation starts.
              (function () {
                try {
                  const c = document.cookie || "";
                  if (c.includes("silo_impersonating=true")) {
                    const el = document.getElementById("logout-link");
                    if (el) el.textContent = "Stop impersonating";
                  }
                } catch (_e) {}
              })();
            </script>
          {{else}}
             <a href="/auth/login" class="text-hc-red hover:text-white transition-colors">Login</a>
          {{/if}}
        {{/unless}}
      </div>
    </nav>

    <main class="max-w-7xl mx-auto w-full px-6 py-8 {{mainClass}}">
      {{{body}}}
    </main>

    {{#if modals}}
      {{{modals}}}
    {{/if}}

    {{#if extraScripts}}
      {{{extraScripts}}}
    {{/if}}
    <script>
      (function() {
        function getTimeAgo(dateString) {
          if (!dateString) return '';
          const date = new Date(dateString);
          const now = new Date();
          const seconds = Math.floor((now - date) / 1000);
          
          if (seconds < 60) return 'now';
          
          const minutes = Math.floor(seconds / 60);
          if (minutes < 60) return `${minutes}m`;
          
          const hours = Math.floor(minutes / 60);
          if (hours < 24) return `${hours}h`;
          
          const days = Math.floor(hours / 24);
          if (days < 30) return `${days}d`;
          
          return date.toLocaleDateString();
        }

        const els = document.querySelectorAll('.deploy-time-ago');
        els.forEach(el => {
          const date = el.getAttribute('data-time');
          if (date) {
            el.textContent = getTimeAgo(date);
          }
        });

        const durationEls = document.querySelectorAll('.build-duration');
        durationEls.forEach(el => {
            const start = el.getAttribute('data-start');
            const end = el.getAttribute('data-end');
            if(start && end) {
                const diff = new Date(end).getTime() - new Date(start).getTime();
                const seconds = Math.floor(diff / 1000);
                if (seconds > 0) {
                     if (seconds < 60) {
                        el.textContent = `took ${seconds}s`;
                     } else {
                        const mins = Math.floor(seconds / 60);
                        el.textContent = `took ${mins}m`;
                     }
                }
            }
        });

      })();
    </script>
  </body>
</html>
