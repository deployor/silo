<div class="flex-1 flex items-center justify-center p-6">
  <div class="max-w-md w-full bg-black/30 rounded-2xl border border-white/10 p-6 text-center">
    <div class="w-16 h-16 bg-hc-red/20 rounded-full flex items-center justify-center mx-auto mb-4">
      <i class="ph ph-lock-key text-3xl text-hc-red"></i>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Your account is locked</h1>

    <p class="text-text-muted mb-4">
      Your account has been locked temporarily.
    </p>

    {{#if reason}}
      <div class="bg-white/5 border border-white/10 p-3 rounded-lg mb-4 text-left">
        <p class="text-text-muted text-xs font-mono mb-1">Reason</p>
        <p class="text-white text-sm font-bold">{{reason}}</p>
      </div>
    {{/if}}

    <p class="text-text-muted text-sm">
      All access (API + dashboard) is suspended for now.
      If you need support, ask in Slack.
    </p>
  </div>
</div>
