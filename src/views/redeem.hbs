{{!< main}}

<div class="max-w-2xl mx-auto py-12 px-4">
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8 shadow-2xl relative overflow-hidden">
        
        <!-- Confetti Canvas (hidden by default) -->
        <canvas id="confetti" class="absolute inset-0 w-full h-full pointer-events-none z-50" style="display: none;"></canvas>

        <div class="text-center mb-8 relative z-10">
            <h1 class="text-4xl font-bold font-display text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 mb-2">Redeem Code</h1>
            <p class="text-zinc-400">Enter your code below to claim your rewards!</p>
        </div>

        {{#if success}}
        <div class="mb-8 p-4 bg-green-500/10 border border-green-500/20 rounded-lg text-green-400 text-center relative z-10 animate-fade-in-up">
            <h3 class="text-xl font-bold mb-1">YAY! 🎉</h3>
            <p class="font-medium">Successfully redeemed!</p>
            <p class="text-sm mt-2 opacity-80">{{credits}} credits added to your account from {{programName}}.</p>
        </div>
        <div class="text-center relative z-10">
            <a href="/dashboard" class="inline-block px-6 py-3 bg-zinc-100 text-zinc-900 font-bold rounded-lg hover:bg-white transition-colors">
                Go to Dashboard
            </a>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const canvas = document.getElementById('confetti');
                canvas.style.display = 'block';
                
                var duration = 3 * 1000;
                var animationEnd = Date.now() + duration;
                var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

                function randomInRange(min, max) {
                  return Math.random() * (max - min) + min;
                }

                var interval = setInterval(function() {
                  var timeLeft = animationEnd - Date.now();

                  if (timeLeft <= 0) {
                    return clearInterval(interval);
                  }

                  var particleCount = 50 * (timeLeft / duration);
                  // since particles fall down, start a bit higher than random
                  confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                  confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
                }, 250);
            });
        </script>
        {{else}}
        
        <form method="POST" action="/redeem" class="space-y-6 relative z-10">
            <div>
                <label for="code" class="sr-only">Redemption Code</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                        </svg>
                    </div>
                    <input type="text" name="code" id="code" required 
                           class="block w-full pl-10 pr-3 py-4 bg-zinc-950 border border-zinc-800 rounded-lg text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-transparent text-lg font-mono text-center uppercase tracking-widest"
                           placeholder="PREFIX-XXXX-XXXX-XXXX"
                           value="{{code}}"
                           >
                </div>
            </div>

            {{#if error}}
            <div class="p-3 bg-red-500/10 border border-red-500/20 rounded text-red-400 text-sm text-center">
                {{error}}
            </div>
            {{/if}}

            <button type="submit" class="w-full flex justify-center py-4 px-4 border border-transparent rounded-lg shadow-sm text-lg font-bold text-white bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all transform hover:scale-[1.02]">
                Redeem Code
            </button>
        </form>
        {{/if}}
        
        <div class="mt-8 text-center">
             <p class="text-xs text-zinc-600">
                Having trouble? Contact support or verify your code source.
            </p>
        </div>
    </div>
</div>
