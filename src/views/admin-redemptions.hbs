{{!< main}}

<!-- Admin Subnav -->
<div class="flex gap-4 mb-6 border-b border-white/10 pb-4">
  <a href="/admin/users" id="tab-users" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Users</a>
  <a href="/admin/ysws" id="tab-ysws" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">YSWS</a>
  <a href="/admin/redemptions" id="tab-redemptions" class="text-white font-bold px-4 py-2 rounded-lg bg-white/10 transition-colors">Redemptions</a>
  <a href="/admin/logs" id="tab-logs" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Logs</a>
  <a href="/admin/settings" id="tab-settings" class="text-text-muted font-bold px-4 py-2 rounded-lg hover:bg-white/5 transition-colors">Settings</a>
</div>

<!-- Main Section -->
<div class="bg-hc-dark rounded-3xl border border-white/10 overflow-hidden card-shadow mb-8">
    <div class="p-6 border-b border-white/10 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-white">Redemption Programs</h2>
            <p class="text-text-muted text-sm mt-1">Manage codes and quota grants for external programs.</p>
        </div>
        <button onclick="document.getElementById('new-program-modal').classList.remove('hidden'); document.getElementById('new-program-modal').classList.add('flex');"
                class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2 rounded-lg text-sm font-bold transition-colors">
            + New Program
        </button>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-white/5 text-text-muted font-bold uppercase text-xs tracking-wider">
                <tr>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4">Prefix</th>
                    <th class="px-6 py-4">Credit</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                {{#each programs}}
                <tr class="hover:bg-white/5 transition-colors">
                    <td class="px-6 py-4 font-medium text-white">{{this.name}}</td>
                    <td class="px-6 py-4 font-mono text-xs text-text-muted">{{this.prefix}}</td>
                    <td class="px-6 py-4 text-white font-mono">{{formatBytes this.quotaCreditBytes}}</td>
                    <td class="px-6 py-4">
                        {{#if this.isActive}}
                            <span class="bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded text-xs font-bold border border-emerald-500/30">
                                ACTIVE
                            </span>
                        {{else}}
                            <span class="bg-white/10 text-text-muted px-2 py-0.5 rounded text-xs font-bold border border-white/20">
                                INACTIVE
                            </span>
                        {{/if}}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <a href="/admin/redemptions/{{this.id}}" class="text-hc-blue hover:text-blue-400 text-xs font-bold uppercase tracking-wider">
                            Manage Codes
                        </a>
                    </td>
                </tr>
                {{/each}}
                {{#unless programs}}
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-text-muted italic">
                        No redemption programs created yet.
                    </td>
                </tr>
                {{/unless}}
            </tbody>
        </table>
    </div>
</div>

<!-- New Program Modal -->
<div id="new-program-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-2xl font-bold text-white">Create New Program</h3>
            <button onclick="document.getElementById('new-program-modal').classList.add('hidden'); document.getElementById('new-program-modal').classList.remove('flex');" class="text-text-muted hover:text-white transition-colors">
                <i class="ph ph-x text-2xl"></i>
            </button>
        </div>
        <form method="POST" action="/admin/redemptions/create">
            <div class="mb-4">
                <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2">Program Name</label>
                <input type="text" name="name" required placeholder="e.g. Hack Club Winter 2024"
                       class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue placeholder-white/20 transition-colors">
            </div>
            <div class="mb-4">
                <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2">Code Prefix</label>
                <input type="text" name="prefix" required placeholder="e.g. WINTER" pattern="[A-Za-z0-9]+" title="Alphanumeric only"
                       class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue placeholder-white/20 transition-colors uppercase font-mono">
                <p class="text-xs text-text-muted mt-2">Codes will look like: PREFIX-XXXX-XXXX</p>
            </div>
             <div class="mb-4">
                <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2">Quota Credit</label>
                <div class="flex gap-2">
                    <input type="number" name="amount" required value="1" step="0.1"
                        class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue placeholder-white/20 transition-colors font-mono">
                    <select name="unit" class="bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue cursor-pointer">
                        <option value="1073741824" selected>GB</option>
                        <option value="1048576">MB</option>
                        <option value="1099511627776">TB</option>
                    </select>
                </div>
            </div>
            <div class="mb-6">
                <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2">Description</label>
                <textarea name="description" rows="3"
                          class="w-full bg-black/30 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-hc-blue focus:ring-1 focus:ring-hc-blue placeholder-white/20 transition-colors"></textarea>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('new-program-modal').classList.add('hidden'); document.getElementById('new-program-modal').classList.remove('flex');"
                        class="text-text-muted hover:text-white px-4 py-2 text-sm font-bold transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="bg-hc-blue hover:bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow">
                    Create Program
                </button>
            </div>
        </form>
    </div>
</div>
