{{!< main}}

<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-4xl mx-auto">
    
    <!-- Hero Section -->
    <div class="text-center max-w-3xl mx-auto w-full mb-12">
        <div class="mb-8 flex justify-center">
            <i class="ph-duotone ph-graduation-cap text-8xl text-yellow-500"></i>
        </div>
        <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
            It's time to say goodbye
        </h1>
        <p class="text-text-muted text-2xl max-w-2xl mx-auto font-medium leading-relaxed">
            You've turned 18, so you've aged out of Silo. <br/>
            Please download your files before your account is closed.
        </p>
    </div>

    <!-- Status Cards -->
    <div class="w-full max-w-3xl mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Time Remaining Card -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
             <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Time Remaining</div>
             <div class="text-4xl font-bold text-white tracking-tight">{{daysRemaining}} Days</div>
        </div>
        <!-- Deadline Card -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
             <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Deadline</div>
             <div class="text-2xl font-bold text-white tracking-tight">{{gracePeriodEndsAt}}</div>
        </div>
    </div>
    
    <!-- Progress Bar -->
    <div class="w-full max-w-3xl bg-white/5 border border-white/10 rounded-2xl p-6 mb-12">
        <div class="flex justify-between text-sm text-text-muted font-bold uppercase tracking-widest mb-4">
            <span>Grace Period Progress</span>
            <span>{{progressPercentage}}%</span>
        </div>
        <div class="w-full bg-black/30 rounded-full h-4 overflow-hidden">
            <div class="bg-hc-red h-full rounded-full transition-all duration-1000" style="width: {{progressPercentage}}%"></div>
        </div>
    </div>

    <!-- Actions Section -->
    <div class="w-full max-w-2xl mx-auto text-center mb-16">
        {{#if showSuccess}}
            <div class="bg-green-500/10 rounded-2xl p-8 mb-8 border border-green-500/20">
                <i class="ph-duotone ph-check-circle text-4xl text-green-500 mb-4"></i>
                <h2 class="text-3xl font-bold mb-2 text-white">Export Started</h2>
                <p class="mb-6 text-text-muted text-lg">Your download should begin automatically.</p>
                <a href="/dashboard/offboarding/archive" class="text-white underline hover:no-underline font-mono">
                    Click here if it doesn't start
                </a>
                
                <script>
                    setTimeout(() => {
                        window.location.href = "/dashboard/offboarding/archive";
                    }, 1000);
                </script>
            </div>
        {{else}}
            {{#if user.dataExported}}
                <div class="bg-blue-500/10 rounded-2xl p-8 mb-8 border border-blue-500/20">
                    <i class="ph-duotone ph-lock-key text-4xl text-blue-500 mb-4"></i>
                    <h3 class="text-white font-bold text-2xl mb-2">Account Frozen</h3>
                    <p class="text-text-muted text-lg leading-relaxed">
                        You've already started an export, so your account is locked to prevent changes. You can re-download your archive below.
                    </p>
                </div>
            {{else}}
                <div class="bg-yellow-500/10 rounded-2xl p-6 mb-8 border border-yellow-500/20 text-left flex gap-4">
                    <i class="ph-fill ph-warning text-yellow-500 text-2xl shrink-0 mt-1"></i>
                    <p class="text-text-muted text-lg leading-relaxed">
                        Downloading your data will <span class="text-white font-bold">immediately freeze your account</span>. You won't be able to upload new files or create buckets afterwards.
                    </p>
                </div>
            {{/if}}

            <form action="/dashboard/offboarding/download" method="POST" id="download-form">
                <button type="button" onclick="triggerDownloadConfirm()" id="download-btn" class="group relative w-full bg-hc-red text-white hover:scale-[1.02] text-xl font-bold py-6 rounded-2xl transition-all shadow-lg shadow-hc-red/20">
                    <span id="btn-content" class="flex items-center justify-center gap-3">
                        <i class="ph-bold ph-download-simple text-2xl"></i>
                        {{#if user.dataExported}}Download Archive Again{{else}}Download Everything (.zip){{/if}}
                    </span>
                    <div id="btn-spinner" class="hidden absolute inset-0 flex items-center justify-center">
                        <svg class="animate-spin h-8 w-8 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                </button>
            </form>
            <p class="text-center text-text-muted mt-4 font-medium">
                This wraps up all your buckets into one file.
            </p>
        {{/if}}
    </div>

    <!-- Migration Guide -->
    <div class="w-full max-w-3xl pt-8">
        <div class="flex items-center gap-4 mb-8 justify-center">
            <div class="h-px bg-white/10 flex-1"></div>
            <h2 class="text-2xl font-bold text-text-muted uppercase tracking-widest">Where to go next</h2>
            <div class="h-px bg-white/10 flex-1"></div>
        </div>
        
        <div class="grid gap-6">
            <div class="bg-white/5 rounded-2xl p-6 border border-white/10 flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left hover:bg-white/10 transition-colors group">
                <div class="shrink-0 w-16 h-16 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-colors">
                     <i class="ph-duotone ph-cloud-arrow-up text-3xl"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-white font-bold text-xl mb-2">Set up Cloudflare R2</h3>
                    <p class="text-text-muted text-lg leading-relaxed">
                        It's the best alternative to Silo (S3-compatible) and has a massive free tier. Create an account, enable R2, and generate "S3 API Tokens".
                    </p>
                </div>
            </div>

            <div class="bg-white/5 rounded-2xl p-6 border border-white/10 flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left hover:bg-white/10 transition-colors group">
                <div class="shrink-0 w-16 h-16 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-colors">
                     <i class="ph-duotone ph-arrows-left-right text-3xl"></i>
                </div>
                <div class="flex-1 w-full max-w-full">
                    <h3 class="text-white font-bold text-xl mb-2">Move your files directly</h3>
                    <p class="text-text-muted text-lg leading-relaxed mb-4">
                        Use <strong>Rclone</strong> to transfer directly from Silo to another provider. Here is the configuration you need:
                    </p>
                    
                    <div class="bg-black/50 rounded-xl p-6 border border-white/10 font-mono text-sm text-emerald-400 overflow-x-auto w-full text-left mb-4">
                        <div class="text-text-muted mb-2 select-none"># ~/.config/rclone/rclone.conf</div>
                        [silo]<br>
                        type = s3<br>
                        provider = Other<br>
                        env_auth = false<br>
                        access_key_id = <span class="text-yellow-400"><your_access_key></span><br>
                        secret_access_key = <span class="text-yellow-400"><your_secret_key></span><br>
                        endpoint = https://silo.hackclub.com<br>
                        acl = private
                    </div>

                    <p class="text-text-muted text-sm mb-2">Then run the sync command:</p>
                    <div class="bg-black/50 rounded-xl p-4 border border-white/10 font-mono text-sm text-white overflow-x-auto w-full text-left">
                        rclone sync silo:my-bucket r2:new-bucket --progress --transfers=32
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="fixed inset-0 bg-black/90 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
        <h3 class="text-2xl font-bold mb-4 text-white" id="confirm-title">
            Confirm Action
        </h3>
        <p class="text-text-muted mb-8 leading-relaxed" id="confirm-message">
            Are you sure you want to proceed?
        </p>

        <div class="flex justify-end gap-3">
            <button onclick="closeConfirmModal()" class="text-text-muted hover:text-white px-4 py-3 text-sm font-bold transition-colors">
                Cancel
            </button>
            <button id="confirm-btn" disabled class="bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2">
                <span id="confirm-btn-text">Confirm (3)</span>
                <svg id="confirm-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    let countdownInterval;

    function openConfirmModal(title, message, onConfirm) {
        document.getElementById("confirm-title").textContent = title;
        document.getElementById("confirm-message").textContent = message;
        
        const btn = document.getElementById("confirm-btn");
        const btnText = document.getElementById("confirm-btn-text");
        
        // Reset Button State
        btn.className = "bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2";
        btn.disabled = true;
        btnText.textContent = "Confirm (3)";

        // Remove old listener to avoid stacking
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        
        // Countdown Logic
        let seconds = 3;
        if (countdownInterval) clearInterval(countdownInterval);
        
        countdownInterval = setInterval(() => {
            seconds--;
            if (seconds <= 0) {
                clearInterval(countdownInterval);
                newBtn.disabled = false;
                newBtn.className = "bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow flex items-center gap-2";
                newBtn.querySelector("#confirm-btn-text").textContent = "Confirm";
            } else {
                newBtn.querySelector("#confirm-btn-text").textContent = `Confirm (${seconds})`;
            }
        }, 1000);

        newBtn.onclick = async () => {
            const spinner = document.getElementById("confirm-spinner");
            const btnText = newBtn.querySelector("#confirm-btn-text");
            
            newBtn.disabled = true;
            spinner.classList.remove("hidden");
            btnText.textContent = "Processing...";
            
            try {
                await onConfirm();
                closeConfirmModal();
            } catch (e) {
                console.error(e);
                alert("Action failed");
            } finally {
                newBtn.disabled = false;
                spinner.classList.add("hidden");
                btnText.textContent = "Confirm";
            }
        };
        
        document.getElementById("confirm-modal").classList.remove("hidden");
        document.getElementById("confirm-modal").classList.add("flex");
    }

    function closeConfirmModal() {
        if (countdownInterval) clearInterval(countdownInterval);
        document.getElementById("confirm-modal").classList.add("hidden");
        document.getElementById("confirm-modal").classList.remove("flex");
    }

    function triggerDownloadConfirm() {
        const title = "Final Check";
        const message = "This will freeze your account immediately to ensure your backup is complete. You won't be able to upload files afterwards. \n\nYou can always re-download this archive until your grace period ends.";
        
        openConfirmModal(title, message, async () => {
            const form = document.getElementById('download-form');
            const btn = document.getElementById('download-btn');
            const content = document.getElementById('btn-content');
            const spinner = document.getElementById('btn-spinner');
            
            // Visual feedback on button
            content.classList.add('opacity-0');
            spinner.classList.remove('hidden');
            btn.disabled = true;
            btn.classList.add('cursor-not-allowed', 'bg-gray-200');

            // Submit the form
            form.submit();

            // Re-enable button logic (fallback)
            setTimeout(() => {
                 content.classList.remove('opacity-0');
                 spinner.classList.add('hidden');
                 btn.disabled = false;
                 btn.classList.remove('cursor-not-allowed', 'bg-gray-200');
            }, 8000);
        });
    }
</script>

{{#section "extraScripts"}}
<script src="https://unpkg.com/@phosphor-icons/web"></script>
{{/section}}
