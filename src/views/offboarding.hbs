{{!< main}}

<div class="min-h-[80vh] flex flex-col items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full text-center">
        <div class="flex justify-center mb-6">
            <div class="text-hc-red p-4 bg-hc-red/10 rounded-full border border-hc-red/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path d="M12 14l9-5-9-5-9 5 9 5z" />
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                </svg>
            </div>
        </div>
        <h1 class="text-4xl font-bold text-white mb-2">Graduation Time</h1>
        <p class="text-xl text-text-muted mb-8">It's time to say goodbye to Silo.</p>

        <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow text-left mb-8 relative overflow-hidden">

            <h2 class="text-2xl font-bold text-white mb-4">Export Your Data</h2>
            <p class="text-text-muted mb-6">
                Since you're over 18, you are graduating from Hack Club Silo.
                We've prepared a complete archive of all your buckets and files.
            </p>

            <div class="bg-white/5 rounded-xl p-4 mb-6 border border-white/10 flex items-center justify-between">
                <div>
                    <div class="text-xs text-text-muted uppercase font-bold tracking-wider mb-1">Time Remaining</div>
                    <div class="text-2xl font-mono text-white">{{daysRemaining}} Days</div>
                </div>
                 <div class="text-right">
                    <div class="text-xs text-text-muted uppercase font-bold tracking-wider mb-1">Deadline</div>
                    <div class="text-sm font-mono text-white">{{gracePeriodEndsAt}}</div>
                </div>
            </div>

            {{#if user.dataExported}}
            <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-4 mb-8">
                <div class="text-blue-200 text-sm flex gap-3">
                    <div class="shrink-0">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                         </svg>
                    </div>
                    <div>
                        <strong>Account Frozen:</strong> You have already initiated an export. Your account is now frozen.
                        <br/><br/>
                        • No new files can be uploaded.<br/>
                        • Buckets and keys cannot be modified.<br/>
                        • You can re-download your data below if needed.
                    </div>
                </div>
            </div>
            {{else}}
            <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-xl p-4 mb-8">
                <div class="text-yellow-200 text-sm flex gap-3">
                    <div class="shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div>
                        <strong>Important:</strong> Clicking the download button below will <span class="underline">immediately freeze your account</span>.
                        You won't be able to upload new files or create new buckets after starting the export.
                    </div>
                </div>
            </div>
            {{/if}}

            <form action="/dashboard/offboarding/download" method="POST" onsubmit="return confirmDownload()">
                <button type="submit" id="download-btn" class="w-full bg-hc-red hover:bg-red-600 text-white text-lg font-bold py-4 rounded-xl shadow-lg hover:shadow-xl transition-all hover:scale-[1.02] flex items-center justify-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    {{#if user.dataExported}}Download Archive Again{{else}}Download All Data (.zip){{/if}}
                </button>
            </form>
            <p class="text-center text-xs text-text-muted mt-4">
                This may take a while depending on your storage usage. Please do not close this tab.
            </p>
        </div>
    </div>
</div>

<script>
    function confirmDownload() {
        if (confirm("Are you sure? This will freeze your account immediately to ensure data consistency during export.")) {
            const btn = document.getElementById('download-btn');
            const originalContent = btn.innerHTML;
            btn.innerHTML = 'Preparing Archive... <svg class="animate-spin h-5 w-5 ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');

            // Re-enable button after a short delay to allow retry if download fails to start or for next download
            // Note: The download itself is a navigation/POST, but if it's an attachment, the page might not unload.
            // A simple timeout is a basic fix; robust solution requires cookie tracking.
            setTimeout(() => {
                 btn.innerHTML = originalContent;
                 btn.disabled = false;
                 btn.classList.remove('opacity-75', 'cursor-not-allowed');
            }, 5000);

            return true;
        }
        return false;
    }
</script>
