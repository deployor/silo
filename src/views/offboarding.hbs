{{!< main}}

<div class="min-h-[80vh] flex flex-col items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full text-center">
        <div class="flex justify-center mb-6">
            <div class="text-hc-red p-4 bg-hc-red/10 rounded-full border border-hc-red/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
        </div>
        <h1 class="text-4xl font-bold text-white mb-2">It's time to move on</h1>
        <p class="text-xl text-text-muted mb-8">It's time to say goodbye to Silo.</p>

        <!-- Stepper -->
        <div class="w-full max-w-3xl mx-auto mb-16 px-4">
            <div class="relative">
                <!-- Progress Track -->
                <div class="absolute top-6 left-0 w-full h-3 bg-white/10 rounded-full overflow-hidden">
                     <!-- Progress Fill (Solid Color) -->
                    <div class="h-full bg-hc-red transition-all duration-1000 ease-out" style="width: {{progressPercentage}}%"></div>
                </div>
                
                <div class="relative flex justify-between w-full">
                    <!-- Step 1: Notification -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        <div class="w-12 h-12 rounded-full bg-white text-black border-4 border-hc-dark flex items-center justify-center z-10 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h3 class="text-white font-bold text-sm uppercase tracking-wide">Notify</h3>
                    </div>

                    <!-- Step 2: Export Data -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        <div class="w-12 h-12 rounded-full {{#if user.dataExported}}bg-white text-black{{else}}bg-hc-red text-white{{/if}} border-4 border-hc-dark flex items-center justify-center z-10 mb-3 transition-colors">
                            {{#if user.dataExported}}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                            </svg>
                            {{else}}
                            <span class="font-bold text-lg">2</span>
                            {{/if}}
                        </div>
                        <h3 class="{{#if user.dataExported}}text-white{{else}}text-hc-red{{/if}} font-bold text-sm uppercase tracking-wide">Export</h3>
                    </div>

                    <!-- Step 3: Deletion -->
                    <div class="flex flex-col items-center group cursor-default w-32">
                        <div class="w-12 h-12 rounded-full bg-hc-dark border-2 border-white/10 flex items-center justify-center z-10 mb-3">
                            <span class="text-text-muted font-bold text-lg">3</span>
                        </div>
                        <h3 class="text-text-muted font-bold text-sm uppercase tracking-wide">Deletion</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow text-left mb-8 relative overflow-hidden">

            {{#if showSuccess}}
                <div class="mb-8 bg-hc-dark border-2 border-emerald-500 rounded-xl p-6 flex flex-col items-center text-center card-shadow">
                    <div class="w-16 h-16 bg-emerald-500 rounded-full flex items-center justify-center text-white mb-4 border-4 border-hc-dark">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-white mb-2">Export Started!</h2>
                    <p class="text-emerald-400 text-sm mb-4 font-bold">
                        Your download should begin automatically. <a href="/dashboard/offboarding/archive" class="underline hover:text-white">Click here if it doesn't</a>.
                    </p>
                    <div class="text-text-muted text-xs max-w-md">
                        Your account is now frozen. Please keep your archive safe! You can download it again from this page until your grace period ends.
                    </div>
                    
                    <!-- Auto-trigger download for fallback -->
                    <script>
                        setTimeout(() => {
                            window.location.href = "/dashboard/offboarding/archive";
                        }, 1000);
                    </script>
                </div>
            {{/if}}

            <h2 class="text-2xl font-bold text-white mb-4">Export Your Data</h2>
            <p class="text-text-muted mb-6">
                Since you're over 18, it's time to move off Hack Club Silo.
                We've prepared a complete archive of all your buckets and files.
            </p>

            <div class="bg-white/5 rounded-xl p-4 mb-6 border border-white/10 flex items-center justify-between">
                <div>
                    <div class="text-xs text-text-muted uppercase font-bold tracking-wider mb-1">Time Remaining</div>
                    <div class="text-2xl font-mono text-white">{{daysRemaining}} Days</div>
                </div>
                 <div class="text-right">
                    <div class="text-xs text-text-muted uppercase font-bold tracking-wider mb-1">Deadline</div>
                    <div class="text-sm font-mono text-white">{{gracePeriodEndsAt}}</div>
                </div>
            </div>

            {{#if user.dataExported}}
            <div class="bg-hc-dark border-2 border-blue-500 rounded-xl p-4 mb-8">
                <div class="text-blue-500 text-sm flex gap-3">
                    <div class="shrink-0">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                         </svg>
                    </div>
                    <div>
                        <strong class="font-bold">Account Frozen:</strong> You have already initiated an export. Your account is now frozen.
                        <br/><br/>
                        • No new files can be uploaded.<br/>
                        • Buckets and keys cannot be modified.<br/>
                        • You can re-download your data below if needed.
                    </div>
                </div>
            </div>
            {{else}}
            <div class="bg-hc-dark border-2 border-yellow-500 rounded-xl p-4 mb-8">
                <div class="text-yellow-500 text-sm flex gap-3">
                    <div class="shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div>
                        <strong class="font-bold">Important:</strong> Clicking the download button below will <span class="underline">immediately freeze your account</span>.
                        You won't be able to upload new files or create new buckets after starting the export.
                    </div>
                </div>
            </div>
            {{/if}}

            <form action="/dashboard/offboarding/download" method="POST" id="download-form">
                <button type="button" onclick="triggerDownloadConfirm()" id="download-btn" class="w-full bg-hc-red hover:bg-red-600 text-white text-lg font-bold py-4 rounded-xl shadow-lg hover:shadow-xl transition-all hover:scale-[1.02] flex items-center justify-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    {{#if user.dataExported}}Download Archive Again{{else}}Download All Data (.zip){{/if}}
                </button>
            </form>
            <p class="text-center text-xs text-text-muted mt-4">
                This may take a while depending on your storage usage. Please do not close this tab.
            </p>
        </div>

        <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow text-left mb-8">
             <h2 class="text-2xl font-bold text-white mb-4">How to Migrate to Cloudflare R2</h2>
             <p class="text-text-muted mb-4">
                Since you're moving on, we recommend Cloudflare R2 as a great alternative. It's S3-compatible and has a generous free tier.
             </p>
             <ol class="list-decimal list-inside text-text-muted space-y-2 mb-6">
                <li>Create a Cloudflare account and enable R2.</li>
                <li>Create a new bucket in R2.</li>
                <li>Generate S3 API tokens (Access Key ID and Secret Access Key) in R2.</li>
                <li>Download your data from Silo using the button above.</li>
                <li>Unzip the archive.</li>
                <li>Use a tool like <code class="text-white">rclone</code> or the AWS CLI to upload your files to R2.</li>
             </ol>
             <div class="bg-black/30 p-4 rounded-xl border border-white/10 font-mono text-xs text-white overflow-x-auto">
                # Example using AWS CLI with R2<br/>
                aws s3 sync ./my-silo-export s3://my-new-r2-bucket --endpoint-url https://<accountid>.r2.cloudflarestorage.com
             </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
        <h3 class="text-2xl font-bold mb-4 text-white" id="confirm-title">
            Confirm Action
        </h3>
        <p class="text-text-muted mb-8" id="confirm-message">
            Are you sure you want to proceed?
        </p>

        <div class="flex justify-end gap-3">
            <button onclick="closeConfirmModal()" class="text-text-muted hover:text-white px-4 py-2 text-sm font-bold transition-colors">
                Cancel
            </button>
            <button id="confirm-btn" class="bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow flex items-center gap-2">
                <span id="confirm-btn-text">Confirm</span>
                <svg id="confirm-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    function openConfirmModal(title, message, onConfirm) {
        document.getElementById("confirm-title").textContent = title;
        document.getElementById("confirm-message").textContent = message;
        
        const btn = document.getElementById("confirm-btn");
        // Remove old listener to avoid stacking (simple way)
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        
        newBtn.onclick = async () => {
            const spinner = document.getElementById("confirm-spinner");
            const btnText = document.getElementById("confirm-btn-text");
            
            newBtn.disabled = true;
            spinner.classList.remove("hidden");
            btnText.textContent = "Processing...";
            
            try {
                await onConfirm();
                closeConfirmModal();
            } catch (e) {
                console.error(e);
                alert("Action failed");
            } finally {
                newBtn.disabled = false;
                spinner.classList.add("hidden");
                btnText.textContent = "Confirm";
            }
        };
        
        document.getElementById("confirm-modal").classList.remove("hidden");
        document.getElementById("confirm-modal").classList.add("flex");
    }

    function closeConfirmModal() {
        document.getElementById("confirm-modal").classList.add("hidden");
        document.getElementById("confirm-modal").classList.remove("flex");
    }

    function triggerDownloadConfirm() {
        const title = "Ready to Migrate?";
        const message = "Please store this archive carefully! By proceeding, you confirm that you are migrating your data. Your account will be frozen to prevent further changes, and your files will be queued for deletion at the end of the grace period. \n\nDon't worry: You can re-download this archive at any time before your grace period ends.";
        
        openConfirmModal(title, message, async () => {
            const form = document.getElementById('download-form');
            const btn = document.getElementById('download-btn');
            const originalContent = btn.innerHTML;
            
            // Visual feedback on button
            btn.innerHTML = 'Preparing Archive... <svg class="animate-spin h-5 w-5 ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');

            // Submit the form
            form.submit();

            // Re-enable button logic (simple timeout fallback)
            setTimeout(() => {
                 btn.innerHTML = originalContent;
                 btn.disabled = false;
                 btn.classList.remove('opacity-75', 'cursor-not-allowed');
            }, 8000);
        });
    }
</script>
