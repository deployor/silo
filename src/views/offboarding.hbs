{{!< main}}

<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-5xl mx-auto" 
     x-data="offboardingWizard()" 
     x-cloak>
    
    <!-- Step 1: Overview & Choice -->
    <div x-show="step === 1" 
         x-transition:enter="transition ease-out duration-300" 
         x-transition:enter-start="opacity-0 transform scale-95" 
         x-transition:enter-end="opacity-100 transform scale-100" 
         class="w-full max-w-4xl mx-auto">
         
         <!-- Hero -->
         <div class="text-center mb-12">
            <div class="mb-6 flex justify-center">
                <i class="ph-duotone ph-hand-waving text-8xl text-hc-red transform scale-x-[-1]"></i>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tighter italic">
                It's time to say goodbye.
            </h1>
            <p class="text-text-muted text-xl md:text-2xl max-w-2xl mx-auto font-medium leading-relaxed">
                You've turned 18, so you've aged out of Silo. <br/>
                Please download your files before your account is closed.
            </p>
         </div>

         <!-- Status Cards -->
         <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
                <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Time Remaining</div>
                <div class="text-4xl font-bold text-white tracking-tight">{{daysRemaining}} Days</div>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
                 <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Deadline</div>
                 <div class="text-2xl font-bold text-white tracking-tight">{{gracePeriodEndsAt}}</div>
            </div>
         </div>

         <!-- Primary Actions -->
         <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Download Option -->
             <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow flex flex-col items-center text-center hover:border-white/30 transition-colors group">
                <div class="h-16 w-16 bg-white/10 rounded-full flex items-center justify-center mb-6 text-3xl text-white group-hover:scale-110 transition-transform">
                    <i class="ph-duotone ph-download-simple"></i>
                </div>
                <h3 class="text-2xl font-bold text-white mb-2">Download Archive</h3>
                <p class="text-text-muted mb-8 flex-1">
                    Get a ZIP file containing all your buckets, files, and metadata.
                </p>
                
                {{#if showSuccess}}
                <div class="bg-green-500/20 text-green-400 p-4 rounded-xl font-bold w-full">
                    <i class="ph-bold ph-check-circle mr-2"></i> Archive Created
                </div>
                {{else}}
                <form action="/dashboard/offboarding/download" method="POST" class="w-full">
                    <button type="button" onclick="triggerDownloadConfirm()" class="w-full bg-white/10 hover:bg-white/20 text-white font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2">
                        Download ZIP
                    </button>
                </form>
                {{/if}}
             </div>

             <!-- Migration Option -->
             <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow flex flex-col items-center text-center hover:border-white/30 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 bg-hc-red text-white text-xs font-bold px-3 py-1 rounded-bl-xl">NEW</div>
                <div class="h-16 w-16 bg-blue-500/10 rounded-full flex items-center justify-center mb-6 text-3xl text-blue-400 group-hover:scale-110 transition-transform">
                    <i class="ph-duotone ph-rocket-launch"></i>
                </div>
                <h3 class="text-2xl font-bold text-white mb-2">Migration Assistant</h3>
                <p class="text-text-muted mb-8 flex-1">
                    Move your files directly to another S3 provider (R2, AWS, etc) without downloading.
                </p>
                <button @click="step = 2" class="w-full bg-hc-red text-white hover:bg-red-600 font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
                    Start Migration
                </button>
             </div>
         </div>
    </div>

    <!-- Step 2: Choose Provider -->
    <div x-show="step === 2" class="w-full max-w-5xl mx-auto text-center"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="mb-8">
            <button @click="step = 1" class="text-text-muted hover:text-white flex items-center gap-2 mx-auto mb-4 font-bold">
                <i class="ph-bold ph-arrow-left"></i> Back
            </button>
            <h2 class="text-4xl font-black text-white mb-4">Choose your new home</h2>
            <p class="text-text-muted text-lg">Where should we move your files?</p>
         </div>

         <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
             <!-- R2 -->
             <button @click="selectProvider('r2')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#F38020]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/cloudflare.png" class="w-full h-full object-contain" alt="Cloudflare" />
                  </div>
                  <div class="flex-1">
                      <div class="flex items-center gap-3 mb-1">
                         <h4 class="text-white font-bold text-xl">Cloudflare R2</h4>
                         <span class="bg-[#F38020]/20 text-[#F38020] text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wide">Recommended</span>
                      </div>
                      <p class="text-text-muted text-sm">Zero egress fees. S3-compatible.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
             
              <!-- AWS -->
              <button @click="selectProvider('aws')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#FF9900]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/aws.png" class="w-full h-full object-contain" alt="AWS" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">Amazon S3</h4>
                      <p class="text-text-muted text-sm">The industry standard.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
 
             <!-- Backblaze -->
              <button @click="selectProvider('backblaze')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#FF0000]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/backblaze.png" class="w-full h-full object-contain" alt="Backblaze" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">Backblaze B2</h4>
                      <p class="text-text-muted text-sm">Affordable object storage.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
 
             <!-- DigitalOcean -->
              <button @click="selectProvider('digitalocean')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#0080FF]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/digitalocean.png" class="w-full h-full object-contain" alt="DigitalOcean" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">DigitalOcean</h4>
                      <p class="text-text-muted text-sm">Simple Spaces object storage.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
            
             <button @click="selectProvider('custom')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-white/50 rounded-2xl p-6 transition-all flex items-center gap-6 col-span-1 md:col-span-2">
                 <div class="h-16 w-16 shrink-0 rounded-xl bg-white/10 flex items-center justify-center p-3 text-3xl text-white">
                     <i class="ph-bold ph-globe"></i>
                 </div>
                 <div class="flex-1">
                     <h4 class="text-white font-bold text-xl mb-1">Other / S3 Compatible</h4>
                     <p class="text-text-muted text-sm">MinIO, Wasabi, etc.</p>
                 </div>
                 <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
            </button>
         </div>
    </div>

    <!-- Step 3: Connect (Credentials) -->
    <div x-show="step === 3" class="w-full max-w-2xl mx-auto"
         x-transition:enter="transition ease-out duration-300" 
         x-transition:enter-start="opacity-0 transform scale-95" 
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="text-center mb-8">
             <button @click="step = 2" class="text-text-muted hover:text-white flex items-center gap-2 mx-auto mb-4 font-bold">
                <i class="ph-bold ph-arrow-left"></i> Back
            </button>
            <h2 class="text-3xl font-black text-white mb-2">Connect <span x-text="providerName"></span></h2>
            <p class="text-text-muted">Enter your credentials to allow Silo to transfer files.</p>
         </div>

         <!-- Instructions Block -->
         <div x-show="provider === 'r2'" class="bg-[#F38020]/10 border border-[#F38020]/20 rounded-2xl p-6 mb-8 text-left">
             <h4 class="text-[#F38020] font-bold mb-2 flex items-center gap-2">
                 <i class="ph-bold ph-info"></i> How to get R2 Credentials
             </h4>
             <ul class="list-disc list-inside text-sm text-[#F38020]/80 space-y-1 ml-1">
                 <li>Go to R2 Dashboard > "Manage R2 API Tokens"</li>
                 <li>Create token with <strong>Admin Read & Write</strong> permissions</li>
                 <li>Copy the Access Key ID and Secret Access Key</li>
             </ul>
         </div>

         <form @submit.prevent="analyze" class="space-y-6 text-left">
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Endpoint URL</label>
                <input type="text" x-model="creds.endpoint" required placeholder="https://..." class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Access Key ID</label>
                <input type="text" x-model="creds.accessKeyId" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Secret Access Key</label>
                <input type="password" x-model="creds.secretAccessKey" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>

            <!-- Debug Button -->
            <button type="button" @click="fillDebug" class="text-xs text-white/20 hover:text-white/50">[Debug]</button>

            <button type="submit" :disabled="loading" class="w-full bg-white text-black hover:bg-gray-200 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-wait">
                <span x-show="!loading">Connect & Analyze</span>
                <span x-show="loading"><i class="ph-bold ph-spinner animate-spin"></i> Connecting...</span>
            </button>
         </form>
    </div>

    <!-- Step 4: Plan -->
    <div x-show="step === 4" class="w-full max-w-4xl mx-auto"
         x-transition:enter="transition ease-out duration-300" 
         x-transition:enter-start="opacity-0 transform scale-95" 
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="text-center mb-8">
            <button @click="step = 3" class="text-text-muted hover:text-white flex items-center gap-2 mx-auto mb-4 font-bold">
                <i class="ph-bold ph-arrow-left"></i> Back
            </button>
            <h2 class="text-3xl font-black text-white mb-2">Migration Plan</h2>
            <p class="text-text-muted">Review where your buckets will go.</p>
         </div>

         <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden mb-8">
             <table class="w-full text-left">
                 <thead class="bg-white/5 text-text-muted font-bold uppercase text-xs tracking-wider">
                     <tr>
                         <th class="p-4 w-12 text-center">
                             <input type="checkbox" @change="toggleAll($el.checked)" checked class="rounded bg-white/10 border-white/20 text-hc-red focus:ring-0">
                         </th>
                         <th class="p-4">Local Bucket</th>
                         <th class="p-4">Target Bucket</th>
                         <th class="p-4 text-right">Status</th>
                     </tr>
                 </thead>
                 <tbody class="divide-y divide-white/5 text-white">
                     <template x-for="bucket in plan" :key="bucket.localName">
                         <tr>
                             <td class="p-4 text-center">
                                 <input type="checkbox" x-model="bucket.selected" class="rounded bg-white/10 border-white/20 text-hc-red focus:ring-0">
                             </td>
                             <td class="p-4 font-mono text-white/70" x-text="bucket.localName"></td>
                             <td class="p-4">
                                 <input type="text" x-model="bucket.targetName" class="bg-black/20 border border-white/10 rounded px-3 py-2 w-full font-mono text-sm focus:border-hc-red outline-none">
                             </td>
                             <td class="p-4 text-right">
                                 <span x-show="bucket.status === 'AVAILABLE'" class="text-blue-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-plus-circle"></i> Create</span>
                                 <span x-show="bucket.status === 'EXISTS'" class="text-green-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-check-circle"></i> Exists</span>
                                 <span x-show="bucket.status === 'TAKEN'" class="text-red-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-x-circle"></i> Taken</span>
                             </td>
                         </tr>
                     </template>
                 </tbody>
             </table>
         </div>

         <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-xl p-4 flex gap-3 text-sm text-yellow-200/80 mb-8 text-left">
                <i class="ph-fill ph-warning text-lg shrink-0 mt-0.5"></i>
                <p>
                    <strong>Warning:</strong> Starting migration will <span class="underline">freeze your Silo account</span>.
                    We will attempt to create any "Create" buckets. Ensure your API token has Write permissions.
                </p>
         </div>

         <button @click="startMigration" class="w-full bg-hc-red text-white hover:bg-red-600 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
            Start Migration <i class="ph-bold ph-rocket-launch"></i>
         </button>
    </div>

    <!-- Step 5: Progress -->
    <div x-show="step === 5" class="w-full max-w-4xl mx-auto"
         x-transition:enter="transition ease-out duration-300" 
         x-transition:enter-start="opacity-0 transform scale-95" 
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-white mb-2">Migrating...</h2>
            <p class="text-text-muted">Don't close this tab.</p>
         </div>

         <div class="bg-black rounded-xl border border-white/10 p-4 h-96 font-mono text-sm overflow-y-auto shadow-2xl text-left" id="terminal-scroll">
             <template x-for="log in logs" :key="log.id">
                 <div :class="{
                    'text-red-400 font-bold bg-red-900/10': log.type === 'error',
                    'text-green-400 font-bold': log.type === 'success',
                    'text-white/60': log.type === 'info'
                 }" class="py-0.5 border-b border-white/5 last:border-0">
                     <span class="opacity-30 mr-2" x-text="log.time"></span>
                     <span x-text="log.msg"></span>
                 </div>
             </template>
         </div>
    </div>

</div>

<!-- Logic -->
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('offboardingWizard', () => ({
        step: 1,
        provider: null,
        loading: false,
        creds: {
            endpoint: '',
            accessKeyId: '',
            secretAccessKey: ''
        },
        plan: [],
        logs: [],
        
        get providerName() {
            const map = {
                r2: 'Cloudflare R2',
                aws: 'Amazon S3',
                backblaze: 'Backblaze B2',
                digitalocean: 'DigitalOcean Spaces',
                custom: 'Compatible Storage'
            };
            return map[this.provider] || 'Storage';
        },

        selectProvider(p) {
            this.provider = p;
            this.step = 3;
            this.creds.endpoint = ''; // Reset

            if(p === 'r2') this.creds.endpoint = 'https://<account_id>.r2.cloudflarestorage.com';
            if(p === 'aws') this.creds.endpoint = 'https://s3.us-east-1.amazonaws.com';
            if(p === 'backblaze') this.creds.endpoint = 'https://s3.us-west-000.backblazeb2.com';
            if(p === 'digitalocean') this.creds.endpoint = 'https://nyc3.digitaloceanspaces.com';
        },

        fillDebug() {
            this.creds.endpoint = 'https://03c80993959141f237f8188172909405.r2.cloudflarestorage.com';
            this.creds.accessKeyId = '348f6572f69435b0d014457e5b385966';
            this.creds.secretAccessKey = '01e5df70067643e26b38c22780b621df26be0f089602492f2323a0747448378d';
        },

        async analyze() {
            this.loading = true;
            try {
                const res = await fetch('/dashboard/offboarding/analyze', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.creds)
                });
                const data = await res.json();
                if(!res.ok) throw new Error(data.error);
                
                this.plan = data.plan.map(p => ({ ...p, selected: true }));
                this.step = 4;
            } catch(e) {
                alert(e.message);
            } finally {
                this.loading = false;
            }
        },

        toggleAll(val) {
            this.plan.forEach(p => p.selected = val);
        },

        async startMigration() {
            if(!confirm('This will freeze your account. Continue?')) return;
            
            this.step = 5;
            this.addLog('Initializing migration agent...', 'info');

            const bucketMapping = {};
            this.plan.forEach(p => {
                if(p.selected) bucketMapping[p.localName] = p.targetName;
            });
            
            const payload = { ...this.creds, bucketMapping };

            try {
                const response = await fetch('/dashboard/offboarding/migrate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                
                while (true) {
                    const { value, done } = await reader.read();
                    if (done) break;
                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');
                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const msg = JSON.parse(line.substring(6));
                                this.addLog(msg.text, msg.type);
                            } catch(e){}
                        }
                    }
                }
            } catch (e) {
                this.addLog('Critical error: ' + e.message, 'error');
            }
        },

        addLog(msg, type) {
            this.logs.push({ 
                id: Date.now() + Math.random(), 
                time: new Date().toLocaleTimeString(), 
                msg, 
                type 
            });
            this.$nextTick(() => {
                const el = document.getElementById('terminal-scroll');
                if(el) el.scrollTop = el.scrollHeight;
            });
        }
    }));
});

// Helper for the manual download button outside Alpine if needed
function triggerDownloadConfirm() {
    if(confirm('Download archive and freeze account?')) {
        document.querySelector('form[action$="/download"]').submit();
    }
}
</script>

<!-- Modals & Extra Scripts -->
{{#section "extraScripts"}}
<script src="https://unpkg.com/htmx.org@1.9.10"></script>
<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/csp@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/@phosphor-icons/web"></script>
{{/section}}
