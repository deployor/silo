{{!< main}}

<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-4xl mx-auto">
    
    <!-- Hero Section -->
    <div class="text-center max-w-3xl mx-auto w-full mb-12">
        <div class="mb-8 flex justify-center">
            <i class="ph-duotone ph-graduation-cap text-8xl text-yellow-500"></i>
        </div>
        <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
            It's time to say goodbye
        </h1>
        <p class="text-text-muted text-2xl max-w-2xl mx-auto font-medium leading-relaxed">
            You've turned 18, so you've aged out of Silo. <br/>
            Please download your files before your account is closed.
        </p>
    </div>

    <!-- Status Cards -->
    <div class="w-full max-w-3xl mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Time Remaining Card -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
             <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Time Remaining</div>
             <div class="text-4xl font-bold text-white tracking-tight">{{daysRemaining}} Days</div>
        </div>
        <!-- Deadline Card -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center">
             <div class="text-sm text-text-muted font-bold uppercase tracking-widest mb-2">Deadline</div>
             <div class="text-2xl font-bold text-white tracking-tight">{{gracePeriodEndsAt}}</div>
        </div>
    </div>
    
    <!-- Progress Bar -->
    <div class="w-full max-w-3xl bg-white/5 border border-white/10 rounded-2xl p-6 mb-12">
        <div class="flex justify-between text-sm text-text-muted font-bold uppercase tracking-widest mb-4">
            <span>Grace Period Progress</span>
            <span>{{progressPercentage}}%</span>
        </div>
        <div class="w-full bg-black/30 rounded-full h-4 overflow-hidden">
            <div class="bg-hc-red h-full rounded-full transition-all duration-1000" style="width: {{progressPercentage}}%"></div>
        </div>
    </div>

    <!-- Automated Migration Section -->
    <div class="w-full max-w-5xl mx-auto mb-16">
        <div class="bg-black/20 border border-white/10 rounded-3xl overflow-hidden backdrop-blur-sm">
            <!-- Header -->
            <div class="p-8 border-b border-white/10 bg-white/5 flex flex-col md:flex-row gap-6 items-start justify-between">
                 <div>
                    <div class="flex items-center gap-4 mb-2">
                        <div class="h-10 w-10 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400">
                            <i class="ph-duotone ph-rocket-launch text-xl"></i>
                        </div>
                        <h2 class="text-2xl font-bold text-white">Migration Assistant</h2>
                    </div>
                    <p class="text-text-muted text-lg max-w-2xl">
                         Move your files directly to a new home. We'll handle the transfer so you don't have to download terabytes of data.
                    </p>
                 </div>
                 <div class="flex items-center gap-2 bg-white/5 rounded-lg p-2 text-sm font-mono text-text-muted border border-white/5">
                     <span class="px-2">Your Storage:</span>
                     <span class="text-white font-bold">{{totalStorageFormatted}}</span>
                 </div>
            </div>

            <!-- Content -->
            <div class="p-8">
                
                <!-- Step 0: Choose Provider -->
                <div id="wizard-step-0" class="space-y-6">
                    <h3 class="text-xl font-bold text-white mb-6">Choose your new home</h3>
                    <div class="flex flex-col space-y-3">
                        
                        <!-- Cloudflare R2 -->
                        <button onclick="selectProvider('r2')" class="group relative bg-white/5 hover:bg-[#F38020]/10 border border-white/10 hover:border-[#F38020]/50 rounded-xl p-5 text-left transition-all flex items-center gap-6">
                             <div class="h-14 w-14 shrink-0 rounded-lg bg-white flex items-center justify-center p-2 overflow-hidden">
                                 <img src="https://img.logokit.com/ticker/NET?token=pk_fr59072484feee0961b89b" class="w-full h-full object-contain" alt="Cloudflare" />
                             </div>
                             <div class="flex-1">
                                 <div class="flex items-center gap-2 mb-1">
                                    <h4 class="text-white font-bold text-lg">Cloudflare R2</h4>
                                    <span class="bg-[#F38020]/20 text-[#F38020] text-[10px] font-bold px-2 py-0.5 rounded-full border border-[#F38020]/20 uppercase tracking-wide">Recommended</span>
                                 </div>
                                 <p class="text-text-muted text-sm">Best value. S3-compatible API with zero egress fees.</p>
                             </div>
                             <div class="text-right hidden md:block">
                                 <div class="text-[#F38020] font-bold text-sm">Free Tier</div>
                                 <div class="text-white/40 text-xs">10GB/mo Storage</div>
                             </div>
                             <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
                        </button>

                        <!-- AWS S3 -->
                        <button onclick="selectProvider('aws')" class="group bg-white/5 hover:bg-[#FF9900]/10 border border-white/10 hover:border-[#FF9900]/50 rounded-xl p-5 text-left transition-all flex items-center gap-6">
                             <div class="h-14 w-14 shrink-0 rounded-lg bg-[#232F3E] flex items-center justify-center p-2 overflow-hidden">
                                 <img src="https://img.logokit.com/ticker/AMZN?token=pk_fr59072484feee0961b89b" class="w-full h-full object-contain" alt="AWS" />
                             </div>
                             <div class="flex-1">
                                 <h4 class="text-white font-bold text-lg mb-1">Amazon S3</h4>
                                 <p class="text-text-muted text-sm">The industry standard. Highly reliable, extensive tooling.</p>
                             </div>
                             <div class="text-right hidden md:block">
                                 <div class="text-[#FF9900] font-bold text-sm">Free Tier</div>
                                 <div class="text-white/40 text-xs">5GB/12mo</div>
                             </div>
                             <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
                        </button>

                        <!-- Backblaze B2 -->
                        <button onclick="selectProvider('b2')" class="group bg-white/5 hover:bg-[#FF0000]/10 border border-white/10 hover:border-[#FF0000]/50 rounded-xl p-5 text-left transition-all flex items-center gap-6">
                             <div class="h-14 w-14 shrink-0 rounded-lg bg-white flex items-center justify-center p-2 overflow-hidden">
                                <img src="https://img.logokit.com/backblaze.com?token=pk_fr59072484feee0961b89b" class="w-full h-full object-contain" alt="Backblaze" />
                             </div>
                             <div class="flex-1">
                                 <h4 class="text-white font-bold text-lg mb-1">Backblaze B2</h4>
                                 <p class="text-text-muted text-sm">Extremely affordable storage. 1/5th the price of S3.</p>
                             </div>
                             <div class="text-right hidden md:block">
                                 <div class="text-[#FF0000] font-bold text-sm">Free Tier</div>
                                 <div class="text-white/40 text-xs">10GB Forever</div>
                             </div>
                             <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
                        </button>

                        <!-- DigitalOcean Spaces -->
                        <button onclick="selectProvider('do')" class="group bg-white/5 hover:bg-[#0080FF]/10 border border-white/10 hover:border-[#0080FF]/50 rounded-xl p-5 text-left transition-all flex items-center gap-6">
                             <div class="h-14 w-14 shrink-0 rounded-lg bg-[#0080FF] flex items-center justify-center p-3 overflow-hidden">
                                 <img src="https://img.logokit.com/ticker/DOCN?token=pk_fr59072484feee0961b89b" class="w-full h-full object-contain brightness-0 invert" alt="DigitalOcean" />
                             </div>
                             <div class="flex-1">
                                 <h4 class="text-white font-bold text-lg mb-1">DigitalOcean Spaces</h4>
                                 <p class="text-text-muted text-sm">Simple, predictable pricing. Built-in CDN.</p>
                             </div>
                             <div class="text-right hidden md:block">
                                 <div class="text-[#0080FF] font-bold text-sm">Trial</div>
                                 <div class="text-white/40 text-xs">$200 Credit</div>
                             </div>
                             <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
                        </button>

                        <!-- Custom / Other -->
                        <button onclick="selectProvider('custom')" class="group bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/30 rounded-xl p-5 text-left transition-all flex items-center gap-6">
                             <div class="h-14 w-14 shrink-0 rounded-lg bg-white/10 flex items-center justify-center text-white text-2xl">
                                 <i class="ph-bold ph-globe"></i>
                             </div>
                             <div class="flex-1">
                                 <h4 class="text-white font-bold text-lg mb-1">Other Provider / MinIO</h4>
                                 <p class="text-text-muted text-sm">Connect to any S3-compatible object storage service.</p>
                             </div>
                             <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white group-hover:translate-x-1 transition-all"></i>
                        </button>
                    </div>
                </div>

                <!-- Step 1: Connect -->
                <div id="wizard-step-1" class="hidden space-y-6">
                    <div class="flex items-center gap-3 mb-6 pb-6 border-b border-white/10">
                        <button onclick="setStep(0)" class="h-10 w-10 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center text-white/60 hover:text-white transition-all">
                            <i class="ph-bold ph-arrow-left"></i>
                        </button>
                        <div>
                            <div class="text-xs font-bold text-text-muted uppercase tracking-wider">Step 1 of 3</div>
                            <h2 class="text-2xl font-bold text-white" id="provider-title">Connect Destination</h2>
                        </div>
                     </div>

                     <!-- INSTRUCTIONS: Cloudflare R2 -->
                     <div id="instructions-r2" class="provider-instructions hidden">
                         <div class="bg-[#F38020]/5 border border-[#F38020]/20 rounded-xl p-6 text-sm text-orange-100/80 mb-6">
                             <h5 class="font-bold text-[#F38020] mb-4 text-lg flex items-center gap-2">
                                 <i class="ph-bold ph-key"></i> How to get your R2 Credentials
                             </h5>
                             <ol class="space-y-3 list-decimal list-inside marker:text-[#F38020] marker:font-bold">
                                <li>Log in to the <strong>Cloudflare Dashboard</strong> and select <strong>R2</strong> from the sidebar.</li>
                                <li>Look for <strong>"Manage R2 API Tokens"</strong> on the right sidebar.</li>
                                <li>Click <strong>"Create API token"</strong>.</li>
                                <li><strong class="text-white bg-[#F38020]/20 px-1 rounded">Important:</strong> Under Permissions, select <strong>"Admin Read & Write"</strong>.</li>
                                <li>Create the token and copy the <strong>Access Key ID</strong> and <strong>Secret Access Key</strong>.</li>
                                <li>Your endpoint looks like: <code>https://<ACCOUNT_ID>.r2.cloudflarestorage.com</code></li>
                             </ol>
                         </div>
                     </div>

                     <!-- INSTRUCTIONS: AWS -->
                     <div id="instructions-aws" class="provider-instructions hidden">
                         <div class="bg-[#FF9900]/5 border border-[#FF9900]/20 rounded-xl p-6 text-sm text-yellow-100/80 mb-6">
                             <h5 class="font-bold text-[#FF9900] mb-4 text-lg flex items-center gap-2">
                                 <i class="ph-bold ph-key"></i> How to get AWS Credentials
                             </h5>
                             <ol class="space-y-3 list-decimal list-inside marker:text-[#FF9900] marker:font-bold">
                                <li>Go to the <strong>IAM Console</strong> in AWS.</li>
                                <li>Create a new <strong>User</strong> (e.g., "silo-migration").</li>
                                <li>Attach the policy <strong>"AmazonS3FullAccess"</strong> (or a scoped policy if you prefer).</li>
                                <li>Go to the <strong>Security credentials</strong> tab for that user.</li>
                                <li>Click <strong>"Create access key"</strong>.</li>
                                <li>Copy the Key ID and Secret immediately.</li>
                             </ol>
                         </div>
                     </div>

                     <!-- INSTRUCTIONS: B2 -->
                     <div id="instructions-b2" class="provider-instructions hidden">
                         <div class="bg-[#FF0000]/5 border border-[#FF0000]/20 rounded-xl p-6 text-sm text-red-100/80 mb-6">
                             <h5 class="font-bold text-red-400 mb-4 text-lg flex items-center gap-2">
                                 <i class="ph-bold ph-key"></i> How to get Backblaze Credentials
                             </h5>
                             <ol class="space-y-3 list-decimal list-inside marker:text-red-400 marker:font-bold">
                                <li>Log in to Backblaze and go to <strong>"App Keys"</strong>.</li>
                                <li>Click <strong>"Add a New Application Key"</strong>.</li>
                                <li>Allow access to <strong>All Buckets</strong> (or specific ones you created).</li>
                                <li>Ensure <strong>"Read and Write"</strong> access is selected.</li>
                                <li>Copy the <code>keyID</code> and <code>applicationKey</code>.</li>
                                <li><strong>Endpoint:</strong> Check your bucket settings (e.g., <code>s3.us-west-004.backblazeb2.com</code>).</li>
                             </ol>
                         </div>
                     </div>

                     <!-- INSTRUCTIONS: DO -->
                     <div id="instructions-do" class="provider-instructions hidden">
                         <div class="bg-[#0080FF]/5 border border-[#0080FF]/20 rounded-xl p-6 text-sm text-blue-100/80 mb-6">
                             <h5 class="font-bold text-[#0080FF] mb-4 text-lg flex items-center gap-2">
                                 <i class="ph-bold ph-key"></i> How to get DigitalOcean Credentials
                             </h5>
                             <ol class="space-y-3 list-decimal list-inside marker:text-[#0080FF] marker:font-bold">
                                <li>Go to <strong>API</strong> in the main dashboard menu.</li>
                                <li>Select the <strong>"Spaces keys"</strong> tab.</li>
                                <li>Click <strong>"Generate New Key"</strong>.</li>
                                <li>Name it and copy the Key and Secret.</li>
                                <li><strong>Endpoint:</strong> <code>https://<region>.digitaloceanspaces.com</code> (e.g., nyc3).</li>
                             </ol>
                         </div>
                     </div>

                    <form id="migration-credentials-form" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2 col-span-2">
                                <label class="text-sm font-bold text-text-muted uppercase tracking-wider">S3 Endpoint URL</label>
                                <input type="text" name="endpoint" id="input-endpoint" placeholder="https://<account>.r2.cloudflarestorage.com" required
                                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20 focus:outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/50 transition-all font-mono text-sm">
                                <p class="text-xs text-white/30">The base URL for API requests (without bucket name).</p>
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-text-muted uppercase tracking-wider">Access Key ID</label>
                                <input type="text" name="accessKeyId" id="input-accessKeyId" placeholder="Values are encrypted" required
                                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20 focus:outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/50 transition-all font-mono text-sm">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-text-muted uppercase tracking-wider">Secret Access Key</label>
                                <input type="password" name="secretAccessKey" id="input-secretAccessKey" placeholder="••••••••••••••••" required
                                    class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20 focus:outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/50 transition-all font-mono text-sm">
                            </div>
                        </div>

                        <div class="flex items-center justify-between gap-4">
                             <!-- Debug Button (Hidden via CSS mostly, but visible here for convenience per request) -->
                             <button type="button" onclick="fillDebugCreds()" class="text-xs text-white/10 hover:text-white/50 px-2 py-1">
                                 [Debug Creds]
                             </button>

                             <button type="submit" id="analyze-btn" class="flex-1 bg-white text-black hover:bg-gray-100 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2">
                                <span>Connect & Analyze</span>
                                <i class="ph-bold ph-arrow-right"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Step 2: Plan -->
                <div id="wizard-step-2" class="hidden space-y-6">
                     <div class="flex items-center gap-2 text-text-muted mb-4">
                        <button onclick="setStep(1)" class="hover:text-white transition-colors flex items-center gap-1">
                            <i class="ph-bold ph-arrow-left"></i> Back
                        </button>
                        <span class="text-white/20">|</span>
                        <span class="font-bold text-white">Migration Plan</span>
                     </div>

                     <form id="migration-plan-form">
                        <div class="bg-black/40 rounded-xl border border-white/10 overflow-hidden">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-white/5 text-text-muted font-bold uppercase tracking-wider">
                                    <tr>
                                        <th class="p-4 w-12 text-center">
                                            <input type="checkbox" onchange="toggleAllBuckets(this)" checked class="rounded bg-white/10 border-white/20 text-blue-500 focus:ring-0 cursor-pointer">
                                        </th>
                                        <th class="p-4">Local Bucket</th>
                                        <th class="p-4 w-1/3">Target Bucket Name</th>
                                        <th class="p-4 text-right">Availability</th>
                                    </tr>
                                </thead>
                                <tbody id="plan-table-body" class="divide-y divide-white/10 text-white/80">
                                    <!-- Rows injected via JS -->
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="mt-6 bg-yellow-500/10 border border-yellow-500/20 rounded-xl p-4 flex gap-3 text-sm text-yellow-200/80">
                             <i class="ph-fill ph-warning text-lg shrink-0 mt-0.5"></i>
                             <p>
                                 <strong>Warning:</strong> Starting migration will <span class="underline">freeze your Silo account</span>.
                                 We will attempt to create any "Missing" buckets. Ensure your API token has <code>Write</code> permissions.
                             </p>
                        </div>

                        <button type="submit" id="start-migration-btn" class="w-full mt-6 bg-hc-red text-white hover:bg-red-600 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
                            <span>Start Migration</span>
                            <i class="ph-bold ph-rocket-launch"></i>
                        </button>
                     </form>
                </div>

                <!-- Step 3: Terminal Output -->
                <div id="migration-terminal" class="hidden mt-8 bg-black rounded-xl border border-white/10 p-4 font-mono text-sm h-80 flex flex-col shadow-2xl">
                    <div class="flex items-center justify-between mb-2">
                         <div class="text-blue-400 font-bold">Silo Migration Agent v1.2</div>
                         <div id="migration-status-badge" class="text-xs px-2 py-1 rounded bg-yellow-500/20 text-yellow-400 border border-yellow-500/20 animate-pulse">Running</div>
                    </div>
                    <div class="h-px bg-white/10 w-full mb-4"></div>
                    
                    <div id="terminal-content" class="flex-1 overflow-y-auto scrollbar-thin scrollbar-thumb-white/20 space-y-1 text-white/70 font-mono text-xs md:text-sm">
                        <!-- Logs go here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Fallback / Manual Download -->
    <div class="w-full max-w-2xl mx-auto text-center mb-16 opacity-60 hover:opacity-100 transition-opacity">
        <h3 class="text-text-muted font-bold uppercase tracking-widest mb-6 text-sm">Or do it manually</h3>
        
        {{#if showSuccess}}
            <!-- ... same success message ... -->
        {{else}}
            <form action="/dashboard/offboarding/download" method="POST" id="download-form">
                <button type="button" onclick="triggerDownloadConfirm()" class="group relative w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white text-lg font-bold py-4 rounded-xl transition-all">
                    <span class="flex items-center justify-center gap-3">
                        <i class="ph-bold ph-download-simple"></i>
                        {{#if user.dataExported}}Download Archive Again{{else}}Download ZIP Archive{{/if}}
                    </span>
                </button>
            </form>
        {{/if}}
    </div>

    <!-- Scripts for Migration -->
    <script>
        const STEPS = [
            document.getElementById('wizard-step-0'), // Providers
            document.getElementById('wizard-step-1'), // Credentials
            document.getElementById('wizard-step-2'), // Plan
            document.getElementById('migration-terminal') // Terminal
        ];
        
        const credsForm = document.getElementById('migration-credentials-form');
        const planForm = document.getElementById('migration-plan-form');
        const terminalContent = document.getElementById('terminal-content');
        let selectedProvider = null;
        let storedCredentials = {};

        function setStep(index) {
            STEPS.forEach((el, i) => {
                if (el) el.classList.toggle('hidden', i !== index);
            });
        }

        function selectProvider(provider) {
            selectedProvider = provider;
            
            // UI Updates
            document.querySelectorAll('.provider-instructions').forEach(el => el.classList.add('hidden'));
            const inst = document.getElementById(`instructions-${provider}`);
            if (inst) inst.classList.remove('hidden');
            
            // Dynamic Title based on provider
            const titleMap = {
                'r2': 'Connect Cloudflare R2',
                'aws': 'Connect Amazon S3',
                'b2': 'Connect Backblaze B2',
                'do': 'Connect DigitalOcean Spaces',
                'custom': 'Connect S3 Compatible Storage'
            };
            document.getElementById('provider-title').textContent = titleMap[provider] || 'Connect Destination';
            
            // Auto-fill endpoint hints
            const endpointInput = document.getElementById('input-endpoint');
            if (provider === 'aws') endpointInput.placeholder = 'https://s3.us-east-1.amazonaws.com';
            else if (provider === 'b2') endpointInput.placeholder = 'https://s3.us-west-004.backblazeb2.com';
            else if (provider === 'do') endpointInput.placeholder = 'https://nyc3.digitaloceanspaces.com';
            else endpointInput.placeholder = 'https://<account>.r2.cloudflarestorage.com';

            setStep(1);
        }

        function fillDebugCreds() {
            // For testing only - easily removable
            document.getElementById('input-endpoint').value = 'https://03c80993959141f237f8188172909405.r2.cloudflarestorage.com';
            document.getElementById('input-accessKeyId').value = '348f6572f69435b0d014457e5b385966';
            document.getElementById('input-secretAccessKey').value = '01e5df70067643e26b38c22780b621df26be0f089602492f2323a0747448378d';
        }
        
        function toggleAllBuckets(source) {
            document.querySelectorAll('input[name^="migrate_"]').forEach(cb => {
                cb.checked = source.checked;
            });
        }

        credsForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('analyze-btn');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i class="ph-bold ph-spinner animate-spin"></i> Analyzing...';

            const formData = new FormData(credsForm);
            storedCredentials = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/dashboard/offboarding/analyze', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(storedCredentials)
                });

                const data = await res.json();
                
                if (!res.ok) throw new Error(data.error || 'Connection failed');

                // Populate Table
                const tbody = document.getElementById('plan-table-body');
                tbody.innerHTML = '';
                
                data.plan.forEach(row => {
                    const tr = document.createElement('tr');
                    
                    // Logic to determine status badge
                    let statusHtml = '';
                    if (row.status === 'EXISTS') {
                        statusHtml = `<span class="text-green-400 flex items-center justify-end gap-1"><i class="ph-bold ph-check-circle"></i> Exists</span>`;
                    } else if (row.status === 'MISSING') {
                        statusHtml = `<span class="text-blue-400 flex items-center justify-end gap-1"><i class="ph-bold ph-plus-circle"></i> Will Create</span>`;
                    } else {
                        statusHtml = `<span class="text-red-400 flex items-center justify-end gap-1"><i class="ph-bold ph-x-circle"></i> Taken</span>`;
                    }

                    tr.innerHTML = `
                        <td class="p-4 text-center">
                            <input type="checkbox" name="migrate_${row.localName}" checked class="rounded bg-white/10 border-white/20 text-blue-500 focus:ring-0 cursor-pointer">
                        </td>
                        <td class="p-4 font-mono text-white/50">${row.localName}</td>
                        <td class="p-4">
                            <input type="text" name="map_${row.localName}" value="${row.targetName}"
                                class="bg-black/20 border border-white/10 rounded px-3 py-2 w-full text-sm font-mono focus:border-blue-500 outline-none text-white transition-all placeholder-white/20">
                        </td>
                        <td class="p-4 text-right font-bold text-xs uppercase tracking-wide">
                            ${statusHtml}
                        </td>
                    `;
                    tbody.appendChild(tr);
                });

                setStep(2);

            } catch (err) {
                alert("Connection Error: " + err.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        function log(msg, type = 'info') {
            const line = document.createElement('div');
            const timestamp = new Date().toLocaleTimeString();
            
            if (type === 'error') line.className = 'text-red-400 font-bold bg-red-900/10 p-1 rounded';
            else if (type === 'success') line.className = 'text-green-400 font-bold';
            else line.className = 'text-white/60 hover:text-white/90 transition-colors';
            
            line.innerHTML = `<span class="opacity-30 mr-2">[${timestamp}]</span>${msg}`;
            terminalContent.appendChild(line);
            
            // Auto scroll
            const terminalContainer = document.getElementById('migration-terminal').querySelector('.overflow-y-auto');
            if(terminalContainer) terminalContainer.scrollTop = terminalContainer.scrollHeight;
        }

        planForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!confirm('Are you ready? This will freeze your account and start moving files.')) {
                return;
            }

            // Build bucket mapping (only checked buckets)
            const formData = new FormData(planForm);
            const bucketMapping = {};
            
            // Find all checked buckets first
            const checkedBuckets = new Set();
            for (const [key, value] of formData.entries()) {
                if (key.startsWith('migrate_') && value === 'on') {
                     checkedBuckets.add(key.replace('migrate_', ''));
                }
            }

            // Map targets for checked buckets
            for (const [key, value] of formData.entries()) {
                if (key.startsWith('map_')) {
                    const originalName = key.replace('map_', '');
                    if (checkedBuckets.has(originalName)) {
                        bucketMapping[originalName] = value;
                    }
                }
            }
            
            if (Object.keys(bucketMapping).length === 0) {
                alert("Please select at least one bucket to migrate.");
                return;
            }

            // UI State
            planForm.classList.add('opacity-50', 'pointer-events-none');
            setStep(3);
            
            log('Initializing migration agent...', 'info');
            log(`Plan: Migrating ${Object.keys(bucketMapping).length} buckets.`, 'info');
            
            const payload = {
                ...storedCredentials,
                bucketMapping
            };

            try {
                const response = await fetch('/dashboard/offboarding/migrate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                const badge = document.getElementById('migration-status-badge');

                while (true) {
                    const { value, done } = await reader.read();
                    if (done) break;
                    
                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');
                    
                    for (const line of lines) {
                        if (!line.trim()) continue;
                        if (line.startsWith('data: ')) {
                             try {
                                 const msg = JSON.parse(line.substring(6));
                                 log(msg.text, msg.type);
                                 
                                 if (msg.type === 'error') {
                                    // Don't stop on single file errors, but if critical...
                                    // Usually the backend stream continues.
                                 }
                                 if (msg.text.includes("Migration Complete")) {
                                     badge.textContent = "Done";
                                     badge.className = "text-xs px-2 py-1 rounded bg-green-500/20 text-green-400 border border-green-500/20";
                                 }
                             } catch(e) {}
                        }
                    }
                }
            } catch (err) {
                log('Network error occurred: ' + err.message, 'error');
                planForm.classList.remove('opacity-50', 'pointer-events-none');
            }
        });
    </script>

</div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="fixed inset-0 bg-black/90 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
        <h3 class="text-2xl font-bold mb-4 text-white" id="confirm-title">
            Confirm Action
        </h3>
        <p class="text-text-muted mb-8 leading-relaxed" id="confirm-message">
            Are you sure you want to proceed?
        </p>

        <div class="flex justify-end gap-3">
            <button onclick="closeConfirmModal()" class="text-text-muted hover:text-white px-4 py-3 text-sm font-bold transition-colors">
                Cancel
            </button>
            <button id="confirm-btn" disabled class="bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2">
                <span id="confirm-btn-text">Confirm (3)</span>
                <svg id="confirm-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    let countdownInterval;

    function openConfirmModal(title, message, onConfirm) {
        document.getElementById("confirm-title").textContent = title;
        document.getElementById("confirm-message").textContent = message;
        
        const btn = document.getElementById("confirm-btn");
        const btnText = document.getElementById("confirm-btn-text");
        
        // Reset Button State
        btn.className = "bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2";
        btn.disabled = true;
        btnText.textContent = "Confirm (3)";

        // Remove old listener to avoid stacking
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        
        // Countdown Logic
        let seconds = 3;
        if (countdownInterval) clearInterval(countdownInterval);
        
        countdownInterval = setInterval(() => {
            seconds--;
            if (seconds <= 0) {
                clearInterval(countdownInterval);
                newBtn.disabled = false;
                newBtn.className = "bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow flex items-center gap-2";
                newBtn.querySelector("#confirm-btn-text").textContent = "Confirm";
            } else {
                newBtn.querySelector("#confirm-btn-text").textContent = `Confirm (${seconds})`;
            }
        }, 1000);

        newBtn.onclick = async () => {
            const spinner = document.getElementById("confirm-spinner");
            const btnText = newBtn.querySelector("#confirm-btn-text");
            
            newBtn.disabled = true;
            spinner.classList.remove("hidden");
            btnText.textContent = "Processing...";
            
            try {
                await onConfirm();
                closeConfirmModal();
            } catch (e) {
                console.error(e);
                alert("Action failed");
            } finally {
                newBtn.disabled = false;
                spinner.classList.add("hidden");
                btnText.textContent = "Confirm";
            }
        };
        
        document.getElementById("confirm-modal").classList.remove("hidden");
        document.getElementById("confirm-modal").classList.add("flex");
    }

    function closeConfirmModal() {
        if (countdownInterval) clearInterval(countdownInterval);
        document.getElementById("confirm-modal").classList.add("hidden");
        document.getElementById("confirm-modal").classList.remove("flex");
    }

    function triggerDownloadConfirm() {
        const title = "Final Check";
        const message = "This will freeze your account immediately to ensure your backup is complete. You won't be able to upload files afterwards. \n\nYou can always re-download this archive until your grace period ends.";
        
        openConfirmModal(title, message, async () => {
            const form = document.getElementById('download-form');
            const btn = document.getElementById('download-btn');
            const content = document.getElementById('btn-content');
            const spinner = document.getElementById('btn-spinner');
            
            // Visual feedback on button
            content.classList.add('opacity-0');
            spinner.classList.remove('hidden');
            btn.disabled = true;
            btn.classList.add('cursor-not-allowed', 'bg-gray-200');

            // Submit the form
            form.submit();

            // Re-enable button logic (fallback)
            setTimeout(() => {
                 content.classList.remove('opacity-0');
                 spinner.classList.add('hidden');
                 btn.disabled = false;
                 btn.classList.remove('cursor-not-allowed', 'bg-gray-200');
            }, 8000);
        });
    }
</script>

