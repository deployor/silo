{{!< main}}

<div class="min-h-[80vh] flex flex-col items-center justify-center py-16 px-4">
    <div class="max-w-xl w-full">
        
        <!-- Header -->
        <div class="mb-12">
            <h1 class="text-6xl font-black text-white mb-6 uppercase tracking-tighter" style="font-family: 'Phantom Sans', system-ui, -apple-system, sans-serif;">
                <span class="text-hc-red">System</span> Update
            </h1>
            <p class="text-xl text-text-muted leading-relaxed max-w-lg mx-auto font-medium">
                You've turned 18, so you've aged out of Silo. <br/>
                Please download your files before your account is closed.
            </p>
        </div>

        <!-- Status Bar -->
        <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 mb-12 card-shadow relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-32 bg-hc-red/5 rounded-full blur-3xl -mr-16 -mt-16 pointer-events-none"></div>
            
            <div class="flex items-end justify-between font-mono relative z-10 mb-6">
                <div>
                    <div class="text-xs text-hc-red font-bold uppercase tracking-widest mb-2">Time Remaining</div>
                    <div class="text-4xl font-bold text-white tracking-tighter">{{daysRemaining}} Days</div>
                </div>
                <div class="text-right">
                    <div class="text-xs text-text-muted uppercase font-bold tracking-widest mb-2">Deadline</div>
                    <div class="text-xl text-white font-bold">{{gracePeriodEndsAt}}</div>
                </div>
            </div>
            <!-- Progress Bar -->
            <div class="w-full bg-black/50 rounded-full h-4 overflow-hidden border border-white/5">
                <div class="bg-hc-red h-full rounded-full transition-all duration-1000 ease-out relative" style="width: {{progressPercentage}}%">
                    <div class="absolute inset-0 bg-white/20 animate-[pulse_2s_infinite]"></div>
                </div>
            </div>
        </div>

        {{#if showSuccess}}
            <div class="bg-emerald-500 text-black rounded-3xl p-8 mb-8 text-center animate-fade-in card-shadow border border-emerald-400">
                <h2 class="text-2xl font-black uppercase tracking-wider mb-2">Export Started</h2>
                <p class="mb-6 font-medium">Your download should begin automatically.</p>
                <a href="/dashboard/offboarding/archive" class="underline hover:no-underline font-mono text-sm font-bold uppercase tracking-wider">
                    Click here if it doesn't start
                </a>
                
                <script>
                    setTimeout(() => {
                        window.location.href = "/dashboard/offboarding/archive";
                    }, 1000);
                </script>
            </div>
        {{else}}
            {{#if user.dataExported}}
                <div class="bg-hc-dark rounded-3xl p-8 mb-8 border border-white/10 card-shadow flex flex-col md:flex-row gap-6 items-center text-center md:text-left">
                    <div class="shrink-0 p-4 bg-blue-500/10 text-blue-400 rounded-2xl">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-white font-black uppercase tracking-wider text-xl mb-2">Account Frozen</h3>
                        <p class="text-text-muted text-sm leading-relaxed">
                            You've already started an export, so your account is locked to prevent changes. You can re-download your archive below.
                        </p>
                    </div>
                </div>
            {{else}}
                <div class="bg-hc-dark rounded-3xl p-8 mb-8 border border-white/10 card-shadow flex flex-col md:flex-row gap-6 items-center text-center md:text-left">
                    <div class="shrink-0 p-4 bg-yellow-500/10 text-yellow-400 rounded-2xl">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-white font-black uppercase tracking-wider text-xl mb-2">Heads up</h3>
                        <p class="text-text-muted text-sm leading-relaxed">
                            Downloading your data will <span class="text-white font-bold">immediately freeze your account</span>. You won't be able to upload new files or create buckets afterwards.
                        </p>
                    </div>
                </div>
            {{/if}}

            <form action="/dashboard/offboarding/download" method="POST" id="download-form">
                <button type="button" onclick="triggerDownloadConfirm()" id="download-btn" class="group relative w-full bg-hc-red hover:bg-red-600 text-white text-xl font-black uppercase tracking-wider py-6 rounded-2xl transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg hover:shadow-red-900/50 border-2 border-red-500 hover:border-red-400">
                    <span id="btn-content" class="flex items-center justify-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        {{#if user.dataExported}}Download Archive Again{{else}}Download Everything (.zip){{/if}}
                    </span>
                    <div id="btn-spinner" class="hidden absolute inset-0 flex items-center justify-center">
                        <svg class="animate-spin h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                </button>
            </form>
            <p class="text-center text-xs text-text-muted mt-4 font-mono opacity-60">
                This wraps up all your buckets into one file.
            </p>
        {{/if}}

        <!-- Migration Guide -->
        <div class="mt-24 pt-12 border-t border-white/10">
            <h2 class="text-2xl font-bold text-white mb-8">Where to go next</h2>
            
            <div class="space-y-8">
                <div class="flex gap-6">
                    <div class="shrink-0 w-8 h-8 rounded-full bg-white text-black flex items-center justify-center font-bold text-sm">1</div>
                    <div>
                        <h3 class="text-white font-bold text-lg">Set up Cloudflare R2</h3>
                        <p class="text-text-muted mt-2 leading-relaxed">
                            It's the best alternative to Silo (S3-compatible) and has a massive free tier. Create an account, enable R2, and generate "S3 API Tokens".
                        </p>
                    </div>
                </div>

                <div class="flex gap-6">
                    <div class="shrink-0 w-8 h-8 rounded-full bg-white text-black flex items-center justify-center font-bold text-sm">2</div>
                    <div>
                        <h3 class="text-white font-bold text-lg">Move your files</h3>
                        <p class="text-text-muted mt-2 leading-relaxed mb-4">
                            Unzip your archive, then use the AWS CLI to sync it to R2:
                        </p>
                        <div class="bg-black rounded-lg p-4 border border-white/10 font-mono text-xs text-emerald-400 overflow-x-auto">
                            aws s3 sync ./silo-export s3://new-bucket-name --endpoint-url https://<account_id>.r2.cloudflarestorage.com
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="fixed inset-0 bg-black/90 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
    <div class="bg-hc-dark rounded-3xl border border-white/10 p-8 w-full max-w-md card-shadow transform transition-all">
        <h3 class="text-2xl font-bold mb-4 text-white" id="confirm-title">
            Confirm Action
        </h3>
        <p class="text-text-muted mb-8 leading-relaxed" id="confirm-message">
            Are you sure you want to proceed?
        </p>

        <div class="flex justify-end gap-3">
            <button onclick="closeConfirmModal()" class="text-text-muted hover:text-white px-4 py-3 text-sm font-bold transition-colors">
                Cancel
            </button>
            <button id="confirm-btn" disabled class="bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2">
                <span id="confirm-btn-text">Confirm (3)</span>
                <svg id="confirm-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    let countdownInterval;

    function openConfirmModal(title, message, onConfirm) {
        document.getElementById("confirm-title").textContent = title;
        document.getElementById("confirm-message").textContent = message;
        
        const btn = document.getElementById("confirm-btn");
        const btnText = document.getElementById("confirm-btn-text");
        
        // Reset Button State
        btn.className = "bg-white/5 text-white/40 cursor-not-allowed px-6 py-3 rounded-xl text-sm font-bold transition-all border border-white/5 flex items-center gap-2";
        btn.disabled = true;
        btnText.textContent = "Confirm (3)";

        // Remove old listener to avoid stacking
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        
        // Countdown Logic
        let seconds = 3;
        if (countdownInterval) clearInterval(countdownInterval);
        
        countdownInterval = setInterval(() => {
            seconds--;
            if (seconds <= 0) {
                clearInterval(countdownInterval);
                newBtn.disabled = false;
                newBtn.className = "bg-hc-red hover:bg-red-600 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all hover:scale-105 card-shadow flex items-center gap-2";
                newBtn.querySelector("#confirm-btn-text").textContent = "Confirm";
            } else {
                newBtn.querySelector("#confirm-btn-text").textContent = `Confirm (${seconds})`;
            }
        }, 1000);

        newBtn.onclick = async () => {
            const spinner = document.getElementById("confirm-spinner");
            const btnText = newBtn.querySelector("#confirm-btn-text");
            
            newBtn.disabled = true;
            spinner.classList.remove("hidden");
            btnText.textContent = "Processing...";
            
            try {
                await onConfirm();
                closeConfirmModal();
            } catch (e) {
                console.error(e);
                alert("Action failed");
            } finally {
                newBtn.disabled = false;
                spinner.classList.add("hidden");
                btnText.textContent = "Confirm";
            }
        };
        
        document.getElementById("confirm-modal").classList.remove("hidden");
        document.getElementById("confirm-modal").classList.add("flex");
    }

    function closeConfirmModal() {
        if (countdownInterval) clearInterval(countdownInterval);
        document.getElementById("confirm-modal").classList.add("hidden");
        document.getElementById("confirm-modal").classList.remove("flex");
    }

    function triggerDownloadConfirm() {
        const title = "Final Check";
        const message = "This will freeze your account immediately to ensure your backup is complete. You won't be able to upload files afterwards. \n\nYou can always re-download this archive until your grace period ends.";
        
        openConfirmModal(title, message, async () => {
            const form = document.getElementById('download-form');
            const btn = document.getElementById('download-btn');
            const content = document.getElementById('btn-content');
            const spinner = document.getElementById('btn-spinner');
            
            // Visual feedback on button
            content.classList.add('opacity-0');
            spinner.classList.remove('hidden');
            btn.disabled = true;
            btn.classList.add('cursor-not-allowed', 'bg-gray-200');

            // Submit the form
            form.submit();

            // Re-enable button logic (fallback)
            setTimeout(() => {
                 content.classList.remove('opacity-0');
                 spinner.classList.add('hidden');
                 btn.disabled = false;
                 btn.classList.remove('cursor-not-allowed', 'bg-gray-200');
            }, 8000);
        });
    }
</script>
