{{!< main}}

<div class="flex-1 flex flex-col items-center justify-center p-6 w-full max-w-5xl mx-auto" 
     x-data="offboardingWizard()" 
     x-cloak>
    
    <!-- Step 1: Overview -->
    <div x-show="step === 1"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100"
         class="w-full max-w-4xl mx-auto text-center">
         
         <div class="mb-8 flex justify-center">
            <i class="ph-duotone ph-hand-waving text-8xl text-hc-red transform scale-x-[-1]"></i>
         </div>

         {{#if user.dataExported}}
             <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
                It was amazing having you.
             </h1>
             <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
                Your data has been successfully migrated. Your account is now frozen.
                <br>
                <span class="text-white/60 text-lg block mt-4">You can still download your data or run the migration assistant again below.</span>
             </p>
         {{else}}
             <h1 class="text-6xl md:text-8xl font-black text-white mb-8 tracking-tighter italic">
                It's time to say goodbye.
             </h1>
             <p class="text-text-muted text-2xl max-w-3xl mx-auto font-medium mb-12 leading-relaxed">
                You've turned 18, so you've aged out of Silo.
                <br>
                You have <span class="text-white font-bold">{{daysRemaining}} days</span> to export your <span class="text-white font-bold">{{totalStorageFormatted}}</span> of data.
             </p>

             <div class="bg-white/5 rounded-xl p-4 mb-12 max-w-2xl mx-auto border border-white/10 flex items-start gap-4 text-left">
                <i class="ph-fill ph-warning text-yellow-500 text-xl mt-1"></i>
                <p class="text-text-muted/70 text-sm font-medium leading-relaxed">
                    Your grace period ends on <span class="text-white">{{gracePeriodEndsAt}}</span>. After this date, your data will be permanently deleted to free up space for new Hack Clubbers.
                </p>
            </div>
         {{/if}}

         <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
             <!-- Download Option -->
              <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow flex flex-col items-center text-center hover:border-white/30 transition-colors group">
                 <div class="h-20 w-20 bg-white/10 rounded-full flex items-center justify-center mb-6 text-4xl text-white group-hover:scale-110 transition-transform">
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor" class="w-10 h-10"><path d="M64 464c-8.8 0-16-7.2-16-16L48 64c0-8.8 7.2-16 16-16l48 0c0 8.8 7.2 16 16 16l32 0c8.8 0 16-7.2 16-16l48 0 0 80c0 17.7 14.3 32 32 32l80 0 0 288c0 8.8-7.2 16-16 16L64 464zM64 0C28.7 0 0 28.7 0 64L0 448c0 35.3 28.7 64 64 64l256 0c35.3 0 64-28.7 64-64l0-293.5c0-17-6.7-33.3-18.7-45.3L274.7 18.7C262.7 6.7 246.5 0 229.5 0L64 0zm48 112c0 8.8 7.2 16 16 16l32 0c8.8 0 16-7.2 16-16s-7.2-16-16-16l-32 0c-8.8 0-16 7.2-16 16zm0 64c0 8.8 7.2 16 16 16l32 0c8.8 0 16-7.2 16-16s-7.2-16-16-16l-32 0c-8.8 0-16 7.2-16 16zm-6.3 71.8L82.1 335.9c-1.4 5.4-2.1 10.9-2.1 16.4c0 35.2 28.8 63.7 64 63.7s64-28.5 64-63.7c0-5.5-.7-11.1-2.1-16.4l-23.5-88.2c-3.7-14-16.4-23.8-30.9-23.8l-14.8 0c-14.5 0-27.2 9.7-30.9 23.8zM128 336l32 0c8.8 0 16 7.2 16 16s-7.2 16-16 16l-32 0c-8.8 0-16-7.2-16-16s7.2-16 16-16z"></path></svg>
                 </div>
                 <h3 class="text-2xl font-bold text-white mb-2">Download ZIP</h3>
                 <p class="text-text-muted mb-8 flex-1 text-lg">
                     {{#if user.dataExported}}
                        You can still download an archive of your data.
                     {{else}}
                        Get a one single archive containing all your buckets files and metadata.
                     {{/if}}
                 </p>
                 
                 {{#if showSuccess}}
                 <div class="bg-green-500/20 text-green-400 p-4 rounded-xl font-bold w-full">
                     <i class="ph-bold ph-check-circle mr-2"></i> Archive Created
                 </div>
                 {{else}}
                 <form action="/dashboard/offboarding/download" method="POST" class="w-full">
                     <button type="button" onclick="triggerDownloadConfirm()" class="group w-full bg-white/10 hover:bg-white/20 text-white font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2">
                         Download Archive <i class="ph-bold ph-download-simple group-hover:translate-y-1 transition-transform"></i>
                     </button>
                 </form>
                 {{/if}}
              </div>

              <!-- Migration Option -->
              <div class="bg-hc-dark border border-white/10 rounded-3xl p-8 card-shadow flex flex-col items-center text-center hover:border-white/30 transition-colors group relative overflow-hidden">
                 {{#unless user.dataExported}}
                 <div class="absolute top-0 right-0 bg-hc-red text-white text-xs font-bold px-3 py-1 rounded-bl-xl">RECOMMENDED</div>
                 {{/unless}}
                 <div class="h-20 w-20 bg-blue-500/10 rounded-full flex items-center justify-center mb-6 text-4xl text-blue-400 group-hover:scale-110 transition-transform">
                     <i class="ph-duotone ph-rocket-launch"></i>
                 </div>
                 <h3 class="text-2xl font-bold text-white mb-2">Migration Assistant</h3>
                 <p class="text-text-muted mb-8 flex-1 text-lg">
                     Directly transfer your files to Cloudflare R2, AWS, or any S3 provider{{#if user.dataExported}} again{{else}} without downloading{{/if}}.
                 </p>
                 <button @click="step = 2" class="group w-full bg-hc-red text-white hover:bg-red-600 font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
                     Start Migration <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
                 </button>
              </div>
         </div>
    </div>

    <!-- Step 2: Choose Provider -->
    <div x-show="step === 2" class="w-full max-w-5xl mx-auto text-center"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="mb-8">
             <div class="mb-8 flex justify-center">
                 <i class="ph-duotone ph-truck text-8xl text-blue-500"></i>
             </div>
            <h2 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">Choose your new home</h2>
            <p class="text-text-muted text-2xl font-medium">Where should we move your files?</p>
         </div>

         <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left mb-12">
             <!-- R2 -->
             <button @click="selectProvider('r2')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#F38020]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/cloudflare.png" class="w-full h-full object-contain" alt="Cloudflare" />
                  </div>
                  <div class="flex-1">
                      <div class="flex items-center gap-3 mb-1">
                         <h4 class="text-white font-bold text-xl">Cloudflare R2</h4>
                         <span class="bg-[#F38020]/20 text-[#F38020] text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wide">Recommended</span>
                      </div>
                      <p class="text-text-muted text-sm">Zero egress fees. S3-compatible.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
             
              <!-- AWS -->
              <button @click="selectProvider('aws')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#FF9900]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-[#232F3E] flex items-center justify-center p-3">
                      <img src="/assets/images/aws.png" class="w-full h-full object-contain" alt="AWS" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">Amazon S3</h4>
                      <p class="text-text-muted text-sm">The industry standard.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
 
             <!-- Backblaze -->
              <button @click="selectProvider('backblaze')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#FF0000]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/backblaze.png" class="w-full h-full object-contain" alt="Backblaze" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">Backblaze B2</h4>
                      <p class="text-text-muted text-sm">Affordable object storage.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
 
             <!-- DigitalOcean -->
              <button @click="selectProvider('digitalocean')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-[#0080FF]/50 rounded-2xl p-6 transition-all flex items-center gap-6">
                  <div class="h-16 w-16 shrink-0 rounded-xl bg-white flex items-center justify-center p-3">
                      <img src="/assets/images/digitalocean.png" class="w-full h-full object-contain" alt="DigitalOcean" />
                  </div>
                  <div class="flex-1">
                      <h4 class="text-white font-bold text-xl mb-1">DigitalOcean</h4>
                      <p class="text-text-muted text-sm">Simple Spaces object storage.</p>
                  </div>
                  <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
             </button>
            
             <button @click="selectProvider('custom')" class="group bg-hc-dark hover:bg-white/5 border border-white/10 hover:border-white/50 rounded-2xl p-6 transition-all flex items-center gap-6 col-span-1 md:col-span-2">
                 <div class="h-16 w-16 shrink-0 rounded-xl bg-white/10 flex items-center justify-center p-3 text-3xl text-white">
                     <i class="ph-bold ph-globe"></i>
                 </div>
                 <div class="flex-1">
                     <h4 class="text-white font-bold text-xl mb-1">Other / S3 Compatible</h4>
                     <p class="text-text-muted text-sm">MinIO, Wasabi, etc.</p>
                 </div>
                 <i class="ph-bold ph-caret-right text-white/20 group-hover:text-white text-2xl"></i>
            </button>
         </div>

         <div class="flex items-center justify-center">
            <button type="button" @click="step = 1" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
                <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                <span>Back</span>
            </button>
         </div>
    </div>

    <!-- Step 3: Connect (Credentials) -->
    <div x-show="step === 3" class="w-full mx-auto"
         :class="(!r2GuideSeen && provider === 'r2') ? 'max-w-5xl' : 'max-w-2xl'"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <!-- R2 Guide -->
         <div x-show="!r2GuideSeen && provider === 'r2'" class="text-center">
             <div class="mb-8">
                 <div class="mb-8 flex justify-center">
                     <i class="ph-duotone ph-graduation-cap text-8xl text-orange-500"></i>
                 </div>
                <h2 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">Setting up Cloudflare R2</h2>
                <p class="text-text-muted text-2xl font-medium">Follow these steps to generate your credentials.</p>
             </div>

             <div class="grid grid-cols-1 gap-12 text-left mb-12">
                 <!-- Step 1 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">1</span>
                         Head to the R2 Section
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step1HeadtoR2Section.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>

                 <!-- Step 2 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">2</span>
                         Subscribe / Enable R2
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step2SubtoR2.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>

                 <!-- Step 3 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">3</span>
                         Click "Manage R2 API Tokens"
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step3GoToManageKeys.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>

                 <!-- Step 4 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">4</span>
                         Create New Token
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step4CreateNewAccountToken.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>

                 <!-- Step 5 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">5</span>
                         Permissions: Admin Read & Write
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step5MakeToken.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>

                 <!-- Step 6 -->
                 <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden flex flex-col shadow-2xl">
                     <div class="p-4 border-b border-white/5 font-bold text-white flex items-center gap-3">
                         <span class="bg-[#F38020] text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">6</span>
                         Copy Access Keys
                     </div>
                     <div class="bg-black/50 p-4 flex-1 flex items-center justify-center">
                         <img src="/assets/images/r2-guide/Step6CopyCredentials.png" class="rounded-lg shadow-2xl border border-white/10 w-full">
                     </div>
                 </div>
             </div>

             <button @click="r2GuideSeen = true" class="bg-[#F38020] text-white hover:bg-[#d66e16] font-bold text-xl py-4 px-12 rounded-xl transition-all shadow-lg shadow-orange-900/20 mb-8">
                 I have my credentials <i class="ph-bold ph-arrow-right ml-2"></i>
             </button>

             <div class="flex items-center justify-center">
                <button type="button" @click="step = 2" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
                    <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                    <span>Back to Providers</span>
                </button>
             </div>
         </div>

         <!-- Credentials Form -->
         <div x-show="r2GuideSeen || provider !== 'r2'" x-transition:enter="transition ease-out duration-300">
            <div class="text-center mb-8">
                <div class="mb-8 flex justify-center">
                    <i class="ph-duotone ph-key text-8xl text-yellow-500"></i>
                </div>
               <h2 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">Connect <span x-text="providerName"></span></h2>
               <p class="text-text-muted text-2xl font-medium">Enter your credentials to allow Silo to transfer files.</p>
            </div>

            <form @submit.prevent="analyze" class="space-y-6 text-left">
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Endpoint URL</label>
                <!-- For R2, we use a placeholder instead of pre-filling to avoid confusion -->
                <input type="text"
                       x-model="endpoint"
                       required
                       :placeholder="provider === 'r2' ? 'https://<account_id>.r2.cloudflarestorage.com' : 'https://...'"
                       class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Access Key ID</label>
                <input type="text" x-model="accessKeyId" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>
            <div>
                <label class="block text-sm font-bold text-text-muted uppercase tracking-wider mb-2">Secret Access Key</label>
                <input type="password" x-model="secretAccessKey" required class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white font-mono focus:border-hc-red focus:outline-none transition-colors">
            </div>

            <!-- Debug Button -->
            <button type="button" @click="fillDebug" class="text-xs text-white/20 hover:text-white/50">[Debug]</button>

            <button type="submit" :disabled="loading" class="group w-full bg-hc-red text-white hover:bg-red-600 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20 disabled:opacity-50 disabled:cursor-wait">
                <span x-show="!loading" class="flex items-center gap-2">Connect & Analyze <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i></span>
                <span x-show="loading"><i class="ph-bold ph-spinner animate-spin"></i> Connecting...</span>
            </button>
         </form>

         <div class="flex items-center justify-center mt-8">
            <button type="button" @click="provider === 'r2' ? r2GuideSeen = false : step = 2" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
                <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                <span>Back</span>
            </button>
         </div>
         </div>
    </div>

    <!-- Step 4: Plan -->
    <div x-show="step === 4" class="w-full max-w-4xl mx-auto"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="text-center mb-8">
             <div class="mb-8 flex justify-center">
                 <i class="ph-duotone ph-clipboard-text text-8xl text-green-500"></i>
             </div>
            <h2 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">Migration Plan</h2>
            <p class="text-text-muted text-2xl font-medium">Review where your buckets will go.</p>
         </div>

         <div class="bg-hc-dark border border-white/10 rounded-2xl overflow-hidden mb-8">
             <table class="w-full text-left">
                 <thead class="bg-white/5 text-text-muted font-bold uppercase text-xs tracking-wider">
                     <tr>
                         <th class="p-4 w-12 text-center">
                             <input type="checkbox" @change="toggleAll($el.checked)" checked class="rounded bg-white/10 border-white/20 text-hc-red focus:ring-0">
                         </th>
                         <th class="p-4">Local Bucket</th>
                         <th class="p-4">Target Bucket</th>
                         <th class="p-4 text-right">Status</th>
                     </tr>
                 </thead>
                 <tbody class="divide-y divide-white/5 text-white">
                     <template x-for="bucket in plan" :key="bucket.localName">
                         <tr>
                             <td class="p-4 text-center">
                                 <input type="checkbox" x-model="bucket.selected" class="rounded bg-white/10 border-white/20 text-hc-red focus:ring-0">
                             </td>
                             <td class="p-4 font-mono text-white/70" x-text="bucket.localName"></td>
                             <td class="p-4">
                                 <input type="text" x-model="bucket.targetName" class="bg-black/20 border border-white/10 rounded px-3 py-2 w-full font-mono text-sm focus:border-hc-red outline-none">
                             </td>
                             <td class="p-4 text-right">
                                 <span x-show="bucket.status === 'AVAILABLE'" class="text-blue-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-plus-circle"></i> Create</span>
                                 <span x-show="bucket.status === 'EXISTS'" class="text-green-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-check-circle"></i> Exists</span>
                                 <span x-show="bucket.status === 'TAKEN'" class="text-red-400 text-xs font-bold uppercase flex items-center justify-end gap-1"><i class="ph-bold ph-x-circle"></i> Taken</span>
                             </td>
                         </tr>
                     </template>
                 </tbody>
             </table>
         </div>

         <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-xl p-4 flex gap-3 text-sm text-yellow-200/80 mb-8 text-left">
                <i class="ph-fill ph-warning text-lg shrink-0 mt-0.5"></i>
                <p>
                    <strong>Warning:</strong> Starting migration will <span class="underline">freeze your Silo account</span>.
                    We will attempt to create any "Create" buckets. Ensure your API token has Write permissions.
                </p>
         </div>

         <button @click="startMigration" class="group w-full bg-hc-red text-white hover:bg-red-600 font-bold text-lg py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-900/20">
            Start Migration <i class="ph-bold ph-rocket-launch group-hover:translate-x-1 transition-transform"></i>
         </button>

         <div class="flex items-center justify-center mt-8">
            <button type="button" @click="step = 3" class="text-text-muted hover:text-white px-6 py-3 font-bold text-lg transition-colors flex items-center gap-2 group">
                <i class="ph-bold ph-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                <span>Back</span>
            </button>
         </div>
    </div>

    <!-- Step 5: Progress -->
    <div x-show="step === 5" class="w-full max-w-4xl mx-auto"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform scale-95"
         x-transition:enter-end="opacity-100 transform scale-100">
         
         <div class="text-center mb-8">
             <div class="mb-8 flex justify-center">
                 <i class="ph-duotone ph-rocket text-8xl text-hc-red"></i>
             </div>
            <h2 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">Migrating...</h2>
            <p class="text-text-muted text-2xl font-medium">Don't close this tab.</p>
         </div>

         <div class="flex justify-end mb-2">
            <button @click="copyLogs" class="text-xs text-text-muted hover:text-white flex items-center gap-1 transition-colors">
                <i class="ph-bold ph-copy"></i> Copy Logs
            </button>
         </div>
         <div class="bg-black rounded-xl border border-white/10 p-4 h-96 font-mono text-sm overflow-y-auto shadow-2xl text-left" id="terminal-scroll">
             <template x-for="log in logs" :key="log.id">
                 <div :class="{
                    'text-red-400 font-bold bg-red-900/10': log.type === 'error',
                    'text-green-400 font-bold': log.type === 'success',
                    'text-white/60': log.type === 'info'
                 }" class="py-0.5 border-b border-white/5 last:border-0">
                     <span class="opacity-30 mr-2" x-text="log.time"></span>
                     <span x-text="log.msg"></span>
                 </div>
             </template>
         </div>
    </div>

</div>

<!-- Logic -->
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('offboardingWizard', () => ({
        step: 1,
        provider: null,
        r2GuideSeen: false,
        loading: false,
        // Flattened credentials to avoid x-model binding issues with nested objects
        endpoint: '',
        accessKeyId: '',
        secretAccessKey: '',
        
        plan: [],
        logs: [],
        
        get providerName() {
            const map = {
                r2: 'Cloudflare R2',
                aws: 'Amazon S3',
                backblaze: 'Backblaze B2',
                digitalocean: 'DigitalOcean Spaces',
                custom: 'Compatible Storage'
            };
            return map[this.provider] || 'Storage';
        },

        selectProvider(p) {
            this.provider = p;
            this.step = 3;
            this.r2GuideSeen = p !== 'r2'; // Show guide only for R2
            
            // Reset fields
            this.endpoint = '';
            this.accessKeyId = '';
            this.secretAccessKey = '';

            // Pre-fill only for fixed endpoints, NOT for R2 (user must paste)
            if(p === 'aws') this.endpoint = 'https://s3.us-east-1.amazonaws.com';
            if(p === 'backblaze') this.endpoint = 'https://s3.us-west-000.backblazeb2.com';
            if(p === 'digitalocean') this.endpoint = 'https://nyc3.digitaloceanspaces.com';
        },

        fillDebug() {
            this.endpoint = 'https://03c80993959141f237f8188172909405.r2.cloudflarestorage.com';
            this.accessKeyId = '348f6572f69435b0d014457e5b385966';
            this.secretAccessKey = '01e5df70067643e26b38c22780b621df26be0f089602492f2323a0747448378d';
        },

        async analyze() {
            this.loading = true;
            try {
                const payload = {
                    endpoint: this.endpoint,
                    accessKeyId: this.accessKeyId,
                    secretAccessKey: this.secretAccessKey
                };

                const res = await fetch('/dashboard/offboarding/analyze', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if(!res.ok) throw new Error(data.error);
                
                this.plan = data.plan.map(p => ({ ...p, selected: true }));
                this.step = 4;
            } catch(e) {
                alert(e.message);
            } finally {
                this.loading = false;
            }
        },

        toggleAll(val) {
            this.plan.forEach(p => p.selected = val);
        },

        async startMigration() {
            if(!confirm('This will freeze your account. Continue?')) return;
            
            this.step = 5;
            this.addLog('Initializing migration agent...', 'info');

            const bucketMapping = {};
            this.plan.forEach(p => {
                if(p.selected) bucketMapping[p.localName] = p.targetName;
            });
            
            const payload = {
                endpoint: this.endpoint,
                accessKeyId: this.accessKeyId,
                secretAccessKey: this.secretAccessKey,
                bucketMapping
            };

            try {
                const response = await fetch('/dashboard/offboarding/migrate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                
                while (true) {
                    const { value, done } = await reader.read();
                    if (done) break;
                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');
                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            try {
                                const msg = JSON.parse(line.substring(6));
                                this.addLog(msg.text, msg.type);
                            } catch(e){}
                        }
                    }
                }
            } catch (e) {
                this.addLog('Critical error: ' + e.message, 'error');
            }
        },

        addLog(msg, type) {
            this.logs.push({
                id: Date.now() + Math.random(),
                time: new Date().toLocaleTimeString(),
                msg,
                type
            });
            this.$nextTick(() => {
                const el = document.getElementById('terminal-scroll');
                if(el) el.scrollTop = el.scrollHeight;
            });
        },

        copyLogs() {
            const text = this.logs.map(l => `[${l.time}] ${l.type.toUpperCase()}: ${l.msg}`).join('\n');
            navigator.clipboard.writeText(text).then(() => alert('Logs copied to clipboard'));
        }
    }));
});

// Helper for the manual download button outside Alpine if needed
function triggerDownloadConfirm() {
    if(confirm('Download archive and freeze account?')) {
        document.querySelector('form[action$="/download"]').submit();
    }
}
</script>

