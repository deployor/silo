{
	"name": "silo-s3-gateway",
	"version": "1.0.0",
	"license": "MIT",
	"private": true,
	"scripts": {
		"dev": "concurrently \"bun run --hot src/index.ts\" \"vite build --watch --mode development\"",
		"build:frontend": "vite build",
		"build": "bun run build:frontend",
		"start": "bun run src/index.ts",
		"prod:compose": "bun run tools/prod-compose.ts",
		"prod:up": "bun run tools/prod-compose.ts up -d --build",
		"dataplane:build": "cargo build --manifest-path dataplane/Cargo.toml --release",
		"dataplane:check": "cargo check --manifest-path dataplane/Cargo.toml",
		"dataplane:dev": "cargo run --manifest-path dataplane/Cargo.toml",
		"db:generate": "drizzle-kit generate:pg",
		"db:push": "drizzle-kit push:pg",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@mongodb-js/zstd": "^7.0.0",
		"@types/bun": "^1.3.13",
		"archiver": "^7.0.1",
		"aws4fetch": "^1.0.20",
		"drizzle-orm": "^0.30.10",
		"fast-xml-parser": "^4.5.6",
		"ioredis": "^5.10.1",
		"motion": "^12.38.0",
		"pg": "^8.20.0",
		"postgres": "^3.4.9",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-icons": "^5.6.0",
		"recharts": "^3.8.1",
		"slack-block-builder": "^2.8.0",
		"tar-stream": "^3.2.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/archiver": "^7.0.0",
		"@types/node": "^20.19.40",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/tar-stream": "^3.1.4",
		"autoprefixer": "^10.5.0",
		"bun-types": "latest",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.20.18",
		"postcss": "^8.5.14",
		"tailwindcss": "3.4.17",
		"vite": "^7.3.3"
	},
	"trustedDependencies": [
		"@mongodb-js/zstd"
	]
}
