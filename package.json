{
	"name": "silo-s3-gateway",
	"version": "1.0.0",
	"scripts": {
		"dev": "concurrently \"bun run --hot src/index.ts\" \"postcss src/styles.css -o src/assets/styles.css --watch\"",
		"build:css": "postcss src/styles.css -o src/assets/styles.css",
		"start": "bun run src/index.ts",
		"db:generate": "drizzle-kit generate:pg",
		"db:push": "drizzle-kit push:pg",
		"db:studio": "drizzle-kit studio",
		"test": "bun run scripts/test.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.985.0",
		"@types/bun": "^1.3.8",
		"archiver": "^7.0.1",
		"aws4fetch": "^1.0.20",
		"drizzle-orm": "^0.30.10",
		"fast-xml-parser": "^4.5.3",
		"handlebars": "^4.7.8",
		"ioredis": "^5.9.2",
		"pg": "^8.18.0",
		"postgres": "^3.4.8",
		"slack-block-builder": "^2.8.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@aws-sdk/s3-request-presigner": "^3.985.0",
		"@biomejs/biome": "^2.3.14",
		"@types/archiver": "^7.0.0",
		"@types/node": "^20.19.33",
		"autoprefixer": "^10.4.24",
		"bun-types": "latest",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.20.18",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "3.4.17"
	}
}
