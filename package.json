{
	"name": "silo-s3-gateway",
	"version": "1.0.0",
	"scripts": {
		"dev": "concurrently \"bun run --hot src/index.ts\" \"vite build --watch --mode development\"",
		"build:frontend": "vite build",
		"build": "npm run build:frontend",
		"start": "bun run src/index.ts",
		"db:generate": "drizzle-kit generate:pg",
		"db:push": "drizzle-kit push:pg",
		"db:studio": "drizzle-kit studio",
		"test": "bun run scripts/test.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.985.0",
		"@types/bun": "^1.3.8",
		"archiver": "^7.0.1",
		"aws4fetch": "^1.0.20",
		"drizzle-orm": "^0.30.10",
		"fast-xml-parser": "^4.5.3",
		"ioredis": "^5.9.2",
		"motion": "^12.38.0",
		"pg": "^8.18.0",
		"postgres": "^3.4.8",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-icons": "^5.6.0",
		"recharts": "^3.8.0",
		"slack-block-builder": "^2.8.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@aws-sdk/s3-request-presigner": "^3.985.0",
		"@biomejs/biome": "^2.3.14",
		"@types/archiver": "^7.0.0",
		"@types/node": "^20.19.33",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"autoprefixer": "^10.4.24",
		"bun-types": "latest",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.20.18",
		"postcss": "^8.5.6",
		"tailwindcss": "3.4.17",
		"vite": "^7.1.3"
	}
}
