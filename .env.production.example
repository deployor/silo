# Silo production environment reference
#
# Do not mount this combined example into every container. In production,
# split it into:
#   1. a host/Compose environment (SILO_*, image digests, cache password),
#   2. one Bun control-plane secret file, and
#   3. one region-specific Rust dataplane secret file.
# Physical provider credentials belong only in the dataplane file. Store the
# real files in Infisical and render them mode 0600 for Dokploy/Compose.

# ---------------------------------------------------------------------------
# Host and Compose deployment (example: the EU host)
# ---------------------------------------------------------------------------
SILO_REGION=eu-central
SILO_INSTANCE_ID=eu-central-a
COMPOSE_PROFILES=control-plane
# Dokploy writes its service environment to `.env`. Override these with
# `/run/secrets/...` only when a host-side secret renderer creates those files.
SILO_CONTROL_ENV_FILE=.env
SILO_DATAPLANE_ENV_FILE=.env
DRAGONFLY_IMAGE=docker.dragonflydb.io/dragonflydb/dragonfly:<reviewed-version-or-digest>
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:<reviewed-version-or-digest>
REDIS_PASSWORD=<unique-random-eu-cache-password>
DRAGONFLY_MAX_MEMORY=8gb
SIGNOZ_OTLP_ENDPOINT=signoz.example.internal:4317
SIGNOZ_INGESTION_KEY=<secret-if-required>
# Bun production defaults: keep parent sampling decisions, sample 5% of new
# root traces, and export metrics every 10 seconds. Override deliberately per
# environment only after checking SigNoz volume and tail-latency impact.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.05
OTEL_METRIC_EXPORT_INTERVAL=10000
GIT_SHA=<deployed-commit>

# Public host ownership. onsilo.dev and eu.onsilo.dev are EU; us.onsilo.dev is
# US. Fixed origins never move and are used for health checks and protected
# control-plane calls. Both dataplanes accept the complete host registry so a
# surviving region can serve either logical region after fenced failover.
S3_DOMAIN=onsilo.dev
DASHBOARD_DOMAIN=dash.onsilo.dev
DATAPLANE_ORIGIN_DOMAINS=onsilo.dev,eu.onsilo.dev,us.onsilo.dev,eu-origin.onsilo.dev,us-origin.onsilo.dev
DATAPLANE_INGRESS_DOMAINS={"onsilo.dev":"eu-central","eu.onsilo.dev":"eu-central","us.onsilo.dev":"us-east","eu-origin.onsilo.dev":"eu-central","us-origin.onsilo.dev":"us-east"}
# Bun must follow the logical public endpoint so these calls follow regional
# DNS after failover. The independent status controller uses fixed origins.
DATAPLANE_REGION_URLS_JSON={"eu-central":"https://onsilo.dev","us-east":"https://us.onsilo.dev"}
DASHBOARD_ORIGIN_DOMAINS=control-origin.onsilo.dev,primary-dashboard-origin.onsilo.dev
CONTROL_PLANE_URL=http://control-plane:3000

# ---------------------------------------------------------------------------
# Shared authoritative services and internal authentication
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
DATABASE_URL=postgres://user:password@your-aiven-host:port/silo?sslmode=require
REDIS_URL=redis://:<regional-cache-password>@dragonfly:6379
DATAPLANE_INTERNAL_SECRET=<at-least-32-random-characters-shared-by-bun-rust-and-status>
S3_REGION=auto

# ---------------------------------------------------------------------------
# Bun control plane only (one global instance, normally on the EU host)
# ---------------------------------------------------------------------------
HC_AUTH_CLIENT_ID=<secret>
HC_AUTH_CLIENT_SECRET=<secret>
HC_AUTH_REDIRECT_URI=https://dash.onsilo.dev/auth/callback
SLACK_BOT_TOKEN=<secret>
SLACK_SIGNING_SECRET=<secret>
SLACK_FILE_UPLOAD_CHANNEL_ID=
REVOCATION_SECRET=<independent-random-secret>

# Bun talks to each regional dataplane through DATAPLANE_REGION_URLS_JSON. It
# must not receive S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_ENDPOINT,
# S3_BUCKET_NAME, or DATAPLANE_STORAGE_REGIONS.
DATAPLANE_URL=http://dataplane:3001

# Optional product features.
DOMAINS=false
DEEP_FREEZE=false
DEEP_FREEZE_STORAGE_PREFIX=deep-freeze
CF_API_TOKEN=
CF_ZONE_ID=
CF_SAAS_FALLBACK_ORIGIN=
CF_SAAS_TARGET=onsilo.dev
CF_SAAS_MIN_TLS=1.2
BUCKET_USAGE_RECONCILE_INTERVAL_MS=600000
CUSTOM_DOMAIN_REVALIDATE_INTERVAL_MS=600000

# ---------------------------------------------------------------------------
# Rust dataplane only (this example is the normal EU secret bundle)
# ---------------------------------------------------------------------------
DATAPLANE_MODE=regional
DATAPLANE_REGION=eu-central
DATAPLANE_BIND=0.0.0.0:3001
DATAPLANE_PUBLIC_SCHEME=https
DATAPLANE_WRITER_INSTANCE_ID=eu-central-a
DATAPLANE_WRITER_AUTO_CLAIM=true
DATAPLANE_WRITER_LEASE_SECONDS=30
DATAPLANE_DATABASE_MAX_CONNECTIONS=32
DATAPLANE_WRITER_MAX_CONNECTIONS=8
DATAPLANE_HTTP_POOL_MAX_IDLE_PER_HOST=128
DATAPLANE_ACTIVE_BACKEND_CACHE_TTL_MS=1000
DATAPLANE_BACKEND_VERIFICATION_MAX_AGE_SECONDS=300
DATAPLANE_MAINTENANCE_REFRESH_SECONDS=3
DATAPLANE_REDIS_OBJECT_CACHE_ENABLED=true
RUST_LOG=info,tower_http=warn

# One logical region may have multiple real S3-compatible physical buckets.
# Backend IDs are stable identities and must match Aiven and the status
# REGION_REGISTRY. `primary` is initially active; replicas are standby targets.
# Use forcePathStyle only when that provider requires it. Bucket names may not
# contain dots in the current dataplane registry validation.
DATAPLANE_STORAGE_REGIONS={"eu-central":{"defaultBackend":"primary","backends":{"primary":{"endpoint":"s3.eu-provider.example","endpointScheme":"https","bucket":"silo-eu-primary","accessKeyId":"<eu-primary-key>","secretAccessKey":"<eu-primary-secret>","signingRegion":"auto","forcePathStyle":false},"replica-1":{"endpoint":"s3.eu-replica-provider.example","endpointScheme":"https","bucket":"silo-eu-replica-1","accessKeyId":"<eu-replica-key>","secretAccessKey":"<eu-replica-secret>","signingRegion":"auto","forcePathStyle":true}}}}

# Normal operation is local-only and contains no remote-region credentials.
# The signed activation hook atomically renders a bundle that adds the failed
# logical region to DATAPLANE_STORAGE_REGIONS and DATAPLANE_FAILOVER_REGIONS,
# then restarts this process. The deactivation hook removes both after DNS
# grace. Never pre-authorize both dataplanes for one another permanently.
DATAPLANE_FAILOVER_REGIONS=
DATAPLANE_REGION_PEERS=

# Local, non-authoritative caches. Use a persistent fast volume for the disk
# cache; each region has its own Dragonfly and its own disk-cache volume.
DISK_CACHE_ENABLED=true
DISK_CACHE_DIR=/var/cache/silo-dataplane
DISK_CACHE_MAX_TOTAL_SIZE=21474836480
DISK_CACHE_MIN_SIZE=10485760
DISK_CACHE_MAX_FILE_SIZE=2147483648
DISK_CACHE_ADMISSION_HITS=2
DISK_CACHE_MAX_ENTRY_AGE_MS=43200000
DISK_CACHE_STATS_CACHE_TTL_MS=3000

# Accounting writes directly to Aiven or falls back to this fsync-backed disk
# spool. Dragonfly is never an accounting durability layer. Keep the spool on
# persistent regional storage and preserve it through container replacement.
DATAPLANE_ACCOUNTING_SPOOL_DIR=/var/cache/silo-dataplane/accounting
# If neither Aiven nor the disk spool can accept an event, the dataplane enters
# an unsafe state and attempts to persist this sticky teardown-blocking marker.
DATAPLANE_ACCOUNTING_UNSAFE_MARKER=/var/cache/silo-dataplane/accounting/UNSAFE

# Required in production. Use the exact same independent secret on Bun and on
# every Rust dataplane; never rotate it one process/region at a time.
OFFBOARDING_EXPORT_DERIVATION_SECRET=<independent-at-least-24-character-secret>

# OpenTelemetry is normally overridden by docker-compose.prod.yml.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=silo-dataplane
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,silo.region=eu-central
