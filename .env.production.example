NODE_ENV=production
PORT=3000

# Public routing:
# - S3_DOMAIN should point at the Rust dataplane.
# - DASHBOARD_DOMAIN should point at the Bun control-plane.
#   It must be a hostname only (no https://). It defaults to dash.S3_DOMAIN.
S3_DOMAIN=onsilo.dev
DASHBOARD_DOMAIN=dash.onsilo.dev
# DNS-only hostname used by the independent monitor even when dash.onsilo.dev
# has been redirected to the external status page.
DASHBOARD_ORIGIN_DOMAINS=primary-dashboard-origin.onsilo.dev

# Aiven is the production source of truth. Use its TLS connection string;
# both PawHost and the temporary Hetzner dataplane connect to this same URL.
DATABASE_URL=postgres://user:password@your-aiven-host:port/silo?sslmode=require
# Used by docker-compose.prod.yml to configure the private Dragonfly service
# and both services' internal Redis URL. Use a URL-safe random value.
REDIS_PASSWORD=replace-me

S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_ENDPOINT=fsn1.your-objectstorage.com
# Production defaults to HTTPS. HTTP exists only for isolated local fixtures.
S3_ENDPOINT_SCHEME=https
S3_BUCKET_NAME=replace-me
S3_REGION=auto

# Rust data-plane disk cache. Mount DISK_CACHE_DIR on persistent fast local
# storage in production.
DISK_CACHE_ENABLED=true
DISK_CACHE_DIR=/var/cache/silo-dataplane
DISK_CACHE_MAX_TOTAL_SIZE=21474836480
DISK_CACHE_MIN_SIZE=10485760
DISK_CACHE_MAX_FILE_SIZE=2147483648
DISK_CACHE_ADMISSION_HITS=2
DISK_CACHE_MAX_ENTRY_AGE_MS=43200000

# Rust provider HTTP client tuning.
DATAPLANE_HTTP_POOL_MAX_IDLE_PER_HOST=128
DATAPLANE_MAINTENANCE_REFRESH_SECONDS=3
# production is the default. emergency disables the disk cache and tunes
# pools down; it is set only by deploy/emergency/docker-compose.yml.
DATAPLANE_MODE=production
DATAPLANE_WRITER_INSTANCE_ID=primary
DATAPLANE_WRITER_AUTO_CLAIM=true
DATAPLANE_WRITER_LEASE_SECONDS=30
DATAPLANE_WRITER_MAX_CONNECTIONS=8
# Fixed DNS-only origin used by the external monitor after onsilo.dev has
# failed over. It is accepted as a path-style S3 host by the Rust dataplane.
DATAPLANE_ORIGIN_DOMAINS=primary-origin.onsilo.dev
DATAPLANE_REDIS_OBJECT_CACHE_ENABLED=true

# Required by both services. Use a long random value and keep the internal
# dataplane endpoints off the public internet where possible.
DATAPLANE_INTERNAL_SECRET=replace-with-at-least-24-random-characters

HC_AUTH_CLIENT_ID=replace-me
HC_AUTH_CLIENT_SECRET=replace-me
HC_AUTH_REDIRECT_URI=https://dash.onsilo.dev/auth/callback

SLACK_BOT_TOKEN=replace-me
SLACK_SIGNING_SECRET=replace-me

# Optional feature flags/config.
DOMAINS=false
DEEP_FREEZE=false
