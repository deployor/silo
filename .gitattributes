# Enforce consistent line endings across OSes.
# Keep repository & working tree text files as LF.
* text=auto eol=lf

# Explicit common text formats
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.hbs text eol=lf
*.sql text eol=lf
*.env text eol=lf

# Shell / scripts
*.sh  text eol=lf

# Treat these as binary to prevent corruption
*.woff2 binary
*.woff  binary
*.ttf   binary
*.otf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
